{
  "name": "kokkai-voice",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/update-project-status.mjs --quiet && astro build",
    "preview": "astro preview",
    "deploy:site": "node scripts/deploy-site.mjs",
    "deploy:extras": "node scripts/notify-search-engines.mjs --live && node scripts/post-to-buffer.mjs --recent 1 && node scripts/check-buffer.mjs",
    "deploy": "npm run deploy:site && npm run deploy:extras",
    "deploy:win": "node scripts/deploy-site.mjs",
    "browser:setup": "playwright install chromium",
    "status": "node scripts/update-project-status.mjs --print",
    "check:case": "node scripts/check-case-page.mjs",
    "check:case:all": "node scripts/check-case-page.mjs --all",
    "pipeline": "node scripts/run-case-pipeline.mjs",
    "pipeline:promote": "node scripts/run-case-pipeline.mjs --promote",
    "pipeline:autorun": "node scripts/pipeline-autorun.mjs",
    "init:article": "node scripts/init-article.mjs",
    "complete:article": "node scripts/complete-article.mjs",
    "x:research": "node scripts/x-research-batch.mjs",
    "legal:check": "node scripts/legal-check.mjs --all",
    "legal:fix": "node scripts/legal-check.mjs --all --fix",
    "promo:pack": "node scripts/generate-promo-pack.mjs",
    "promo:all": "node scripts/generate-promo-pack.mjs --live",
    "promo:sprint": "node scripts/generate-promo-sprint.mjs",
    "titles:brushup": "node scripts/brushup-titles.mjs",
    "promo:recent": "node scripts/generate-promo-pack.mjs --recent 7",
    "promo:weekly": "node scripts/generate-weekly-digest.mjs",
    "notify:search": "node scripts/notify-search-engines.mjs --live",
    "notify:recent": "node scripts/notify-search-engines.mjs --recent 7",
    "notify:slug": "node scripts/notify-search-engines.mjs --slug",
    "buffer:check": "node scripts/check-buffer.mjs",
    "buffer:post": "node scripts/post-to-buffer.mjs --recent 1",
    "buffer:digest": "node scripts/post-daily-digest.mjs",
    "buffer:digest:dry": "node scripts/post-daily-digest.mjs --dry-run",
    "buffer:hot": "node scripts/post-hot-single.mjs",
    "buffer:hot:dry": "node scripts/post-hot-single.mjs --dry-run",
    "buffer:launch": "node scripts/post-x-launch.mjs --slot both",
    "buffer:launch:noon": "node scripts/post-x-launch.mjs --slot noon",
    "buffer:launch:evening": "node scripts/post-x-launch.mjs --slot evening",
    "browser:login": "node scripts/browser-login.mjs",
    "post:hatena": "node scripts/post-hatena-bookmarks.mjs",
    "post:note:intro": "node scripts/post-note-intro.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^5.7.0"
  },
  "devDependencies": {
    "playwright": "^1.52.0",
    "wrangler": "^4.105.0"
  }
}
