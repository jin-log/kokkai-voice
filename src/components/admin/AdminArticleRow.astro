---
import { promoDateShort } from "../../lib/promo-intro-status.mjs";
import { adminBucketBadge } from "../../lib/admin-buckets.mjs";
import { automationModeLabel } from "../../lib/admin-status-guide.mjs";

/** @typedef {import("../../lib/project-status.mjs").SlugStatus} SlugStatus */

interface Props {
  s: SlugStatus;
}

const { s } = Astro.props;
const activity = s.activity ?? [];
const distribution = s.distribution ?? [];
const badge = adminBucketBadge(s);
---

<article
  class:list={[
    "admin-row",
    s.adminHidden && "admin-row--hidden",
    s.publishState === "draft" && "admin-row--draft",
    s.publishState === "live" && !s.adminHidden && "admin-row--live",
    s.specialPublish && "admin-row--special",
    !s.qualityOk && "admin-row--quality-ng",
    s.stall?.stalled && "admin-row--stalled",
    s.runState === "active" && "admin-row--active",
  ]}
  data-slug={s.slug}
  data-publish-state={s.publishState}
  data-admin-bucket={s.adminBucket || "prep"}
  data-owner-todo={s.ownerTodo ? "1" : "0"}
  data-special-publish={s.specialPublish ? "1" : "0"}
  data-quality-ng={!s.qualityOk ? "1" : "0"}
  data-stall={s.stall?.stalled ? "1" : "0"}
  data-gold-pct={s.goldPct}
  data-title={s.shortTitle}
  data-category={s.category || ""}
>
  <div class="admin-row__grid">
    <div class="admin-row__meter" aria-hidden="true">
      <span class="admin-row__meter-fill" style={`height: ${s.goldPct}%`}></span>
      <span class="admin-row__meter-label">{s.goldPct}</span>
    </div>

    <div class="admin-row__main">
      <header class="admin-row__head">
        <h3 class="admin-row__title">
          {s.previewUrl ? (
            <a href={s.previewUrl} target="_blank" rel="noopener">{s.shortTitle}</a>
          ) : s.publishState === "live" && !s.adminHidden ? (
            <a href={`/case/${s.slug}/`}>{s.shortTitle}</a>
          ) : (
            s.shortTitle
          )}
        </h3>
        <div class="admin-row__badges">
          <span class:list={["admin-row__badge", "admin-row__badge--state", `admin-row__badge--bucket-${s.adminBucket || "prep"}`]}>
            {badge}
          </span>
          {s.category && (
            <span class:list={["admin-row__badge", "admin-row__badge--cat", `admin-row__badge--cat-${s.category}`]}>
              {s.category}
            </span>
          )}
        </div>
      </header>

      {s.statusExplain && (
        <p class="admin-row__explain" data-role="status-explain">{s.statusExplain}</p>
      )}

      <p class="admin-row__revise-link">
        <a href={`/dev/articles/revise/${s.slug}/`}>ブロック修正</a>
      </p>

      {s.stall?.stalled && (
        <div class="admin-row__stall" data-role="stall-box">
          <p class="admin-row__stall-title">自動処理が止まっている</p>
          {s.stall.ownerHint && <p class="admin-row__stall-hint">{s.stall.ownerHint}</p>}
        </div>
      )}

      {s.specialPublish && s.specialPublishSummary && (
        <p class="admin-row__special-note">未完了: {s.specialPublishSummary}</p>
      )}

      {s.pageReady && s.titleAnswerOk === false && (
        <p class="admin-row__title-warn">公開中だが1行目がタイトルに未回答</p>
      )}
    </div>

    <div class="admin-row__quick">
      <a href={`/dev/articles/revise/${s.slug}/`} class="admin-row__btn admin-row__btn--ghost">
        ブロック修正
      </a>
      {s.previewUrl && (
        <a href={s.previewUrl} class="admin-row__btn admin-row__btn--ghost" target="_blank" rel="noopener">
          プレビュー
        </a>
      )}
      {s.publishGateOk && !s.pageReady ? (
        <button type="button" class="admin-row__btn admin-row__btn--primary publish-slug-btn" data-slug={s.slug}>
          公開する
        </button>
      ) : s.publishState === "live" ? (
        <a href={`/case/${s.slug}/`} class="admin-row__btn admin-row__btn--ghost" data-role="live-link">本番を見る</a>
      ) : (
        <span class="admin-row__gate-hint" data-role="gate-hint">
          {s.adminBucket === "prep" ? `完成度 ${s.goldPct}%` : "—"}
        </span>
      )}
      <span class="deploy-slug-status" data-slug={s.slug} hidden></span>
    </div>
  </div>

  <details class="admin-row__details admin-disclosure">
    <summary class="admin-disclosure__summary">
      <span class="admin-disclosure__chev" aria-hidden="true"></span>
      <span class="admin-disclosure__label">詳細・編集を開く</span>
      <span class="admin-disclosure__hint">タイトル変更・非表示・履歴</span>
    </summary>
    <div class="admin-row__details-body">
      <p class="admin-row__slug"><code>{s.slug}</code></p>
      {(s.workItems ?? []).length > 0 && (
        <ul class="admin-row__work" aria-label="内部チェック（詳細）">
          {(s.workItems ?? []).map((w) => (
            <li class:list={["admin-row__work-item", w.state === "active" && "is-active", w.state === "blocked" && "is-blocked"]}>
              <span class="admin-row__work-icon" aria-hidden="true">
                {w.state === "active" ? "◌" : "✕"}
              </span>
              <span>{w.label}</span>
            </li>
          ))}
        </ul>
      )}
      <div class="status-card__bar" role="progressbar" aria-valuenow={s.goldPct} aria-valuemin={0} aria-valuemax={100}>
        <span style={`width: ${s.goldPct}%`} />
      </div>
      <ul class="admin-row__promo">
        <li class:list={s.promo?.x && "is-done"}>X {s.promo?.x ? promoDateShort(s.promo.x) : "—"}</li>
        <li class:list={s.promo?.hatena && "is-done"}>はてブ {s.promo?.hatena ? promoDateShort(s.promo.hatena) : "—"}</li>
        <li class:list={s.promo?.note && "is-done"}>note {s.promo?.note ? promoDateShort(s.promo.note) : "—"}</li>
        <li>Shorts {s.short?.label ?? "未"}</li>
      </ul>
      {distribution.length > 0 && (
        <table class="admin-row__dist" aria-label="発信の自動化と実績">
          <thead>
            <tr>
              <th>チャネル</th>
              <th>方式</th>
              <th>状態</th>
            </tr>
          </thead>
          <tbody>
            {distribution.map((d) => (
              <tr class:list={[d.done && "is-done"]}>
                <td>{d.channel}</td>
                <td>{automationModeLabel(d.automation)}</td>
                <td>{d.status}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
      {activity.length > 0 && (
        <div class="admin-row__history">
          <p class="admin-row__history-title">操作・自動処理の履歴</p>
          <ol class="admin-row__history-list">
            {activity.map((e) => (
              <li>
                <time datetime={e.at}>{e.when}</time>
                <span>{e.line}</span>
              </li>
            ))}
          </ol>
        </div>
      )}
      {(s.specialPublish || !s.published) && s.blockers.length > 0 && (
        <div class="status-card__blockers">
          <p class="status-card__blockers-title">{s.specialPublish ? "特別公開 — ゲート未達" : "ゲート未達"}</p>
          <ol class="status-card__blockers-list">
            {s.blockers.map((b) => (
              <li>
                <strong>{b.label ?? b.id}</strong>
                <span>{b.todo ?? b.detail}</span>
              </li>
            ))}
          </ol>
        </div>
      )}
      {!s.qualityOk && (s.qualityBlockers?.length ?? 0) > 0 && (
        <div class="status-card__blockers status-card__blockers--quality">
          <p class="status-card__blockers-title">品質NG</p>
          <ol class="status-card__blockers-list">
            {s.qualityBlockers.map((q) => (
              <li>
                <strong>{q.id}</strong>
                <span>{q.message}</span>
              </li>
            ))}
          </ol>
        </div>
      )}
      <div class="status-card__title-edit">
        <input type="text" class="status-card__title-input" value={s.title} data-slug={s.slug} aria-label="タイトル" />
        <button type="button" class="admin-row__btn save-title-btn" data-slug={s.slug}>保存</button>
        <span class="title-save-status" data-slug={s.slug} hidden></span>
      </div>
      <div class="admin-row__admin-btns">
        {s.adminHidden ? (
          <button type="button" class="admin-row__btn unhide-btn" data-slug={s.slug}>表示に戻す</button>
        ) : (
          <button type="button" class="admin-row__btn hide-btn" data-slug={s.slug}>非表示</button>
        )}
        <button type="button" class="admin-row__btn admin-row__btn--danger delete-btn" data-slug={s.slug}>削除</button>
        <span class="admin-action-status" data-slug={s.slug} hidden></span>
      </div>
    </div>
  </details>
</article>
