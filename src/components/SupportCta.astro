---
import { SITE } from "../lib/site-config.mjs";
import {
  noteMembershipButtonLabel,
  noteMembershipLink,
  noteTipLink,
} from "../lib/note-link.mjs";

interface Props {
  /** 案件 slug（計測用） */
  context?: string;
}

const { context = "site" } = Astro.props;
const variant = SITE.supportAbVariant ?? "a";
const memberUrl = noteMembershipLink("support_cta", context);
const memberUrlWithAb = memberUrl
  ? `${memberUrl}&utm_campaign=ab_${variant}`
  : null;
const tipUrl = noteTipLink("support_cta", context);
const memberBtnLabel = noteMembershipButtonLabel();
---

<section class="support-cta" aria-labelledby="support-cta-title" data-support-cta data-ab={variant}>
  <h2 id="support-cta-title" class="support-cta__title">
    {variant === "a" ? "この整理、続けたい？" : "追いかけ続けるには"}
  </h2>
  <p class="support-cta__body">
    {
      variant === "a"
        ? "無料の記事は広告と X で運営しています。週次ダイジェストは note メンバー、今回だけの応援はチップ（任意）から。"
        : "公言と行動のギャップは、時間が経つほど見えにくくなります。メンバー向けに週次ダイジェストと深掘りを配信予定です。"
    }
  </p>
  {
    memberUrlWithAb ? (
      <a
        href={memberUrlWithAb}
        class="support-cta__btn"
        target="_blank"
        rel="noopener noreferrer"
        data-track="support-note-member"
        data-ab={variant}
      >
        {memberBtnLabel}
      </a>
    ) : (
      <p class="support-cta__soon">
        note 準備中 —
        <a href={SITE.xUrl} target="_blank" rel="noopener noreferrer">
          {SITE.xHandle}
        </a>
        をフォロー
      </p>
    )
  }
  {
    tipUrl && (
      <p class="support-cta__tip">
        今回だけ応援する →
        <a
          href={tipUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-track="support-note-tip"
        >
          チップ（任意）
        </a>
      </p>
    )
  }
  <p class="support-cta__note">サイト本体は引き続き無料。個人名は出しません。</p>
</section>
