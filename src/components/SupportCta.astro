---
import { SUPPORT } from "../lib/support-copy.mjs";
import { noteMembershipLink, noteTipLink } from "../lib/note-link.mjs";

interface Props {
  /** 案件 slug（計測用） */
  context?: string;
}

const { context = "site" } = Astro.props;
const memberUrl = noteMembershipLink("support_cta", context);
const tipUrl = noteTipLink("support_cta", context);
if (!memberUrl && !tipUrl) return null;
---

<aside class="support-cta" data-support-cta aria-label="運営支援">
  <div class="support-cta__inner container">
    <p class="support-cta__lead">{SUPPORT.lead}</p>
    <div class="support-cta__actions">
      {
        memberUrl && (
          <a
            href={memberUrl}
            class="support-cta__btn"
            target="_blank"
            rel="noopener noreferrer"
            data-track="support-note-member"
          >
            {SUPPORT.memberBtn}
          </a>
        )
      }
      {
        tipUrl && (
          <a
            href={tipUrl}
            class="support-cta__btn"
            target="_blank"
            rel="noopener noreferrer"
            data-track="support-note-tip"
          >
            {SUPPORT.tipBtn}
          </a>
        )
      }
    </div>
  </div>
</aside>
