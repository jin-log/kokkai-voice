---
import { formatDate } from "../../lib/case-helpers.mjs";

const { article } = Astro.props;
const s = article.primarySpeech;
const xPosts = article.xPosts || [];
---

<section class="timeline" id="sec-timeline" aria-label="案件タイムライン">
  <article class="timeline-item">
    <time class="timeline-item__date" datetime={s.date}>{formatDate(s.date)}</time>
    <p class="timeline-item__type">
      国会 · {s.nameOfHouse} · {s.nameOfMeeting}
    </p>
    <div class="event-card">
      <p class="event-card__who">
        {s.speaker}{s.speakerGroup ? `（${s.speakerGroup}）` : ""}
      </p>
      <p class="event-card__meta">
        第{s.session}回国会 · 号 {s.issue} · speechID {s.speechID}
      </p>
      <div class="plain-box">
        <p class="plain-box__label">原文抜粋（speechFull 参照）</p>
        <p>{s.excerpt}</p>
      </div>
      <blockquote class="quote-block">
        <a href={s.speechURL} target="_blank" rel="noopener">国会議事録で原文を見る ↗</a>
        · <a href={s.meetingURL} target="_blank" rel="noopener">会議全文 ↗</a>
      </blockquote>
    </div>
  </article>
  {
    xPosts.map((p) =>
      p.post_url ? (
        <article class="timeline-item">
          <p class="timeline-item__type">X · 枠 {p.slot}</p>
          <div class="event-card">
            <p class="event-card__who">{p.account_label || p.speaker_hint}</p>
            <p class="event-card__meta">
              {p.captured_at
                ? `取得: ${formatDate(p.captured_at.slice(0, 10))} · スクショ済み`
                : "URL登録済み · スクショ取得待ち"}
            </p>
            {p.post_text && (
              <div class="plain-box">
                <p class="plain-box__label">投稿内容</p>
                <p>{p.post_text}</p>
              </div>
            )}
            <blockquote class="quote-block">
              <a href={p.post_url} target="_blank" rel="noopener">元投稿を見る ↗</a>
            </blockquote>
            {
              p.screenshot && (
                <figure class="x-shot">
                  <div class="x-shot__header">
                    <span>スクリーンショットアーカイブ</span>
                    {
                      p.status === "deleted" ? (
                        <span class="x-shot__badge">削除済み</span>
                      ) : (
                        <span class="x-shot__badge x-shot__badge--live">投稿存続</span>
                      )
                    }
                  </div>
                  <div class="x-shot__body">
                    <img
                      src={p.screenshot}
                      alt={`X投稿のスクリーンショット（枠 ${p.slot}）`}
                      loading="lazy"
                    />
                  </div>
                  <figcaption class="x-shot__footer">
                    元URL:{" "}
                    <a href={p.post_url} target="_blank" rel="noopener">
                      {p.post_url}
                    </a>
                    {p.captured_at && ` · 取得: ${p.captured_at.slice(0, 10)}`}
                  </figcaption>
                </figure>
              )
            }
          </div>
        </article>
      ) : (
        <article class="timeline-item">
          <p class="timeline-item__type">X · 枠 {p.slot}（URL未登録）</p>
          <div class="event-card event-card--pending">
            <p class="event-card__meta">国会議員の関連投稿 — スクショ取得待ち</p>
            <div class="plain-box">
              <p class="plain-box__label">X調査中</p>
              <p>ツイートURLを登録 → Playwrightスクショ → R2保存（API不使用）</p>
            </div>
          </div>
        </article>
      )
    )
  }
</section>
