---
import { formatDate } from "../../lib/case-helpers.mjs";
import {
  getTimelineEvents,
  sortTimelineEvents,
  TIMELINE_INITIAL_VISIBLE,
} from "../../lib/timeline.mjs";
import { showsDietPendingUI } from "../../lib/diet-pending.mjs";
import { showsXUnavailableNotice } from "../../lib/x-research-policy.mjs";
import { TIMELINE_SOURCE } from "../../lib/x-post-ui.mjs";
import DietPendingNotice from "./DietPendingNotice.astro";
import XUnavailableNotice from "./XUnavailableNotice.astro";
import XPostCard from "./XPostCard.astro";

const { article } = Astro.props;
const defaultOrder = "desc";
const events = sortTimelineEvents(getTimelineEvents(article), defaultOrder);
const dietPending = showsDietPendingUI(article);
const xUnavailable = showsXUnavailableNotice(article);

function sourceOf(type) {
  return TIMELINE_SOURCE[type] ?? TIMELINE_SOURCE.source;
}
---

<section class="timeline-section" id="sec-timeline" aria-label="案件タイムライン">
  <div class="timeline-section__head">
    <div class="timeline-section__head-main">
      <h2 class="timeline-section__title">経緯タイムライン</h2>
      {
        events.length > 0 && (
          <p class="timeline-section__lead">
            出来事は追記のみ（過去の記録は原則改変しません）。
            {events.length > TIMELINE_INITIAL_VISIBLE
              ? ` 全${events.length}件 · 直近${TIMELINE_INITIAL_VISIBLE}件を表示`
              : ` 全${events.length}件`}
          </p>
        )
      }
    </div>
    <div class="timeline-controls" data-timeline-controls>
      <button
        type="button"
        class="timeline-controls__btn"
        data-timeline-sort="asc"
        aria-pressed="false"
      >
        古い順
      </button>
      <button
        type="button"
        class="timeline-controls__btn is-active"
        data-timeline-sort="desc"
        aria-pressed="true"
      >
        新しい順
      </button>
    </div>
  </div>

  {xUnavailable && (
    <XUnavailableNotice researchedAt={article.xResearch?.researched_at} />
  )}

  {
    events.length === 0 ? (
      dietPending ? (
        <DietPendingNotice article={article} />
      ) : (
        <p class="timeline-empty">国会・X のイベントはこれから追加します。</p>
      )
    ) : (
      <div
        class="timeline"
        data-timeline-list
        data-timeline-default-sort={defaultOrder}
      >
        {
          events.map((ev, idx) => {
            const hidden = idx >= TIMELINE_INITIAL_VISIBLE;
            const year = ev.date?.slice(0, 4) || "日付不明";
            const prevYear = events[idx - 1]?.date?.slice(0, 4) || "日付不明";
            const showYear = idx === 0 || year !== prevYear;
            const src = sourceOf(ev.type);
            return (
              <>
                {showYear && (
                  <p class="timeline-year" data-timeline-year={year}>
                    {year}
                  </p>
                )}
                <article
                  class:list={["timeline-item", hidden && "timeline-item--hidden"]}
                  data-timeline-item
                  data-timeline-date={ev.date || ""}
                  data-timeline-index={idx}
                  hidden={hidden || undefined}
                >
                  {ev.date && (
                    <time class="timeline-item__date" datetime={ev.date}>
                      {formatDate(ev.date)}
                    </time>
                  )}
                  {ev.type === "speech" && ev.speech && (
                    <>
                      <p class="timeline-item__type">
                        <span class:list={["source-badge", src.badgeClass]}>{src.label}</span>
                        <span class="timeline-item__type-detail">
                          {ev.speech.nameOfHouse} · {ev.speech.nameOfMeeting}
                        </span>
                      </p>
                      <div class:list={["event-card", src.cardClass]}>
                        <p class="event-card__who">
                          {ev.speech.speaker}
                          {ev.speech.speakerGroup
                            ? `（${ev.speech.speakerGroup}）`
                            : ""}
                        </p>
                        {ev.summaryPlain && (
                          <div class="plain-box plain-box--diet">
                            <p class="plain-box__label">ヒヨコでも分かる要約</p>
                            <p>{ev.summaryPlain}</p>
                          </div>
                        )}
                        <blockquote class="quote-block">
                          <a
                            href={ev.speech.speechURL}
                            target="_blank"
                            rel="noopener"
                          >
                            国会議事録で原文を見る ↗
                          </a>
                          {ev.speech.meetingURL && (
                            <>
                              {" "}
                              ·{" "}
                              <a
                                href={ev.speech.meetingURL}
                                target="_blank"
                                rel="noopener"
                              >
                                会議全文 ↗
                              </a>
                            </>
                          )}
                        </blockquote>
                      </div>
                    </>
                  )}
                  {ev.type === "milestone" && (
                    <>
                      <p class="timeline-item__type">
                        <span class:list={["source-badge", src.badgeClass]}>{src.label}</span>
                      </p>
                      <div class:list={["event-card", src.cardClass]}>
                        <p class="event-card__who">{ev.milestone?.label}</p>
                        {ev.summaryPlain && <p>{ev.summaryPlain}</p>}
                        {ev.milestone?.sourceUrl && (
                          <blockquote class="quote-block">
                            <a
                              href={ev.milestone.sourceUrl}
                              target="_blank"
                              rel="noopener"
                            >
                              出典 ↗
                            </a>
                          </blockquote>
                        )}
                      </div>
                    </>
                  )}
                  {ev.type === "source" && (
                    <>
                      <p class="timeline-item__type">
                        <span class:list={["source-badge", src.badgeClass]}>{src.label}</span>
                        <span class="timeline-item__type-detail">公式</span>
                      </p>
                      <div class:list={["event-card", src.cardClass]}>
                        {ev.summaryPlain && <p>{ev.summaryPlain}</p>}
                        {ev.sourceUrl && (
                          <blockquote class="quote-block">
                            <a href={ev.sourceUrl} target="_blank" rel="noopener">
                              出典を見る ↗
                            </a>
                          </blockquote>
                        )}
                      </div>
                    </>
                  )}
                  {ev.type === "x_post" && ev.xPost && (
                    <>
                      <p class="timeline-item__type">
                        <span class:list={["source-badge", src.badgeClass]}>{src.label}</span>
                      </p>
                      <XPostCard xPost={ev.xPost} />
                    </>
                  )}
                </article>
              </>
            );
          })
        }
      </div>
    )
  }

  {
    events.length > TIMELINE_INITIAL_VISIBLE && (
      <button type="button" class="btn timeline-more" data-timeline-more>
        もっと見る（あと{events.length - TIMELINE_INITIAL_VISIBLE}件）
      </button>
    )
  }

  {dietPending && events.length > 0 && <DietPendingNotice article={article} />}

  <div class="x-lightbox" id="x-lightbox" hidden role="dialog" aria-modal="true" aria-label="X投稿スクリーンショット">
    <button type="button" class="x-lightbox__close" aria-label="閉じる">×</button>
    <img class="x-lightbox__img" alt="" />
  </div>
</section>
