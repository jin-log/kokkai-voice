---
import DietPendingNotice from "./DietPendingNotice.astro";
import RichTextWithTermLinks from "./RichTextWithTermLinks.astro";
import { showsDietPendingUI } from "../../lib/diet-pending.mjs";

const { article, variant = "default" } = Astro.props;
const ns = article.nowSummary ?? {};
const bullets = ns.bullets ?? [];
const termLinkUsed = new Set();
const updatedNote = ns.updatedAt ? ` · 要約更新: ${ns.updatedAt.slice(0, 10)}` : "";
const fetchedLabel = article.fetchedAt?.slice(0, 10) ?? "—";
const dietPending = showsDietPendingUI(article);
const isBlocks = variant === "blocks";
---

<div class:list={[isBlocks ? "cb-now" : "now-box"]} id="sec-now">
  <p class:list={[isBlocks ? "cb-now__label" : "now-box__label"]}>
    {isBlocks ? "いまの結論" : ns.label || "いまどうなってる？"}
  </p>
  {dietPending && <DietPendingNotice article={article} variant="inline" />}
  {
    bullets.length > 0 ? (
      <ul class:list={[isBlocks ? undefined : "now-box__bullets"]}>
        {bullets.map((b) => (
          <li>
            <RichTextWithTermLinks text={b} article={article} usedTerms={termLinkUsed} />
          </li>
        ))}
      </ul>
    ) : ns.text ? (
      <p class:list={[isBlocks ? undefined : "now-box__text"]}>{ns.text}</p>
    ) : null
  }
  <p class:list={[isBlocks ? "now-box__updated" : "now-box__updated"]}>
    データ取得: {fetchedLabel}
    {!dietPending && article.apiHits != null && <> · APIヒット {article.apiHits}件</>}
    {updatedNote} · {ns.disclaimer}
  </p>
</div>
