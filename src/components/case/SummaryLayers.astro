---
import RichTextWithTermLinks from "./RichTextWithTermLinks.astro";
import {
  hasDietSourceContent,
  showsDietPendingUI,
} from "../../lib/diet-pending.mjs";

const { article, usedTerms } = Astro.props;
const bullets = article.summaryBullets || [];
const hasBullets = bullets.length > 0;
const termLinkUsed = usedTerms ?? new Set();
const dietPending = showsDietPendingUI(article);
const dietSourced = hasDietSourceContent(article);
const publicSourced = dietPending || !dietSourced;
const aiDisclaimer =
  article.nowSummary?.disclaimer ||
  (dietPending
    ? "AI補助による要約です。解釈を含みます。数字・引用の正本は報道・公開ソースをご確認ください。国会議事録は掲載待ちです。"
    : dietSourced
      ? "AI補助による要約です。解釈を含みます。数字・引用・発言内容の正本は国会議事録リンクをご確認ください。"
      : "AI補助による要約です。解釈を含みます。数字・引用の正本は各出典リンクをご確認ください。");

function splitSummaryBullet(b) {
  if (b && typeof b === "object") {
    const head = String(b.key || b.headline || "").trim();
    const detail = String(b.detail || b.text || "").trim();
    return { head, detail };
  }
  const s = String(b ?? "").trim();
  const m = s.match(/^([^：:—＝]{2,28})\s*[：—＝]\s*(.+)$/u);
  if (m) return { head: m[1].trim(), detail: m[2].trim() };
  return { head: "", detail: s };
}

const items = bullets.map(splitSummaryBullet);
---

{
  hasBullets && (
    <section id="sec-detail" class="summary-layers" aria-label="根拠となるポイント">
      <div class="plain-box">
        <p class="plain-box__label">
          {publicSourced
            ? "根拠となるポイント（報道・公開情報）"
            : "根拠となるポイント（国会の発言から）"}
        </p>
        <p class="summary-layers__lead">
          {dietPending
            ? "上の「いまの結論」を支える事実の整理。国会議事録は更新次第、タイムラインに追記します。"
            : publicSourced
              ? "上の「いまの結論」を支える事実の整理。結論そのものではなく、公開情報の要点です。"
              : "上の「いまの結論」を支える事実の整理。結論そのものではなく、国会で語られた内容の要点です。"}
        </p>
        <ul class="summary-bullets">
          {items.map((item) => (
            <li class="summary-bullets__item">
              {item.head ? (
                <>
                  <span class="summary-bullets__head">{item.head}</span>
                  <span class="summary-bullets__detail">
                    <RichTextWithTermLinks
                      text={item.detail}
                      article={article}
                      usedTerms={termLinkUsed}
                    />
                  </span>
                </>
              ) : (
                <RichTextWithTermLinks
                  text={item.detail}
                  article={article}
                  usedTerms={termLinkUsed}
                />
              )}
            </li>
          ))}
        </ul>
      </div>
      <p class="summary-layers__disclaimer">{aiDisclaimer}</p>
    </section>
  )
}
