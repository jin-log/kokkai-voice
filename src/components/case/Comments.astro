---
import { SITE } from "../../lib/site-config.mjs";

interface Props {
  slug: string;
}
const { slug } = Astro.props;
const live = SITE.commentsLive;
const turnstileKey = SITE.turnstileSiteKey;
---

<section class="comments" aria-labelledby="comments-title" data-comment-section data-slug={slug}>
  {
    !live ? (
      <>
        <h2 id="comments-title">コメント（準備中）</h2>
        <p class="comments__prep">
          ご意見は
          <a href={SITE.xUrl} target="_blank" rel="noopener noreferrer">{SITE.xHandle}</a>
          まで。
        </p>
      </>
    ) : (
      <>
        <h2 id="comments-title">コメント</h2>

        <div class="comment-list-wrap">
          <ul class="comment-list" data-comment-list aria-live="polite"></ul>
        </div>

        <form class="comment-form" data-comment-form>
          <p class="comment-form__lead">この案件について書く</p>
          <label class="comment-field">
            <span class="comment-field__label">ニックネーム（任意）</span>
            <input type="text" name="name" maxlength="32" autocomplete="nickname" />
          </label>
          <label class="comment-field">
            <span class="comment-field__label">コメント</span>
            <textarea
              name="body"
              placeholder="賛成・反対・疑問など"
              maxlength="500"
              required
            ></textarea>
          </label>
          <p class="comment-legal" data-comment-legal hidden aria-live="polite"></p>
          <div class="comment-form__actions">
            <label class="comment-terms">
              <input type="checkbox" name="terms" data-comment-terms required />
              <span>
                <a href="/comment-policy/" target="_blank" rel="noopener">コメント投稿規約</a>に同意する
              </span>
            </label>
            {turnstileKey && (
              <div class="comment-form__turnstile" data-turnstile-host></div>
            )}
            <button type="submit" class="btn btn--primary comment-form__submit" data-comment-submit disabled>
              投稿する
            </button>
          </div>
        </form>
      </>
    )
  }
</section>

{
  live && (
    <>
      {turnstileKey && (
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
      )}
      <script define:vars={{ slug, turnstileKey }}>
        let turnstileToken = "";
        let hardBlocked = false;
        let scanTimer = null;

        const form = document.querySelector("[data-comment-form]");
        const legalEl = document.querySelector("[data-comment-legal]");
        const submitBtn = document.querySelector("[data-comment-submit]");
        const termsBox = document.querySelector("[data-comment-terms]");

        function updateSubmitState() {
          const body = form?.body?.value?.trim() ?? "";
          const termsOk = Boolean(termsBox?.checked);
          if (submitBtn) submitBtn.disabled = !body || hardBlocked || !termsOk;
        }

        function setHardBlock(blocked, hasText) {
          hardBlocked = blocked;
          if (!legalEl) return;
          if (!hasText || !blocked) {
            legalEl.hidden = true;
            legalEl.textContent = "";
            legalEl.className = "comment-legal";
          } else {
            legalEl.hidden = false;
            legalEl.textContent = "投稿できません（卑猥な表現・殺害予告が含まれています）";
            legalEl.className = "comment-legal comment-legal--ng";
          }
          updateSubmitState();
        }

        async function scanLegal() {
          const name = form?.name?.value?.trim() ?? "";
          const body = form?.body?.value?.trim() ?? "";
          if (!body) {
            setHardBlock(false, false);
            return;
          }
          const res = await fetch("/api/comments-scan", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name, body }),
          });
          if (!res.ok) {
            setHardBlock(true, true);
            return;
          }
          const data = await res.json();
          setHardBlock(!data.ok, true);
        }

        function scheduleScan() {
          clearTimeout(scanTimer);
          scanTimer = setTimeout(scanLegal, 350);
        }

        function renderCommentNode(c, { isReply = false } = {}) {
          const li = document.createElement("li");
          li.className = isReply ? "comment comment--reply" : "comment";
          li.dataset.commentId = c.id;
          const goodActive = c.myReaction === "good" ? " is-active" : "";
          const badActive = c.myReaction === "bad" ? " is-active" : "";
          li.innerHTML = `
            <div class="comment__author"></div>
            <p class="comment__body"></p>
            <div class="comment__actions">
              <button type="button" class="comment__react comment__react--good${goodActive}" data-react="good" aria-pressed="${c.myReaction === "good"}">
                👍 <span class="comment__react-num">${c.good ?? 0}</span>
              </button>
              <button type="button" class="comment__react comment__react--bad${badActive}" data-react="bad" aria-pressed="${c.myReaction === "bad"}">
                👎 <span class="comment__react-num">${c.bad ?? 0}</span>
              </button>
              ${isReply ? "" : '<button type="button" class="comment__reply-btn">返信</button>'}
              <span class="comment__time"></span>
              <button type="button" class="comment__report" data-comment-id="">通報</button>
            </div>
            <form class="comment__reply-form" hidden>
              <textarea name="body" placeholder="返信を入力…" maxlength="500" required aria-label="返信"></textarea>
              <button type="submit" class="btn btn--primary btn--sm">返信する</button>
              <button type="button" class="comment__reply-cancel">キャンセル</button>
            </form>
            <ul class="comment__replies"></ul>`;
          li.querySelector(".comment__author").textContent = c.name || "匿名";
          li.querySelector(".comment__body").textContent = c.body;
          li.querySelector(".comment__time").textContent = c.at
            ? new Date(c.at).toLocaleString("ja-JP")
            : "";

          const reportBtn = li.querySelector(".comment__report");
          reportBtn.dataset.commentId = c.id;
          reportBtn.addEventListener("click", () => reportComment(c.id, reportBtn));

          li.querySelectorAll(".comment__react").forEach((btn) => {
            btn.addEventListener("click", () => voteComment(c.id, btn));
          });

          const replyBtn = li.querySelector(".comment__reply-btn");
          const replyForm = li.querySelector(".comment__reply-form");
          const replyCancel = li.querySelector(".comment__reply-cancel");
          replyBtn?.addEventListener("click", () => {
            replyForm.hidden = !replyForm.hidden;
            if (!replyForm.hidden) replyForm.querySelector("textarea")?.focus();
          });
          replyCancel?.addEventListener("click", () => {
            replyForm.hidden = true;
            replyForm.reset();
          });
          replyForm?.addEventListener("submit", (e) => submitReply(e, c.id, replyForm));

          const repliesUl = li.querySelector(".comment__replies");
          for (const child of c.replies ?? []) {
            repliesUl.appendChild(renderCommentNode(child, { isReply: true }));
          }
          return li;
        }

        function buildCommentTree(comments) {
          const byId = new Map();
          const roots = [];
          for (const c of comments) {
            byId.set(c.id, { ...c, replies: [] });
          }
          for (const c of byId.values()) {
            if (c.parentId && byId.has(c.parentId)) {
              byId.get(c.parentId).replies.push(c);
            } else {
              roots.push(c);
            }
          }
          return roots;
        }

        function renderApproved(comments) {
          const list = document.querySelector("[data-comment-list]");
          if (!list) return;
          if (!comments.length) {
            list.innerHTML = `<li class="comment-list__empty">まだコメントはありません。</li>`;
            return;
          }
          list.innerHTML = "";
          for (const c of buildCommentTree(comments)) {
            list.appendChild(renderCommentNode(c));
          }
        }

        async function voteComment(commentId, btn) {
          const kind = btn.dataset.react;
          const isActive = btn.classList.contains("is-active");
          const reaction = isActive ? "clear" : kind;
          btn.disabled = true;
          const res = await fetch("/api/comments-react", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ commentId, slug, reaction }),
          });
          btn.disabled = false;
          if (!res.ok) return;
          const data = await res.json();
          const row = btn.closest(".comment");
          const goodBtn = row?.querySelector('[data-react="good"]');
          const badBtn = row?.querySelector('[data-react="bad"]');
          if (goodBtn) {
            goodBtn.classList.toggle("is-active", data.myReaction === "good");
            goodBtn.setAttribute("aria-pressed", data.myReaction === "good" ? "true" : "false");
            goodBtn.querySelector(".comment__react-num").textContent = String(data.good ?? 0);
          }
          if (badBtn) {
            badBtn.classList.toggle("is-active", data.myReaction === "bad");
            badBtn.setAttribute("aria-pressed", data.myReaction === "bad" ? "true" : "false");
            badBtn.querySelector(".comment__react-num").textContent = String(data.bad ?? 0);
          }
        }

        async function submitReply(e, parentId, replyForm) {
          e.preventDefault();
          const body = replyForm.body.value.trim();
          const acceptedTerms = Boolean(termsBox?.checked);
          if (!body || hardBlocked || !acceptedTerms) {
            if (!acceptedTerms) alert("規約への同意が必要です。");
            return;
          }
          const name = form?.name?.value?.trim() ?? "";
          const res = await fetch("/api/comments", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ slug, name, body, parentId, acceptedTerms }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            alert(data.error || "返信に失敗しました。");
            return;
          }
          replyForm.reset();
          replyForm.hidden = true;
          await loadComments();
        }

        async function reportComment(commentId, btn) {
          if (!confirm("このコメントを通報しますか？")) return;
          btn.disabled = true;
          const res = await fetch("/api/comments-report", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ commentId, slug }),
          });
          if (res.ok) {
            btn.textContent = "通報済み";
          } else {
            btn.disabled = false;
            alert("通報に失敗しました。");
          }
        }

        async function loadComments() {
          const res = await fetch(`/api/comments?slug=${encodeURIComponent(slug)}`);
          if (!res.ok) return;
          const data = await res.json();
          renderApproved(data.comments || []);
        }

        function mountTurnstile() {
          if (!turnstileKey || !window.turnstile) return;
          const host = document.querySelector("[data-turnstile-host]");
          if (!host || host.dataset.mounted) return;
          host.dataset.mounted = "1";
          window.turnstile.render(host, {
            sitekey: turnstileKey,
            size: "compact",
            appearance: "interaction-only",
            feedback: false,
            callback: (token) => {
              turnstileToken = token;
            },
            "expired-callback": () => {
              turnstileToken = "";
            },
          });
        }

        form?.addEventListener("input", () => {
          scheduleScan();
          updateSubmitState();
        });
        termsBox?.addEventListener("change", updateSubmitState);
        form?.addEventListener("submit", async (e) => {
          e.preventDefault();
          const name = form.name.value.trim();
          const body = form.body.value.trim();
          const acceptedTerms = Boolean(termsBox?.checked);
          if (!body || hardBlocked || !acceptedTerms) return;
          if (turnstileKey && !turnstileToken) {
            alert("認証を完了してください。");
            return;
          }
          const res = await fetch("/api/comments", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ slug, name, body, turnstileToken, acceptedTerms }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            alert(data.error || "投稿に失敗しました。");
            return;
          }
          form.reset();
          setHardBlock(false, false);
          turnstileToken = "";
          if (window.turnstile) window.turnstile.reset();
          await loadComments();
        });

        loadComments();
        if (turnstileKey) {
          const timer = setInterval(() => {
            if (window.turnstile) {
              clearInterval(timer);
              mountTurnstile();
            }
          }, 200);
        }
      </script>
    </>
  )
}
