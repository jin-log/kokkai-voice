---
import { SUPPORT } from "../lib/support-copy.mjs";
import { noteMembershipLink, noteTipLink, hasNoteMembership } from "../lib/note-link.mjs";

interface Props {
  content?: string;
}

const { content } = Astro.props;
const memberHref = noteMembershipLink("sticky", content);
const tipHref = noteTipLink("sticky", content);
if (!hasNoteMembership() || (!memberHref && !tipHref)) return null;
---

<div class="note-sticky" data-note-sticky hidden>
  <p class="note-sticky__text">{SUPPORT.stickyText}</p>
  <div class="note-sticky__actions">
    {
      memberHref && (
        <a
          href={memberHref}
          class="note-sticky__btn note-sticky__btn--member"
          target="_blank"
          rel="noopener noreferrer"
          data-track="support-note-member"
        >
          メンバー
        </a>
      )
    }
    {
      tipHref && (
        <a
          href={tipHref}
          class="note-sticky__btn note-sticky__btn--tip"
          target="_blank"
          rel="noopener noreferrer"
          data-track="support-note-tip"
        >
          チップ
        </a>
      )
    }
  </div>
  <button type="button" class="note-sticky__close" data-note-sticky-close aria-label="閉じる">
    ×
  </button>
</div>

<script>
  (function () {
    const KEY = "note-sticky-dismiss";
    const bar = document.querySelector("[data-note-sticky]");
    if (!bar || sessionStorage.getItem(KEY)) return;

    const mq = window.matchMedia("(max-width: 768px)");
    function sync() {
      bar.hidden = !mq.matches;
    }
    sync();
    mq.addEventListener("change", sync);

    bar.querySelector("[data-note-sticky-close]")?.addEventListener("click", () => {
      sessionStorage.setItem(KEY, "1");
      bar.hidden = true;
    });
  })();
</script>
