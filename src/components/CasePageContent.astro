---
/**
 * 案件ページ本体（公開・プレビュー共通）
 */
import ProsCons from "./case/ProsCons.astro";
import ArcSummary from "./case/ArcSummary.astro";
import NowBox from "./case/NowBox.astro";
import ReactionSummary from "./case/ReactionSummary.astro";
import SummaryLayers from "./case/SummaryLayers.astro";
import StanceMatrix from "./case/StanceMatrix.astro";
import Glossary from "./case/Glossary.astro";
import Timeline from "./case/Timeline.astro";
import Comments from "./case/Comments.astro";
import ShareBar from "./case/ShareBar.astro";
import SupportCta from "./SupportCta.astro";
import NoteStickyBar from "./NoteStickyBar.astro";
import FloatToc from "./case/FloatToc.astro";
import FloatReact from "./case/FloatReact.astro";
import { articleShortTitle, shouldPublishParty } from "../lib/case-helpers.mjs";
import { dietPendingBadgeLabel } from "../lib/diet-pending.mjs";

const { article, stance, preview = false } = Astro.props;
const hasStance =
  stance &&
  (stance.matrix.parties ?? []).filter(shouldPublishParty).length > 0;
const shortTitle = articleShortTitle(article);
const sourceTag =
  article.category === "国会" ? "国会議事録 API" : `${article.category || "報道"}・公開ソース`;
const dietBadge = dietPendingBadgeLabel(article);
---

{preview && (
  <div class="preview-banner" role="status">
    <p class="preview-banner__text">
      <strong>プレビュー（非公開）</strong>
      — 一般公開前の確認用。内容を確認して管理画面から「公開する」を押してください。
    </p>
    <button type="button" class="preview-banner__link" data-admin-nav>← 戻る</button>
  </div>
)}

<main class="container">
  <header class="case-hero">
    <div class="case-hero__tags">
      {article.tags.map((t) => (
        <span class="tag">{t}</span>
      ))}
      <span class="tag tag--source">{sourceTag}</span>
      {dietBadge && <span class="tag tag--diet-pending">{dietBadge}</span>}
      {preview && <span class="tag tag--preview">非公開プレビュー</span>}
    </div>
    <h1 class="case-hero__title">{shortTitle}</h1>

    {!preview && <ShareBar article={article} />}

    <NowBox article={article} />
    <ProsCons article={article} />
    <ArcSummary article={article} />
    <ReactionSummary article={article} />
    <SummaryLayers article={article} />
  </header>

  {hasStance && <StanceMatrix article={article} stance={stance} />}
  <Glossary article={article} />
  <Timeline article={article} />
  {!preview && <SupportCta context={article.slug} />}
  <Comments slug={article.slug} />
</main>

<FloatToc article={article} hasStance={hasStance} />
<FloatReact article={article} />
{!preview && <NoteStickyBar content={article.slug} />}
