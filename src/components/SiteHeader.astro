---
import { SITE } from "../lib/site-config.mjs";
import { noteMembershipLink } from "../lib/note-link.mjs";
import { ASSET_V } from "../lib/case-helpers.mjs";

interface Props {
  showSearch?: boolean;
  searchQuery?: string;
}

const { showSearch = false, searchQuery = "" } = Astro.props;
const noteHref = noteMembershipLink("header");
---

<header class="site-header">
  <div class="container site-header__inner site-header__inner--search">
    <a class="logo" href="/">
      <img
        class="logo__img"
        src={`/assets/logo-header-nihon-seiji-naw.png?v=${ASSET_V}`}
        alt="日本の政治 now. あの話どうなった？"
        width="1024"
        height="576"
      />
    </a>
    {
      showSearch && (
        <form class="site-search" data-search-form role="search" action="/search" method="get">
          <label class="visually-hidden" for="header-q">案件を検索</label>
          <input
            id="header-q"
            class="site-search__input"
            type="search"
            name="q"
            placeholder="物価高、都知事、リコール…"
            value={searchQuery}
          />
          <button type="submit" class="site-search__btn">検索</button>
        </form>
      )
    }
    <nav class="nav" aria-label="メイン">
      {
        noteHref && (
          <a
            href={noteHref}
            class="nav__note-link"
            target="_blank"
            rel="noopener noreferrer"
            data-track="support-note"
          >
            note ¥500
          </a>
        )
      }
      <a
        href={SITE.xUrl}
        class="nav__x-link"
        target="_blank"
        rel="noopener noreferrer"
        data-track="header-x"
      >
        <span class="nav__x-icon" aria-hidden="true">𝕏</span>
        <span class="nav__x-label">{SITE.xHandle}</span>
      </a>
      <a href="/search" class="nav__all-btn">すべての案件</a>
    </nav>
  </div>
</header>
