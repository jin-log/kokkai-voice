---
import { articleShortTitle, caseCardMeta } from "../lib/case-helpers.mjs";
import { getTimelineEvents } from "../lib/timeline.mjs";

const { article } = Astro.props;
const { goodPct, updated, tagLine, summary } = caseCardMeta(article);
const events = getTimelineEvents(article);
const eventCount = events.length;
const xCount = events.filter((e) => e.type === "x_post").length;
---

<a class="case-card" href={`/case/${article.slug}`}>
  <span class="case-card__tag">{tagLine} · 更新 {updated}</span>
  <h2 class="case-card__title">{article.title}</h2>
  <p class="case-card__summary">{summary}</p>
  <div class="case-card__meta">
    <span>イベント {eventCount}件 · X {xCount}件</span>
    <span class="reaction-pill">😊 {goodPct}%</span>
  </div>
</a>
