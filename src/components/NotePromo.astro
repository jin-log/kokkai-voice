---
import { SUPPORT } from "../lib/support-copy.mjs";
import { noteMembershipLink, noteTipLink } from "../lib/note-link.mjs";

interface Props {
  medium?: string;
  content?: string;
  /** hero = トップのメンバー訴求カード */
  variant?: "hero";
}

const { medium = "banner", content, variant } = Astro.props;
const memberHref = noteMembershipLink(medium, content);
const tipHref = noteTipLink(medium, content);

if (variant === "hero") {
  if (!memberHref) return null;
}
if (!variant && !memberHref && !tipHref) return null;
---

{
  variant === "hero" && memberHref && (
    <section class="note-promo note-promo--hero" aria-labelledby="note-promo-title">
      <h2 id="note-promo-title" class="note-promo__title">{SUPPORT.heroTitle}</h2>
      <p class="note-promo__body">{SUPPORT.heroBody}</p>
      <a
        href={memberHref}
        class="note-promo__btn note-promo__btn--member"
        target="_blank"
        rel="noopener noreferrer"
        data-track="support-note-member"
      >
        {SUPPORT.heroMemberBtn}
      </a>
    </section>
  )
}
