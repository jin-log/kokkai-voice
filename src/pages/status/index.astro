---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { loadProjectStatus } from "../../lib/project-status.mjs";

const status = await loadProjectStatus().catch(() => null);

function formatJa(iso) {
  if (!iso) return "—";
  return new Date(iso).toLocaleString("ja-JP");
}
---

<BaseLayout
  title="完成度 — 日本の政治なう"
  description="active 案件の完成度と公開状況"
>
  <SiteHeader showSearch />
  <main class="container status-page">
    <h1 class="status-page__title">サイト完成度</h1>
    <p class="status-page__lead">
      active {status?.activeCount ?? 0} 件を <strong>100%完成</strong> まで仕上げてから次を増やす方針です。
      数値はビルド・デプロイの直前に自動更新されます。
    </p>

    {
      status ? (
        <>
          <section class="status-hero" aria-label="全体">
            <div class="status-hero__ring" style={`--pct: ${status.overallGoldPct}`}>
              <span class="status-hero__num">{status.overallGoldPct}%</span>
              <span class="status-hero__sub">100%完成</span>
            </div>
            <dl class="status-hero__stats">
              <div>
                <dt>本番公開</dt>
                <dd>
                  {status.publishedCount} / {status.activeCount} 件
                </dd>
              </div>
              <div>
                <dt>保留（parked）</dt>
                <dd>{status.parkedCount} 件</dd>
              </div>
              <div>
                <dt>ゲート達成率</dt>
                <dd>{status.overallGatePct}%</dd>
              </div>
              <div>
                <dt>最終更新</dt>
                <dd>{formatJa(status.generatedAt)}</dd>
              </div>
              {status.deltaGoldPct != null && status.deltaGoldPct !== 0 && (
                <div>
                  <dt>前回比</dt>
                  <dd class={status.deltaGoldPct > 0 ? "is-up" : "is-down"}>
                    {status.deltaGoldPct > 0 ? "+" : ""}
                    {status.deltaGoldPct}%
                  </dd>
                </div>
              )}
            </dl>
          </section>

          <section class="status-slugs" aria-label="案件別">
            <h2>案件別</h2>
            {status.slugs.map((s) => (
              <article class="status-card">
                <header class="status-card__head">
                  <h3 class="status-card__title">
                    {s.published ? (
                      <a href={`/case/${s.slug}/`}>{s.shortTitle}</a>
                    ) : (
                      s.shortTitle
                    )}
                  </h3>
                  <span class="status-card__pct">{s.goldPct}%</span>
                </header>
                <div
                  class="status-card__bar"
                  role="progressbar"
                  aria-valuenow={s.goldPct}
                  aria-valuemin={0}
                  aria-valuemax={100}
                >
                  <span style={`width: ${s.goldPct}%`} />
                </div>
                <ul class="status-card__checks">
                  {s.gold.map((g) => (
                    <li class:list={["status-check", g.ok && "is-ok"]}>
                      {g.ok ? "✓" : "○"} {g.label}
                    </li>
                  ))}
                </ul>
                {!s.published && s.blockers.length > 0 && (
                  <p class="status-card__blockers">
                    未了: {s.blockers.map((b) => b.id).join(", ")}
                  </p>
                )}
              </article>
            ))}
          </section>

          <section class="status-legend">
            <h2>パイプライン（順番固定）</h2>
            <p class="status-page__lead">
              <strong>公開ゲート</strong> = ①〜④すべてOK → 初めて <code>npm run deploy</code> 可。<br />
              <strong>100%完成</strong> = ⑤デプロイ後に ⑥デバッグOK まで。
            </p>
            <ol>
              <li>①コンテンツ（経緯・国会・要約）</li>
              <li>②〇×2党確定（◎▲❌）</li>
              <li>③X検証2件+</li>
              <li>④法務OK — <em>デプロイ直前</em></li>
              <li>⑤本番デプロイ</li>
              <li>⑥デバッグOK — <em>公開後</em>（<code>qaReview.status: ok</code>）</li>
            </ol>
          </section>
        </>
      ) : (
        <p>status 未生成。CEO が <code>npm run status</code> を実行してください。</p>
      )
    }
  </main>
  <SiteFooter note="完成度は data/project-status.json から表示。" />
</BaseLayout>
