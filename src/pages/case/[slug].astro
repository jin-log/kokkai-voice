---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import NowBox from "../../components/case/NowBox.astro";
import ReactionSummary from "../../components/case/ReactionSummary.astro";
import SummaryLayers from "../../components/case/SummaryLayers.astro";
import StanceMatrix from "../../components/case/StanceMatrix.astro";
import Glossary from "../../components/case/Glossary.astro";
import Timeline from "../../components/case/Timeline.astro";
import Comments from "../../components/case/Comments.astro";
import FloatToc from "../../components/case/FloatToc.astro";
import FloatReact from "../../components/case/FloatReact.astro";
import {
  getArticleSlugs,
  loadArticle,
  loadStanceData,
} from "../../lib/articles.mjs";
import {
  articleShortTitle,
  shouldPublishParty,
} from "../../lib/case-helpers.mjs";

export async function getStaticPaths() {
  const slugs = await getArticleSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const article = await loadArticle(slug);
const stance = await loadStanceData(article);
const hasStance =
  stance &&
  (stance.matrix.parties ?? []).filter(shouldPublishParty).length > 0;
const shortTitle = articleShortTitle(article);
const description = article.primarySpeech.excerpt.slice(0, 120);
---

<BaseLayout
  title={`${shortTitle} — あの話どうなった？｜日本の政治なう`}
  description={description}
  bodyDataCase={article.slug}
  includeAppJs
>
  <SiteHeader />
  <main class="container">
    <header class="case-hero">
      <div class="case-hero__tags">
        {article.tags.map((t) => (
          <span class="tag">{t}</span>
        ))}
        <span class="tag tag--source">国会議事録 API</span>
      </div>
      <h1 class="case-hero__title">{shortTitle}</h1>

      <NowBox article={article} />
      <ReactionSummary article={article} />
      <SummaryLayers article={article} />
    </header>

    {hasStance && <StanceMatrix article={article} stance={stance} />}
    <Glossary article={article} />
    <Timeline article={article} />
    <Comments />
    <p class="demo-note">
      ※ 発言は国会議事録APIの実データ。X枠は構造のみ（URL・スクショ未）。YouTubeショートは未実装。
    </p>
  </main>

  <FloatToc article={article} hasStance={hasStance} />
  <FloatReact article={article} />
</BaseLayout>
