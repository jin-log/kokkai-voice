---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import PreReleaseBanner from "../components/PreReleaseBanner.astro";
import NotePromo from "../components/NotePromo.astro";
import SupportCta from "../components/SupportCta.astro";
import CaseCard from "../components/CaseCard.astro";
import { SITE } from "../lib/site-config.mjs";
import { loadAllArticles } from "../lib/articles.mjs";

const articles = await loadAllArticles();

// 注目：国会での発言量（apiHits）上位5件
const featured = [...articles]
  .sort((a, b) => (b.apiHits ?? 0) - (a.apiHits ?? 0))
  .slice(0, 5);
const featuredSlugs = new Set(featured.map((a) => a.slug));

// 新着：最終更新日の新しい順5件（注目と重複除く）
const recent = [...articles]
  .filter((a) => !featuredSlugs.has(a.slug))
  .sort((a, b) => {
    const da = a.nowSummary?.updatedAt ?? a.fetchedAt ?? "";
    const db = b.nowSummary?.updatedAt ?? b.fetchedAt ?? "";
    return db.localeCompare(da);
  })
  .slice(0, 5);
const recentSlugs = new Set(recent.map((a) => a.slug));

// 残り全件
const rest = articles.filter(
  (a) => !featuredSlugs.has(a.slug) && !recentSlugs.has(a.slug)
);
---

<BaseLayout title={`${SITE.name} — あの話どうなった？`}>
  <PreReleaseBanner />
  <SiteHeader showSearch />
  <main class="container hero">
    <h1 class="hero__title">あの話<br />どうなった？</h1>
    <p class="hero__lead">
      政治家の発言と行動を追いかける。<br />
      みんなの気持ちが分かる「{SITE.name}」
    </p>
    <NotePromo medium="hero" variant="hero" />
  </main>

  <section class="container case-section" aria-label="注目の案件">
    <h2 class="case-section__heading">🔥 注目の案件</h2>
    <div class="case-grid">
      {featured.map((article) => (
        <CaseCard article={article} />
      ))}
    </div>
  </section>

  <section class="container case-section" aria-label="新着の案件">
    <h2 class="case-section__heading">🆕 新着</h2>
    <div class="case-grid">
      {recent.map((article) => (
        <CaseCard article={article} />
      ))}
    </div>
  </section>

  {rest.length > 0 && (
    <section class="container case-section" aria-label="すべての案件">
      <h2 class="case-section__heading">すべての案件</h2>
      <div class="case-grid">
        {rest.map((article) => (
          <CaseCard article={article} />
        ))}
      </div>
    </section>
  )}

  <SupportCta context="home" />
  <SiteFooter note="国会議事録 API + スクショアーカイブ。AI要約は解釈を含みます。" />
</BaseLayout>
