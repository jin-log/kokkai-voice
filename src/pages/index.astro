---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import CaseCard from "../components/CaseCard.astro";
import { loadAllArticles } from "../lib/articles.mjs";

const articles = await loadAllArticles();
---

<BaseLayout title="日本の政治なう — あの話どうなった？">
  <SiteHeader showSearch />
  <main class="container hero">
    <h1 class="hero__title">あの話<br />どうなった？</h1>
    <p class="hero__lead">
      約束した？ やった？ 消した？<br />
      政治家の言葉と行動を、<strong>だれでもわかる言葉</strong>で記録します。
    </p>
  </main>

  <section class="container case-grid" aria-label="注目の案件">
    {articles.map((article) => (
      <CaseCard article={article} />
    ))}
  </section>

  <SiteFooter note="国会議事録 API + スクショアーカイブ。AI要約は解釈を含みます。" />
</BaseLayout>
