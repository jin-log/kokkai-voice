---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PreReleaseBanner from "../components/PreReleaseBanner.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { loadAllArticles, articleToSearchEntry } from "../lib/articles.mjs";

const articles = await loadAllArticles();
const searchCases = articles.map(articleToSearchEntry);
const categories = [
  ...new Set(articles.flatMap((a) => [...(a.tags || []), a.category].filter(Boolean))),
].sort();
---

<BaseLayout title="検索｜日本の政治なう">
  <PreReleaseBanner />
  <SiteHeader showSearch />
  <main class="container search-page">
    <h1 class="search-page__title">案件を探す</h1>
    <p class="search-page__lead" data-search-meta>読み込み中…</p>

    <div class="category-chips" role="group" aria-label="カテゴリで絞り込み" data-category-chips>
      <button type="button" class="category-chip category-chip--active" data-category="">
        すべて
      </button>
      {
        categories.map((cat) => (
          <button type="button" class="category-chip" data-category={cat}>
            {cat}
          </button>
        ))
      }
    </div>

    <div class="sort-bar">
      <div class="sort-tabs" role="tablist" aria-label="並び替え">
        <button
          type="button"
          class="sort-tab sort-tab--active"
          data-sort="heat"
          role="tab"
          aria-selected="true"
          title="😊＋😠・コメント×2・直近7日PV">関心順</button
        >
        <button
          type="button"
          class="sort-tab"
          data-sort="trend"
          role="tab"
          aria-selected="false"
          title="直近48h/7日の投票・追記・X引用の伸び">話題順</button
        >
        <button
          type="button"
          class="sort-tab"
          data-sort="new"
          role="tab"
          aria-selected="false"
          title="案件ページの最終更新日">新着</button
        >
        <button
          type="button"
          class="sort-tab"
          data-sort="chrono"
          role="tab"
          aria-selected="false"
          title="案件開始日（古い→新しい）">時系列</button
        >
      </div>
      <p class="sort-hint" data-sort-desc aria-live="polite"></p>
    </div>

    <div class="search-results" data-search-results></div>
  </main>

  <SiteFooter note="MVP — ソートは記事データ由来のデモスコア。本番は D1 + Workers API。" />
  <script is:inline define:vars={{ searchCases }}>
    window.__SEARCH_CASES__ = searchCases;
  </script>
  <script is:inline src="/js/search.js"></script>
</BaseLayout>
