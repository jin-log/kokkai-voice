---
import BaseLayout from "../../layouts/DevLayout.astro";
import DevHeader from "../../components/DevHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import AdminArticleRow from "../../components/admin/AdminArticleRow.astro";
import { loadProjectStatus, sortSlugsForAdminPanel, adminSlugFilter } from "../../lib/project-status.mjs";

const status = await loadProjectStatus().catch(() => null);
const adminSlugs = status ? sortSlugsForAdminPanel(status.slugs) : [];
const adminCounts = status
  ? {
      action: status.slugs.filter((s) => adminSlugFilter(s) === "action").length,
      draft: status.slugs.filter((s) => adminSlugFilter(s) === "draft").length,
      live: status.slugs.filter((s) => adminSlugFilter(s) === "live").length,
      hidden: status.slugs.filter((s) => adminSlugFilter(s) === "hidden").length,
      qualityNg: status.qualityFailed ?? status.slugs.filter((s) => s.needsQualityFix).length,
      all: status.slugs.length,
    }
  : null;

function formatJa(iso) {
  if (!iso) return "—";
  return new Date(iso).toLocaleString("ja-JP");
}
---

<BaseLayout tabTitle="· v2提案">
  <DevHeader current="status" />
  <div id="dev-gate" style="display:none">
    <main class="container admin-v2">
      <div class="admin-v2__banner">
        <strong>UI v2 提案</strong>
        <span>旧版は <a href="/dev/status/">/dev/status/</a> ・ OKなら v2 を本番管理画面に差し替え</span>
      </div>

      {
        status ? (
          <>
            <header class="admin-v2__top" aria-label="サマリー">
              <div class="admin-v2__ring" id="status-hero-ring" style={`--pct: ${status.overallGoldPct}`}>
                <span class="admin-v2__pct" id="status-hero-pct">{status.overallGoldPct}%</span>
                <span class="admin-v2__pct-sub">100%完成</span>
              </div>
              <div class="admin-v2__top-body">
                <h1 class="admin-v2__title">サイト完成度</h1>
                <p class="admin-v2__sync">
                  本番同期は<strong>品質巡回が自動</strong>（手動ボタン不要）・ 数値は15秒ごとに更新
                </p>
                <p class="status-hero__live" id="status-live-badge" hidden>● ライブ更新中</p>
                <p class="status-hero__live status-hero__live--error" id="status-live-error" hidden></p>
                <dl class="admin-v2__stats">
                  <div><dt>一般公開</dt><dd id="stat-published">{status.publishedCount} / {status.activeCount}</dd></div>
                  <div><dt>ゲート</dt><dd id="stat-gate">{status.overallGatePct}%</dd></div>
                  <div><dt>品質NG</dt><dd>{status.qualityFailed} 件</dd></div>
                  <div><dt>更新</dt><dd id="stat-updated">{formatJa(status.generatedAt)}</dd></div>
                  <div id="stat-delta-wrap" hidden={status.deltaGoldPct == null || status.deltaGoldPct === 0}>
                    <dt>前回比</dt>
                    <dd id="stat-delta" class={status.deltaGoldPct > 0 ? "is-up" : "is-down"}>
                      {status.deltaGoldPct != null && status.deltaGoldPct !== 0
                        ? `${status.deltaGoldPct > 0 ? "+" : ""}${status.deltaGoldPct}%`
                        : "—"}
                    </dd>
                  </div>
                </dl>
              </div>
            </header>

            {status.qualityFailed > 0 && (
              <section class="admin-v2__alert" aria-label="品質NG">
                <h2>品質NG {status.qualityFailed} 件</h2>
                <ul>
                  {status.slugs
                    .filter((s) => !s.qualityOk)
                    .slice(0, 6)
                    .map((s) => (
                      <li>
                        <a href={s.previewUrl ?? `#`}>{s.shortTitle}</a>
                        <span>{s.qualityBlockers?.[0]?.message ?? "要修正"}</span>
                      </li>
                    ))}
                </ul>
              </section>
            )}

            <section class="admin-v2__list" aria-label="案件一覧">
              <div class="admin-v2__list-head">
                <h2>案件</h2>
                <nav class="status-slugs__tabs" id="admin-tabs" aria-label="フィルタ">
                  <button type="button" class="status-slugs__tab is-active" data-filter="action">
                    要対応 <span class="status-slugs__count" id="tab-count-action">{adminCounts?.action ?? 0}</span>
                  </button>
                  <button type="button" class="status-slugs__tab" data-filter="draft">
                    公開待ち <span class="status-slugs__count" id="tab-count-draft">{adminCounts?.draft ?? 0}</span>
                  </button>
                  <button type="button" class="status-slugs__tab" data-filter="live">
                    公開済み <span class="status-slugs__count" id="tab-count-live">{adminCounts?.live ?? 0}</span>
                  </button>
                  <button type="button" class="status-slugs__tab" data-filter="hidden">
                    非表示 <span class="status-slugs__count" id="tab-count-hidden">{adminCounts?.hidden ?? 0}</span>
                  </button>
                  <button type="button" class="status-slugs__tab" data-filter="all">
                    すべて <span class="status-slugs__count" id="tab-count-all">{adminCounts?.all ?? 0}</span>
                  </button>
                </nav>
              </div>
              <p class="status-slugs__hint" id="admin-filter-hint">制作中の案件だけ表示しています。</p>
              <div class="status-slugs__pager" id="admin-pager" hidden>
                <button type="button" class="status-slugs__page-btn" id="admin-prev" disabled>← 前</button>
                <span id="admin-page-label">1 / 1</span>
                <button type="button" class="status-slugs__page-btn" id="admin-next" disabled>次 →</button>
              </div>
              <div id="admin-cards">
                {adminSlugs.map((s) => (
                  <AdminArticleRow s={s} />
                ))}
              </div>
              <p class="status-slugs__empty" id="admin-empty" hidden>該当なし</p>
            </section>

            <div class="admin-v2__tools">
              <details class="admin-v2__panel">
                <summary>新規記事を作成</summary>
                <div class="admin-v2__panel-body dev-new-article">
                  <p class="dev-new-article__note">キーワードのみ。無理なテーマはアラートで止めます。</p>
                  <div class="dev-new-article__form">
                    <input id="new-keyword" type="text" placeholder="キーワード" class="dev-new-article__input" />
                    <input id="new-title" type="text" placeholder="タイトル（任意）" class="dev-new-article__input" />
                  </div>
                  <button id="new-generate" class="dev-new-article__btn">生成スタート</button>
                  <div id="new-status" class="dev-new-article__status" style="display:none"></div>
                </div>
              </details>

              <details class="admin-v2__panel">
                <summary>Buffer × X 投稿</summary>
                <div class="admin-v2__panel-body dev-buffer-panel" id="buffer-panel">
                  <p id="buffer-summary" class="dev-buffer-panel__summary">読み込み中…</p>
                  <dl class="dev-buffer-panel__meta" id="buffer-meta"></dl>
                  <ul id="buffer-fix-steps" class="dev-buffer-panel__fixes" hidden></ul>
                </div>
              </details>

              <details class="admin-v2__panel">
                <summary>状態の見方</summary>
                <div class="admin-v2__panel-body status-legend">
                  <ul>
                    <li><strong>100%完成</strong> — ①〜⑥すべてOK（公開は④までで可）</li>
                    <li><strong>要対応</strong> — 制作中・ゲート未達</li>
                    <li><strong>X未発見</strong> — 5段調査後も投稿なし（公開可）</li>
                  </ul>
                </div>
              </details>
            </div>
          </>
        ) : (
          <p>status 未生成</p>
        )
      }

      <script is:inline>
      (function () {
        const PAGE = 10;
        let filter = "action";
        let page = 1;
        const rowSel = "#admin-cards .admin-row";

        function render() {
          const cards = [...document.querySelectorAll(rowSel)];
          const matched = cards.filter((c) => {
            const f = c.getAttribute("data-admin-filter");
            return filter === "all" || f === filter;
          });
          const totalPages = Math.max(1, Math.ceil(matched.length / PAGE));
          if (page > totalPages) page = totalPages;
          cards.forEach((c) => { c.style.display = "none"; });
          const start = (page - 1) * PAGE;
          matched.slice(start, start + PAGE).forEach((c) => { c.style.display = ""; });
          const pager = document.getElementById("admin-pager");
          const label = document.getElementById("admin-page-label");
          const empty = document.getElementById("admin-empty");
          const hint = document.getElementById("admin-filter-hint");
          if (empty) empty.hidden = matched.length > 0;
          if (pager) pager.hidden = matched.length <= PAGE;
          if (label) label.textContent = `${page} / ${totalPages}（${matched.length}件）`;
          const prev = document.getElementById("admin-prev");
          const next = document.getElementById("admin-next");
          if (prev) prev.disabled = page <= 1;
          if (next) next.disabled = page >= totalPages;
          if (hint) {
            const hints = {
              action: "いま手を入れる案件",
              draft: "完成・非公開 — 公開ボタン待ち",
              live: "一般公開中",
              hidden: "管理画面から隠している案件",
              all: "全案件",
            };
            hint.textContent = hints[filter] || "";
          }
        }

        function setFilter(next) {
          filter = next;
          page = 1;
          document.getElementById("admin-tabs")?.querySelectorAll("[data-filter]").forEach((btn) => {
            btn.classList.toggle("is-active", btn.getAttribute("data-filter") === filter);
          });
          render();
          try {
            const u = new URL(location.href);
            u.searchParams.set("filter", filter);
            history.replaceState(null, "", u);
          } catch { /* ignore */ }
        }

        function init() {
          const tabs = document.getElementById("admin-tabs");
          if (!tabs || tabs.dataset.ready === "1") return;
          tabs.dataset.ready = "1";
          const q = new URLSearchParams(location.search).get("filter");
          if (q && ["action", "draft", "live", "hidden", "all"].includes(q)) filter = q;
          tabs.querySelectorAll("[data-filter]").forEach((btn) => {
            btn.addEventListener("click", () => setFilter(btn.getAttribute("data-filter") || "action"));
          });
          document.getElementById("admin-prev")?.addEventListener("click", () => { if (page > 1) { page -= 1; render(); } });
          document.getElementById("admin-next")?.addEventListener("click", () => { page += 1; render(); });
          tabs.querySelectorAll("[data-filter]").forEach((btn) => {
            btn.classList.toggle("is-active", btn.getAttribute("data-filter") === filter);
          });
          render();
        }

        window.kvAdminTabs = { init, render, setFilter };
        if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
        else init();
      })();
      </script>
    </main>
  </div>

  <div id="dev-lock" style="display:none">
    <div style="min-height:60vh;display:flex;align-items:center;justify-content:center">
      <div style="text-align:center;padding:2rem">
        <p style="font-size:1.1rem;margin-bottom:1rem">PINを入力</p>
        <input id="pin-input" type="password" maxlength="8" style="font-size:1.5rem;text-align:center;width:8rem;padding:0.5rem;border:2px solid var(--color-border);border-radius:0.5rem" placeholder="••••" />
        <br><br>
        <button id="pin-submit" style="background:var(--color-primary);color:#fff;border:none;padding:0.6rem 1.5rem;border-radius:2rem;font-size:1rem;cursor:pointer">入力</button>
        <p id="pin-error" style="color:red;margin-top:0.5rem;display:none">PINが違います</p>
      </div>
    </div>
  </div>

  <SiteFooter note="" />
</BaseLayout>

<script>
/* 旧 status.astro と同じ操作系（deploy-all のみ削除） */
const PIN = "1192";
const KEY = "dev_auth";
function show(id) { document.getElementById(id).style.display = "block"; }
function hide(id) { document.getElementById(id).style.display = "none"; }
if (localStorage.getItem(KEY) === PIN) { show("dev-gate"); startLiveStatusPoll(); }
else {
  show("dev-lock");
  document.getElementById("pin-submit").addEventListener("click", () => {
    if (document.getElementById("pin-input").value === PIN) {
      localStorage.setItem(KEY, PIN);
      hide("dev-lock"); show("dev-gate"); startLiveStatusPoll();
    } else document.getElementById("pin-error").style.display = "block";
  });
  document.getElementById("pin-input").addEventListener("keydown", (e) => {
    if (e.key === "Enter") document.getElementById("pin-submit").click();
  });
}
function getPin() { return localStorage.getItem(KEY) || ""; }
async function callDispatch(action, extra = {}) {
  const res = await fetch("/api/dispatch", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ pin: getPin(), action, ...extra }) });
  const data = await res.json();
  if (!res.ok || !data.ok) throw new Error(data.error || data.detail || "エラー");
  return data;
}
document.getElementById("new-keyword")?.addEventListener("input", () => {
  const kw = document.getElementById("new-keyword").value.trim();
  if (!document.getElementById("new-title").dataset.manual) {
    document.getElementById("new-title").value = kw ? `${kw}（具体疑問タイトルに編集）` : "";
  }
});
document.getElementById("new-title")?.addEventListener("input", () => { document.getElementById("new-title").dataset.manual = "1"; });
document.getElementById("new-generate")?.addEventListener("click", async () => {
  const keyword = document.getElementById("new-keyword").value.trim();
  const titleIn = document.getElementById("new-title").value.trim();
  if (!keyword) { alert("キーワードを入力"); return; }
  const statusEl = document.getElementById("new-status");
  const btn = document.getElementById("new-generate");
  statusEl.style.display = "block";
  statusEl.className = "dev-new-article__status is-loading";
  statusEl.textContent = "⏳ 確認中…";
  btn.disabled = true;
  try {
    const data = await callDispatch("create", { keyword, title: titleIn });
    statusEl.className = "dev-new-article__status is-ok";
    statusEl.textContent = "✅ " + data.message + (data.slug ? ` — ${data.slug}` : "");
  } catch (e) {
    statusEl.className = "dev-new-article__status is-error";
    statusEl.textContent = "❌ " + e.message;
    alert(e.message);
  } finally { btn.disabled = false; }
});
document.querySelectorAll(".publish-slug-btn").forEach((btn) => {
  btn.addEventListener("click", async () => {
    const slug = btn.dataset.slug;
    const statusEl = document.querySelector(`.deploy-slug-status[data-slug="${slug}"]`);
    if (!confirm(`「${slug}」を一般公開しますか？`)) return;
    btn.disabled = true;
    statusEl.hidden = false;
    statusEl.className = "deploy-slug-status is-loading";
    statusEl.textContent = "⏳ 公開中…";
    try {
      const data = await callDispatch("deploy_article", { slug });
      statusEl.className = "deploy-slug-status is-ok";
      statusEl.textContent = "✅ " + data.message;
    } catch (e) {
      statusEl.className = "deploy-slug-status is-error";
      statusEl.textContent = "❌ " + e.message;
    } finally { btn.disabled = false; }
  });
});
async function refreshLiveStatus() {
  const pin = getPin();
  if (!pin) return;
  const badge = document.getElementById("status-live-badge");
  const err = document.getElementById("status-live-error");
  try {
    let st = null;
    const ts = Date.now();
    const r1 = await fetch(`/api/project-status?pin=${encodeURIComponent(pin)}&t=${ts}`);
    if (r1.ok) { const d1 = await r1.json(); if (d1.ok && d1.status) st = d1.status; }
    if (!st) {
      const r3 = await fetch(`/status-live.json?t=${ts}`);
      if (r3.ok) st = await r3.json();
    }
    if (!st) { if (err) { err.hidden = false; err.textContent = "⚠ 取得失敗"; } return; }
    applyLiveStatus(st);
    if (badge) badge.hidden = false;
    if (err) err.hidden = true;
  } catch { if (err) { err.hidden = false; err.textContent = "⚠ エラー"; } }
}
function applyLiveStatus(st) {
  const ring = document.getElementById("status-hero-ring");
  const pctEl = document.getElementById("status-hero-pct");
  const next = st.overallGoldPct ?? 0;
  if (ring) ring.style.setProperty("--pct", String(next));
  if (pctEl) pctEl.textContent = `${next}%`;
  const pub = document.getElementById("stat-published");
  if (pub) pub.textContent = `${st.publishedCount} / ${st.activeCount}`;
  const gate = document.getElementById("stat-gate");
  if (gate) gate.textContent = `${st.overallGatePct}%`;
  const updated = document.getElementById("stat-updated");
  if (updated && st.generatedAt) updated.textContent = new Date(st.generatedAt).toLocaleString("ja-JP");
  for (const s of st.slugs ?? []) {
    const row = document.querySelector(`.admin-row[data-slug="${s.slug}"]`);
    if (!row) continue;
    const label = row.querySelector(".admin-row__meter-label");
    if (label) label.textContent = String(s.goldPct);
    const fill = row.querySelector(".admin-row__meter-fill");
    if (fill) fill.style.height = `${s.goldPct}%`;
    const bar = row.querySelector(".status-card__bar > span");
    if (bar) bar.style.width = `${s.goldPct}%`;
  }
  const counts = { action: 0, draft: 0, live: 0, hidden: 0, all: st.slugs?.length ?? 0 };
  for (const s of st.slugs ?? []) {
    if (s.adminHidden) counts.hidden += 1;
    else if (s.publishState === "live") counts.live += 1;
    else if (s.publishState === "draft") counts.draft += 1;
    else counts.action += 1;
  }
  for (const [key, id] of Object.entries({ action: "tab-count-action", draft: "tab-count-draft", live: "tab-count-live", hidden: "tab-count-hidden", all: "tab-count-all" })) {
    const el = document.getElementById(id);
    if (el) el.textContent = String(counts[key] ?? 0);
  }
  window.kvAdminTabs?.render?.();
}
let liveStatusTimer = null;
function startLiveStatusPoll() {
  if (liveStatusTimer) return;
  liveStatusTimer = true;
  refreshLiveStatus();
  refreshBufferStatus();
  window.kvAdminTabs?.init?.();
  setInterval(refreshLiveStatus, 15000);
  setInterval(refreshBufferStatus, 15000);
}
async function refreshBufferStatus() {
  const pin = getPin();
  const summary = document.getElementById("buffer-summary");
  const meta = document.getElementById("buffer-meta");
  const fixes = document.getElementById("buffer-fix-steps");
  if (!summary || !meta) return;
  let s = null;
  if (pin) { try { const res = await fetch(`/api/buffer-status?pin=${encodeURIComponent(pin)}`); s = await res.json(); } catch {} }
  if (!s) { try { const res = await fetch(`/buffer-status.json?t=${Date.now()}`); if (res.ok) s = await res.json(); } catch {} }
  if (!s) { summary.textContent = "取得失敗"; return; }
  summary.textContent = s.message || s.statusLabel || "—";
  meta.innerHTML = "";
}
document.querySelectorAll(".save-title-btn").forEach((btn) => {
  btn.addEventListener("click", async () => {
    const slug = btn.dataset.slug;
    const input = document.querySelector(`.status-card__title-input[data-slug="${slug}"]`);
    const statusEl = document.querySelector(`.title-save-status[data-slug="${slug}"]`);
    const title = input?.value?.trim();
    if (!title) return;
    btn.disabled = true;
    statusEl.hidden = false;
    try {
      const data = await callDispatch("update_title", { slug, title });
      statusEl.className = "title-save-status is-ok";
      statusEl.textContent = "✅ " + data.message;
    } catch (e) {
      statusEl.className = "title-save-status is-error";
      statusEl.textContent = "❌ " + e.message;
    } finally { btn.disabled = false; }
  });
});
document.querySelectorAll(".hide-btn").forEach((btn) => btn.addEventListener("click", () => adminAction(btn, "hide", "非表示にしますか？")));
document.querySelectorAll(".unhide-btn").forEach((btn) => btn.addEventListener("click", () => adminAction(btn, "unhide", "表示に戻しますか？")));
document.querySelectorAll(".delete-btn").forEach((btn) => btn.addEventListener("click", () => adminAction(btn, "delete_article", "削除しますか？")));
async function adminAction(btn, action, confirmMsg) {
  const slug = btn.dataset.slug;
  if (!confirm(confirmMsg)) return;
  const statusEl = document.querySelector(`.admin-action-status[data-slug="${slug}"]`);
  btn.disabled = true;
  statusEl.hidden = false;
  try {
    const data = await callDispatch(action, { slug });
    statusEl.className = "admin-action-status is-ok";
    statusEl.textContent = "✅ " + data.message;
    setTimeout(() => location.reload(), 12000);
  } catch (e) {
    statusEl.className = "admin-action-status is-error";
    statusEl.textContent = "❌ " + e.message;
    btn.disabled = false;
  }
}
</script>
