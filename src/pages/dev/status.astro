---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { loadProjectStatus } from "../../lib/project-status.mjs";

const status = await loadProjectStatus().catch(() => null);

function formatJa(iso) {
  if (!iso) return "—";
  return new Date(iso).toLocaleString("ja-JP");
}
---

<BaseLayout
  title="[開発] 完成度 — 日本の政治なう"
  description="開発者用ページ"
  noindex={true}
>
  <SiteHeader showSearch />
  <div id="dev-gate" style="display:none">
    <main class="container status-page">
      <p class="status-page__lead" style="color:var(--color-text-muted);font-size:0.8rem;margin-bottom:0.5rem">
        🔒 開発者専用ページ
      </p>
      <h1 class="status-page__title">サイト完成度</h1>
      <p class="status-page__lead">
        active {status?.activeCount ?? 0} 件を <strong>100%完成</strong> まで仕上げてから次を増やす方針です。
        数値はビルド・デプロイの直前に自動更新されます。
      </p>

      <!-- 新規記事作成UI -->
      <section class="dev-new-article" id="new-article">
        <h2>🆕 新規記事を作成</h2>
        <p class="dev-new-article__note">キーワードを入れて「生成」。国会＝議事録API／それ以外＝ソースURL＋X調査（2〜3分）</p>
        <div class="dev-new-article__form">
          <input id="new-keyword" type="text" placeholder="キーワード（例: 東京リコール、防衛増税）" class="dev-new-article__input" />
          <input id="new-title" type="text" placeholder="タイトル（空欄なら自動）" class="dev-new-article__input" />
          <input id="new-sources" type="text" placeholder="ソースURL（カンマ区切り・任意）" class="dev-new-article__input" />
          <select id="new-category" class="dev-new-article__select">
            <option value="国会">国会</option>
            <option value="地方">地方</option>
            <option value="行政">行政</option>
            <option value="選挙">選挙</option>
            <option value="リコール">リコール</option>
          </select>
        </div>
        <button id="new-generate" class="dev-new-article__btn">▶ 生成スタート</button>
        <div id="new-status" class="dev-new-article__status" style="display:none"></div>
      </section>

      {
        status ? (
          <>
            <section class="status-hero" aria-label="全体">
              <div class="status-hero__ring" style={`--pct: ${status.overallGoldPct}`}>
                <span class="status-hero__num">{status.overallGoldPct}%</span>
                <span class="status-hero__sub">100%完成</span>
              </div>
              <dl class="status-hero__stats">
                <div><dt>本番公開</dt><dd>{status.publishedCount} / {status.activeCount} 件</dd></div>
                <div><dt>保留（parked）</dt><dd>{status.parkedCount} 件</dd></div>
                <div><dt>ゲート達成率</dt><dd>{status.overallGatePct}%</dd></div>
                <div><dt>最終更新</dt><dd>{formatJa(status.generatedAt)}</dd></div>
                {status.deltaGoldPct != null && status.deltaGoldPct !== 0 && (
                  <div>
                    <dt>前回比</dt>
                    <dd class={status.deltaGoldPct > 0 ? "is-up" : "is-down"}>
                      {status.deltaGoldPct > 0 ? "+" : ""}{status.deltaGoldPct}%
                    </dd>
                  </div>
                )}
              </dl>
            </section>

            <section class="status-slugs" aria-label="案件別">
              <h2>案件別</h2>
              {status.slugs.map((s) => (
                <article class="status-card">
                  <header class="status-card__head">
                    <h3 class="status-card__title">
                      {s.published ? <a href={`/case/${s.slug}/`}>{s.shortTitle}</a> : s.shortTitle}
                    </h3>
                    <span class="status-card__pct">{s.goldPct}%</span>
                  </header>
                  <div class="status-card__bar" role="progressbar" aria-valuenow={s.goldPct} aria-valuemin={0} aria-valuemax={100}>
                    <span style={`width: ${s.goldPct}%`} />
                  </div>
                  <ul class="status-card__checks">
                    {s.gold.map((g) => (
                      <li class:list={["status-check", g.ok && "is-ok"]}>{g.ok ? "✓" : "○"} {g.label}</li>
                    ))}
                  </ul>
                  {!s.published && s.blockers.length > 0 && (
                    <p class="status-card__blockers">未了: {s.blockers.map((b) => b.id).join(", ")}</p>
                  )}
                </article>
              ))}
            </section>

            <section class="status-legend">
              <h2>パイプライン（順番固定）</h2>
              <ol>
                <li>①コンテンツ（経緯・国会・要約）</li>
                <li>②〇×2党確定（○▲×）</li>
                <li>③X検証2件+</li>
                <li>④法務OK — <em>デプロイ直前</em></li>
                <li>⑤本番デプロイ</li>
                <li>⑥デバッグOK</li>
              </ol>
            </section>
          </>
        ) : (
          <p>status 未生成。CEO が <code>npm run status</code> を実行してください。</p>
        )
      }
    </main>
  </div>

  <div id="dev-lock" style="display:none">
    <div style="min-height:60vh;display:flex;align-items:center;justify-content:center">
      <div style="text-align:center;padding:2rem">
        <p style="font-size:1.1rem;margin-bottom:1rem">🔒 PINを入力してください</p>
        <input id="pin-input" type="password" maxlength="8"
          style="font-size:1.5rem;text-align:center;width:8rem;padding:0.5rem;border:2px solid var(--color-border);border-radius:0.5rem"
          placeholder="••••" />
        <br><br>
        <button id="pin-submit"
          style="background:var(--color-primary);color:#fff;border:none;padding:0.6rem 1.5rem;border-radius:2rem;font-size:1rem;cursor:pointer">
          入力
        </button>
        <p id="pin-error" style="color:red;margin-top:0.5rem;display:none">PINが違います</p>
      </div>
    </div>
  </div>

  <SiteFooter note="開発者専用ページ" />
</BaseLayout>

<script>
const PIN = "1192";
const KEY = "dev_auth";

function show(id) { document.getElementById(id).style.display = "block"; }
function hide(id) { document.getElementById(id).style.display = "none"; }

if (localStorage.getItem(KEY) === PIN) {
  show("dev-gate");
} else {
  show("dev-lock");
  document.getElementById("pin-submit").addEventListener("click", () => {
    const val = document.getElementById("pin-input").value;
    if (val === PIN) {
      localStorage.setItem(KEY, PIN);
      hide("dev-lock");
      show("dev-gate");
    } else {
      document.getElementById("pin-error").style.display = "block";
    }
  });
  document.getElementById("pin-input").addEventListener("keydown", (e) => {
    if (e.key === "Enter") document.getElementById("pin-submit").click();
  });
}

function makeSlug(keyword) {
  const ascii = keyword
    .trim()
    .toLowerCase()
    .normalize("NFKC")
    .replace(/[\s　]+/g, "-")
    .replace(/[^a-z0-9-]/g, "")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "");
  if (ascii.length >= 3) return ascii.substring(0, 40);
  return `case-${Date.now().toString(36)}`;
}

function makeTitle(keyword) {
  return `${keyword.trim()} — あの話どうなった？`;
}

document.getElementById("new-keyword").addEventListener("input", () => {
  const kw = document.getElementById("new-keyword").value.trim();
  if (!document.getElementById("new-title").dataset.manual) {
    document.getElementById("new-title").value = kw ? `${kw} — あの話どうなった？` : "";
  }
});
document.getElementById("new-title").addEventListener("input", () => {
  document.getElementById("new-title").dataset.manual = "1";
});

// 記事生成
document.getElementById("new-generate").addEventListener("click", async () => {
  const keyword  = document.getElementById("new-keyword").value.trim();
  const titleIn  = document.getElementById("new-title").value.trim();
  const sources  = document.getElementById("new-sources").value.trim();
  const category = document.getElementById("new-category").value;
  const pin      = localStorage.getItem("dev_auth") || "";
  const title    = titleIn || makeTitle(keyword);
  const slug     = makeSlug(keyword);

  if (!keyword) { alert("キーワードを入力してください"); return; }

  const statusEl = document.getElementById("new-status");
  statusEl.style.display = "block";
  statusEl.className = "dev-new-article__status is-loading";
  statusEl.textContent = "⏳ ワークフロー起動中...";
  document.getElementById("new-generate").disabled = true;

  try {
    const res = await fetch("/api/dispatch", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ pin, slug, keyword, title, category, sources }),
    });
    const data = await res.json();
    if (data.ok) {
      statusEl.className = "dev-new-article__status is-ok";
      statusEl.textContent = `✅ ${data.message}（/${slug}/）`;
    } else {
      statusEl.className = "dev-new-article__status is-error";
      statusEl.textContent = "❌ " + (data.error || "エラーが発生しました");
    }
  } catch (e) {
    statusEl.className = "dev-new-article__status is-error";
    statusEl.textContent = "❌ 通信エラー: " + e.message;
  } finally {
    document.getElementById("new-generate").disabled = false;
  }
});
</script>
