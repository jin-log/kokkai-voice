---
import BaseLayout from "../../layouts/DevLayout.astro";
import DevHeader from "../../components/DevHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { loadProjectStatus, sortSlugsForAdminPanel, adminSlugFilter } from "../../lib/project-status.mjs";
import { promoDateShort } from "../../lib/promo-intro-status.mjs";

const status = await loadProjectStatus().catch(() => null);
const adminSlugs = status ? sortSlugsForAdminPanel(status.slugs) : [];
const adminCounts = status
  ? {
      action: status.slugs.filter((s) => adminSlugFilter(s) === "action").length,
      draft: status.slugs.filter((s) => adminSlugFilter(s) === "draft").length,
      live: status.slugs.filter((s) => adminSlugFilter(s) === "live").length,
      hidden: status.slugs.filter((s) => adminSlugFilter(s) === "hidden").length,
      qualityNg: status.qualityFailed ?? status.slugs.filter((s) => s.needsQualityFix).length,
      all: status.slugs.length,
    }
  : null;

function formatJa(iso) {
  if (!iso) return "—";
  return new Date(iso).toLocaleString("ja-JP");
}
---

<BaseLayout tabTitle="·">
  <DevHeader current="status" />
  <div id="dev-gate" style="display:none">
    <main class="container status-page">
      <p class="status-page__lead status-page__lead--dev">🔒 認証が必要です</p>
      <h1 class="status-page__title">サイト完成度</h1>
      <p class="status-page__lead">
        active {status?.activeCount ?? 0} 件を <strong>100%完成</strong> まで仕上げてから次を増やす方針です。
        完成度は <strong>15秒ごとにライブ更新</strong>（巡回の進捗をそのまま反映。デプロイ待ち不要）。
      </p>

      <!-- 新規記事作成UI -->
      <section class="dev-new-article" id="new-article">
        <h2>🆕 新規記事を作成</h2>
        <p class="dev-new-article__note">キーワード（＋タイトル任意）だけ入力。カテゴリ・ソースURLは自動。生成前に可否チェックし、無理なら<strong>アラートで止めます</strong>。</p>
        <div class="dev-new-article__form">
          <input id="new-keyword" type="text" placeholder="キーワード（例: 防衛増税、東京リコール）" class="dev-new-article__input" />
          <input id="new-title" type="text" placeholder="タイトル（空欄なら自動）" class="dev-new-article__input" />
        </div>
        <button id="new-generate" class="dev-new-article__btn">▶ 生成スタート</button>
        <div id="new-status" class="dev-new-article__status" style="display:none"></div>
      </section>

      {
        status ? (
          <>
            <section class="status-hero" aria-label="全体">
              <div class="status-hero__ring" id="status-hero-ring" style={`--pct: ${status.overallGoldPct}`}>
                <span class="status-hero__num" id="status-hero-pct">{status.overallGoldPct}%</span>
                <span class="status-hero__sub">100%完成</span>
              </div>
              <p class="status-hero__live" id="status-live-badge" hidden aria-live="polite">● ライブ更新中</p>
              <p class="status-hero__live status-hero__live--error" id="status-live-error" hidden aria-live="assertive"></p>
              <dl class="status-hero__stats">
                <div><dt>一般公開</dt><dd id="stat-published">{status.publishedCount} / {status.activeCount} 件</dd></div>
                <div><dt>保留（parked）</dt><dd id="stat-parked">{status.parkedCount} 件</dd></div>
                <div><dt>ゲート達成率</dt><dd id="stat-gate">{status.overallGatePct}%</dd></div>
                <div><dt>最終更新</dt><dd id="stat-updated">{formatJa(status.generatedAt)}</dd></div>
                <div id="stat-delta-wrap" hidden={status.deltaGoldPct == null || status.deltaGoldPct === 0}>
                  <dt>前回比</dt>
                  <dd id="stat-delta" class={status.deltaGoldPct > 0 ? "is-up" : "is-down"}>
                    {status.deltaGoldPct != null && status.deltaGoldPct !== 0
                      ? `${status.deltaGoldPct > 0 ? "+" : ""}${status.deltaGoldPct}%`
                      : "—"}
                  </dd>
                </div>
              </dl>
            </section>

            {status.qualityFailed > 0 && (
              <section class="status-quality" aria-label="品質NG">
                <h2>⚠ 品質NG {status.qualityFailed} 件（ゲート100%でも中身ダメ）</h2>
                <p class="status-quality__lead">
                  オーナー目視なしで検出。担当エージェントへ自動タスク化（<code>data/agent-tasks.json</code>）。
                  修正は <code>npm run pipeline:autorun</code> または各コマンド。
                </p>
                <ul class="status-quality__list">
                  {status.slugs
                    .filter((s) => !s.qualityOk)
                    .slice(0, 12)
                    .map((s) => (
                      <li class="status-quality__item">
                        <a href={s.previewUrl ?? `#`}>{s.shortTitle}</a>
                        <span class="status-quality__meta">
                          {s.qualityBlockerCount} 件 — {s.agentTasks?.[0]?.agentLabel ?? "ライター"}
                        </span>
                        {s.qualityBlockers?.[0] && (
                          <p class="status-quality__msg">{s.qualityBlockers[0].message}</p>
                        )}
                      </li>
                    ))}
                </ul>
              </section>
            )}

            <section class="dev-buffer-panel" id="buffer-panel" aria-live="polite">
              <h2>📣 Buffer × X 自動投稿</h2>
              <p id="buffer-summary" class="dev-buffer-panel__summary">読み込み中…</p>
              <dl class="dev-buffer-panel__meta" id="buffer-meta"></dl>
              <ul id="buffer-fix-steps" class="dev-buffer-panel__fixes" hidden></ul>
              <p class="dev-buffer-panel__hint">
                deploy 時に新規公開1件を自動投稿（日上限3本）。設定: <code>docs/buffer-setup.md</code>
              </p>
            </section>

            <section class="dev-deploy" aria-label="サイト反映">
              <h2>🚀 サイトを反映（管理画面の同期）</h2>
              <p class="dev-deploy__note">
                記事JSONの変更を管理画面・プレビューに反映します。<strong>一般ユーザーへの公開ではありません</strong>（公開は各案件の「🌍 公開する」）。
                生成スタート後は通常、自動でここまで走ります（手動は取りこぼし用）。
              </p>
              <button type="button" id="deploy-all" class="dev-deploy__btn dev-deploy__btn--primary">全体を本番に反映</button>
              <div id="deploy-all-status" class="dev-deploy__status" style="display:none"></div>
            </section>

            <section class="status-slugs" aria-label="案件別">
              <div class="status-slugs__head">
                <h2>案件別</h2>
                <nav class="status-slugs__tabs" id="admin-tabs" aria-label="表示フィルタ">
                  <button type="button" class="status-slugs__tab is-active" data-filter="action">
                    要対応 <span class="status-slugs__count">{adminCounts?.action ?? 0}</span>
                  </button>
                  <button type="button" class="status-slugs__tab" data-filter="draft">
                    公開待ち <span class="status-slugs__count">{adminCounts?.draft ?? 0}</span>
                  </button>
                  <button type="button" class="status-slugs__tab" data-filter="live">
                    公開済み <span class="status-slugs__count">{adminCounts?.live ?? 0}</span>
                  </button>
                  <button type="button" class="status-slugs__tab" data-filter="all">
                    すべて <span class="status-slugs__count">{adminCounts?.all ?? 0}</span>
                  </button>
                </nav>
              </div>
              <p class="status-slugs__hint" id="admin-filter-hint">
                デフォルトは「要対応」のみ。公開済みは薄く表示・末尾に並びます。
              </p>
              <div class="status-slugs__pager" id="admin-pager" hidden>
                <button type="button" class="status-slugs__page-btn" id="admin-prev" disabled>← 前</button>
                <span id="admin-page-label">1 / 1</span>
                <button type="button" class="status-slugs__page-btn" id="admin-next" disabled>次 →</button>
              </div>
              <div id="admin-cards">
              {adminSlugs.map((s) => (
                <article class:list={[
                  "status-card",
                  s.adminHidden && "status-card--hidden",
                  s.publishState === "draft" && "status-card--draft",
                  s.publishState === "live" && !s.adminHidden && "status-card--live",
                ]} data-slug={s.slug} data-publish-state={s.publishState} data-admin-filter={adminSlugFilter(s)}>
                  <header class="status-card__head">
                    <h3 class="status-card__title">
                      {s.publishState === "live" && !s.adminHidden ? (
                        <a href={`/case/${s.slug}/`}>{s.shortTitle}</a>
                      ) : s.previewUrl ? (
                        <a href={s.previewUrl}>{s.shortTitle}</a>
                      ) : (
                        s.shortTitle
                      )}
                      {s.publishState === "draft" && <span class="status-card__badge status-card__badge--draft">完成・非公開</span>}
                      {s.publishState === "live" && <span class="status-card__badge status-card__badge--live">公開中</span>}
                      {s.needsQualityFix && <span class="status-card__badge status-card__badge--quality">品質NG</span>}
                      {s.adminHidden && <span class="status-card__badge">非表示</span>}
                    </h3>
                    <span class="status-card__pct">{s.goldPct}%</span>
                  </header>
                  <p class="status-card__slug"><code>{s.slug}</code></p>
                  <ul class="status-card__promo" aria-label="外部紹介">
                    <li class:list={["status-card__promo-item", s.promo?.x && "is-done"]}>
                      X {s.promo?.x ? `✓ ${promoDateShort(s.promo.x)}` : "—"}
                    </li>
                    <li class:list={["status-card__promo-item", s.promo?.hatena && "is-done"]}>
                      はてブ {s.promo?.hatena ? `✓ ${promoDateShort(s.promo.hatena)}` : "—"}
                    </li>
                    <li class:list={["status-card__promo-item", s.promo?.note && "is-done"]}>
                      note {s.promo?.note ? `✓ ${promoDateShort(s.promo.note)}` : "—"}
                    </li>
                  </ul>
                  <p class:list={["status-card__short", s.short?.uploaded && "is-done", s.short?.generated && !s.short?.uploaded && "is-partial"]}>
                    🎬 Shorts {s.short?.label ?? "未生成"}
                    {s.short?.url ? (
                      <>
                        {" · "}
                        <a href={s.short.url} target="_blank" rel="noopener noreferrer">YouTube</a>
                      </>
                    ) : null}
                  </p>
                  <p class="status-card__next">{s.nextAction ?? "npm run status で次アクションを更新"}</p>
                  <div class="status-card__title-edit">
                    <input type="text" class="status-card__title-input" value={s.title} data-slug={s.slug} aria-label="タイトル編集" />
                    <button type="button" class="dev-deploy__btn save-title-btn" data-slug={s.slug}>タイトル保存</button>
                    <span class="title-save-status" data-slug={s.slug} hidden></span>
                  </div>
                  <div class="status-card__bar" role="progressbar" aria-valuenow={s.goldPct} aria-valuemin={0} aria-valuemax={100}>
                    <span style={`width: ${s.goldPct}%`} />
                  </div>
                  <ul class="status-card__checks">
                    {s.gold.map((g) => (
                      <li class:list={["status-check", g.ok && "is-ok"]}>{g.ok ? "✓" : "○"} {g.label}</li>
                    ))}
                  </ul>
                  {!s.published && s.blockers.length > 0 && (
                    <div class="status-card__blockers">
                      <p class="status-card__blockers-title">ゲート未達 {s.blockerCount ?? s.blockers.length} 項目</p>
                      <ol class="status-card__blockers-list">
                        {s.blockers.map((b) => (
                          <li>
                            <strong>{b.label ?? b.id}</strong>
                            <span>{b.todo ?? b.detail}</span>
                          </li>
                        ))}
                      </ol>
                    </div>
                  )}
                  {!s.qualityOk && (s.qualityBlockers?.length ?? 0) > 0 && (
                    <div class="status-card__blockers status-card__blockers--quality">
                      <p class="status-card__blockers-title">品質NG {s.qualityBlockerCount} 件（{s.agentTasks?.[0]?.agentLabel ?? "ライター"}）</p>
                      <ol class="status-card__blockers-list">
                        {s.qualityBlockers.map((q) => (
                          <li>
                            <strong>{q.id}</strong>
                            <span>{q.message}</span>
                          </li>
                        ))}
                      </ol>
                      {s.agentTasks?.[0]?.command && (
                        <p class="status-card__cmd"><code>{s.agentTasks[0].command}</code></p>
                      )}
                    </div>
                  )}
                  <div class="status-card__deploy">
                    {s.publishState === "draft" && s.previewUrl && (
                      <a href={s.previewUrl} class="dev-deploy__btn dev-deploy__btn--preview" target="_blank" rel="noopener">
                        👁️ プレビューで中身を確認
                      </a>
                    )}
                    {s.publishGateOk && !s.pageReady ? (
                      <>
                        <button type="button" class="dev-deploy__btn dev-deploy__btn--slug dev-deploy__btn--publish publish-slug-btn" data-slug={s.slug}>
                          🌍 公開する
                        </button>
                        <span class="deploy-slug-status" data-slug={s.slug} hidden></span>
                      </>
                    ) : s.publishState === "live" ? (
                      <>
                        <p class="status-card__deploy-hint">✅ 一般公開中 — <a href={`/case/${s.slug}/`}>/case/{s.slug}/</a></p>
                        <a href={`/dev/hatena/#${s.slug}`} class="dev-deploy__btn dev-deploy__btn--preview">
                          📑 はてブ投稿
                        </a>
                      </>
                    ) : (
                      <p class="status-card__deploy-hint">①〜④が全部OKになるとプレビューと公開ボタンが使えます（現在 {s.gatePct}%）</p>
                    )}
                  </div>
                  <div class="status-card__admin">
                    {s.adminHidden ? (
                      <button type="button" class="dev-deploy__btn unhide-btn" data-slug={s.slug}>👁️ 表示に戻す</button>
                    ) : (
                      <button type="button" class="dev-deploy__btn hide-btn" data-slug={s.slug}>🙈 非表示</button>
                    )}
                    <button type="button" class="dev-deploy__btn dev-admin-btn--danger delete-btn" data-slug={s.slug}>🗑️ 削除</button>
                    <span class="admin-action-status" data-slug={s.slug} hidden></span>
                  </div>
                </article>
              ))}
              </div>
              <p class="status-slugs__empty" id="admin-empty" hidden>このタブに該当する案件はありません。</p>
            </section>

            <section class="status-legend">
              <h2>状態の見方</h2>
              <ul class="status-legend__states">
                <li><strong>要対応タブ</strong> — 制作中（①〜④未完了）。公開済みは「公開済み」タブ</li>
                <li><strong>品質NG</strong> — 公開中でもバッジ表示。ゲートとは別（スクショ・数値等）</li>
                <li><strong>📋 完成・非公開</strong> — プレビューで確認 →「公開する」</li>
                <li><strong>✅ 公開中</strong> — 一般ユーザーに /case/ で表示</li>
                <li><strong>X / はてブ / note</strong> — 紹介済みは緑✓＋日付、未は —</li>
              </ul>
              <h2>パイプライン（順番固定）</h2>
              <ol>
                <li>①コンテンツ（経緯・国会・要約）</li>
                <li>②〇×2党確定（○▲×）</li>
                <li>③X検証2件+</li>
                <li>④法務OK — <em>デプロイ直前</em></li>
                <li>⑤本番デプロイ</li>
                <li>⑥デバッグOK</li>
              </ol>
            </section>
          </>
        ) : (
          <p>status 未生成。CEO が <code>npm run status</code> を実行してください。</p>
        )
      }
    </main>
  </div>

  <div id="dev-lock" style="display:none">
    <div style="min-height:60vh;display:flex;align-items:center;justify-content:center">
      <div style="text-align:center;padding:2rem">
        <p style="font-size:1.1rem;margin-bottom:1rem">🔒 PINを入力してください</p>
        <input id="pin-input" type="password" maxlength="8"
          style="font-size:1.5rem;text-align:center;width:8rem;padding:0.5rem;border:2px solid var(--color-border);border-radius:0.5rem"
          placeholder="••••" />
        <br><br>
        <button id="pin-submit"
          style="background:var(--color-primary);color:#fff;border:none;padding:0.6rem 1.5rem;border-radius:2rem;font-size:1rem;cursor:pointer">
          入力
        </button>
        <p id="pin-error" style="color:red;margin-top:0.5rem;display:none">PINが違います</p>
      </div>
    </div>
  </div>

  <SiteFooter note="" />
</BaseLayout>

<script>
const PIN = "1192";
const KEY = "dev_auth";

function show(id) { document.getElementById(id).style.display = "block"; }
function hide(id) { document.getElementById(id).style.display = "none"; }

if (localStorage.getItem(KEY) === PIN) {
  show("dev-gate");
  startLiveStatusPoll();
} else {
  show("dev-lock");
  document.getElementById("pin-submit").addEventListener("click", () => {
    const val = document.getElementById("pin-input").value;
    if (val === PIN) {
      localStorage.setItem(KEY, PIN);
      hide("dev-lock");
      show("dev-gate");
      startLiveStatusPoll();
    } else {
      document.getElementById("pin-error").style.display = "block";
    }
  });
  document.getElementById("pin-input").addEventListener("keydown", (e) => {
    if (e.key === "Enter") document.getElementById("pin-submit").click();
  });
}

document.getElementById("new-keyword").addEventListener("input", () => {
  const kw = document.getElementById("new-keyword").value.trim();
  if (!document.getElementById("new-title").dataset.manual) {
    document.getElementById("new-title").value = kw ? `${kw}（具体疑問タイトルに編集）` : "";
  }
});
document.getElementById("new-title").addEventListener("input", () => {
  document.getElementById("new-title").dataset.manual = "1";
});

const urlKw = new URLSearchParams(window.location.search).get("keyword");
if (urlKw) {
  const kwEl = document.getElementById("new-keyword");
  if (kwEl) {
    kwEl.value = urlKw;
    kwEl.dispatchEvent(new Event("input"));
    kwEl.scrollIntoView({ behavior: "smooth", block: "center" });
  }
}

function getPin() {
  return localStorage.getItem(KEY) || "";
}

function setDeployStatus(el, type, text) {
  el.style.display = "block";
  el.className = type === "loading"
    ? "dev-deploy__status is-loading"
    : type === "ok"
      ? "dev-deploy__status is-ok"
      : "dev-deploy__status is-error";
  el.textContent = text;
}

async function callDispatch(action, extra = {}) {
  const res = await fetch("/api/dispatch", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ pin: getPin(), action, ...extra }),
  });
  const data = await res.json();
  if (!res.ok || !data.ok) {
    throw new Error(data.error || data.detail || "エラーが発生しました");
  }
  return data;
}

document.getElementById("deploy-all")?.addEventListener("click", async () => {
  const btn = document.getElementById("deploy-all");
  const statusEl = document.getElementById("deploy-all-status");
  if (!confirm("main の最新を本番（seiji1192.site）に反映します。よろしいですか？")) return;

  btn.disabled = true;
  setDeployStatus(statusEl, "loading", "⏳ 本番デプロイを起動中…");

  try {
    const data = await callDispatch("deploy");
    setDeployStatus(statusEl, "ok", "✅ " + data.message);
  } catch (e) {
    setDeployStatus(statusEl, "error", "❌ " + e.message);
  } finally {
    btn.disabled = false;
  }
});

document.querySelectorAll(".publish-slug-btn").forEach((btn) => {
  btn.addEventListener("click", async () => {
    const slug = btn.dataset.slug;
    const statusEl = document.querySelector(`.deploy-slug-status[data-slug="${slug}"]`);
    if (!confirm(`「${slug}」を一般公開します。\n/case/${slug}/ が誰でも見られるようになります。よろしいですか？`)) return;

    btn.disabled = true;
    statusEl.hidden = false;
    statusEl.className = "deploy-slug-status is-loading";
    statusEl.textContent = "⏳ 公開処理中…";

    try {
      const data = await callDispatch("deploy_article", { slug });
      statusEl.className = "deploy-slug-status is-ok";
      statusEl.textContent = "✅ " + data.message;
    } catch (e) {
      statusEl.className = "deploy-slug-status is-error";
      statusEl.textContent = "❌ " + e.message;
    } finally {
      btn.disabled = false;
    }
  });
});

// 記事生成
document.getElementById("new-generate").addEventListener("click", async () => {
  const keyword = document.getElementById("new-keyword").value.trim();
  const titleIn = document.getElementById("new-title").value.trim();
  const pin = getPin();

  if (!keyword) {
    alert("キーワードを入力してください");
    return;
  }

  const statusEl = document.getElementById("new-status");
  const btn = document.getElementById("new-generate");
  statusEl.style.display = "block";
  statusEl.className = "dev-new-article__status is-loading";
  statusEl.textContent = "⏳ 生成可否を確認中（ソース・国会API）…";
  btn.disabled = true;

  try {
    const res = await fetch("/api/dispatch", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ pin, keyword, title: titleIn }),
    });
    const data = await res.json();
    if (data.ok) {
      statusEl.className = "dev-new-article__status is-ok";
      statusEl.textContent = `✅ ${data.message}`;
      if (data.slug) {
        statusEl.textContent += ` — slug: ${data.slug}`;
      }
    } else {
      statusEl.className = "dev-new-article__status is-error";
      statusEl.textContent = "❌ " + (data.error || "生成できません");
      alert("生成できませんでした。\n\n" + (data.error || "条件を満たせませんでした。"));
    }
  } catch (e) {
    statusEl.className = "dev-new-article__status is-error";
    statusEl.textContent = "❌ 通信エラー: " + e.message;
    alert("通信エラー: " + e.message);
  } finally {
    btn.disabled = false;
  }
});

async function refreshLiveStatus() {
  const pin = getPin();
  if (!pin) return;
  const badge = document.getElementById("status-live-badge");
  const err = document.getElementById("status-live-error");
  try {
    let st = null;
    const ts = Date.now();

    const r1 = await fetch(`/api/project-status?pin=${encodeURIComponent(pin)}&t=${ts}`);
    if (r1.ok) {
      const ct = r1.headers.get("content-type") || "";
      if (ct.includes("application/json")) {
        const d1 = await r1.json();
        if (d1.ok && d1.status) st = d1.status;
      }
    }

    if (!st) {
      const r2 = await fetch(`/api/admin-status?pin=${encodeURIComponent(pin)}&t=${ts}`);
      if (r2.ok) {
        const d2 = await r2.json();
        if (d2.projectStatus) st = d2.projectStatus;
        if (d2.deployFailed && err) {
          err.hidden = false;
          err.textContent = "⚠ 直近のデプロイ失敗 — 完成度はライブ、記事HTMLは古い可能性";
        }
      }
    }

    if (!st) {
      const r3 = await fetch(`/status-live.json?t=${ts}`);
      if (r3.ok) st = await r3.json();
    }

    if (!st) {
      if (err) {
        err.hidden = false;
        err.textContent = "⚠ ライブ取得失敗 — 再試行中…";
      }
      return;
    }

    applyLiveStatus(st);
    if (badge) badge.hidden = false;
    if (err) err.hidden = true;
  } catch {
    if (err) {
      err.hidden = false;
      err.textContent = "⚠ ライブ取得エラー — 再試行中…";
    }
  }
}

function applyLiveStatus(st) {
  const ring = document.getElementById("status-hero-ring");
  const pctEl = document.getElementById("status-hero-pct");
  const prev = pctEl ? Number.parseInt(pctEl.textContent, 10) : null;
  const next = st.overallGoldPct ?? 0;

  if (ring) ring.style.setProperty("--pct", String(next));
  if (pctEl) pctEl.textContent = `${next}%`;
  if (pctEl && prev !== null && prev !== next) {
    pctEl.classList.add("is-bump");
    setTimeout(() => pctEl.classList.remove("is-bump"), 600);
  }

  const pub = document.getElementById("stat-published");
  if (pub) pub.textContent = `${st.publishedCount} / ${st.activeCount} 件`;
  const parked = document.getElementById("stat-parked");
  if (parked) parked.textContent = `${st.parkedCount} 件`;
  const gate = document.getElementById("stat-gate");
  if (gate) gate.textContent = `${st.overallGatePct}%`;
  const updated = document.getElementById("stat-updated");
  if (updated && st.generatedAt) {
    updated.textContent = new Date(st.generatedAt).toLocaleString("ja-JP");
  }

  const deltaWrap = document.getElementById("stat-delta-wrap");
  const deltaEl = document.getElementById("stat-delta");
  if (deltaWrap && deltaEl && st.deltaGoldPct != null && st.deltaGoldPct !== 0) {
    deltaWrap.hidden = false;
    deltaEl.className = st.deltaGoldPct > 0 ? "is-up" : "is-down";
    deltaEl.textContent = `${st.deltaGoldPct > 0 ? "+" : ""}${st.deltaGoldPct}%`;
  }

  for (const s of st.slugs ?? []) {
    const card = document.querySelector(`.status-card[data-slug="${s.slug}"]`);
    if (!card) continue;
    const cardPct = card.querySelector(".status-card__pct");
    if (cardPct) cardPct.textContent = `${s.goldPct}%`;
    const fill = card.querySelector(".status-card__bar > span");
    if (fill) fill.style.width = `${s.goldPct}%`;
    const bar = card.querySelector(".status-card__bar");
    if (bar) bar.setAttribute("aria-valuenow", String(s.goldPct));
  }
}

let liveStatusTimer = null;
function startLiveStatusPoll() {
  if (liveStatusTimer) return;
  refreshLiveStatus();
  refreshBufferStatus();
  initAdminPager();
  setInterval(refreshLiveStatus, 15000);
  setInterval(refreshBufferStatus, 15000);
}

async function refreshBufferStatus() {
  const pin = getPin();
  const summary = document.getElementById("buffer-summary");
  const meta = document.getElementById("buffer-meta");
  const fixes = document.getElementById("buffer-fix-steps");
  const panel = document.getElementById("buffer-panel");
  if (!summary || !meta) return;

  /** @type {object|null} */
  let live = null;
  /** @type {object|null} */
  let file = null;

  if (pin) {
    try {
      const res = await fetch(`/api/buffer-status?pin=${encodeURIComponent(pin)}`);
      live = await res.json();
    } catch { /* local dev fallback */ }
  }
  try {
    const res = await fetch(`/buffer-status.json?t=${Date.now()}`);
    if (res.ok) file = await res.json();
  } catch { /* ignore */ }

  const s = live && !live.error ? live : file;
  if (!s) {
    summary.className = "dev-buffer-panel__summary is-error";
    summary.textContent = "⚠️ 状態取得失敗";
    return;
  }

  const ok = s.ok === true;
  const failed = s.status === "post_failed" || s.lastPostOk === false;
  panel?.classList.toggle("is-error", !ok || failed);
  panel?.classList.toggle("is-ok", ok && !failed);

  if (!s.configured) {
    summary.className = "dev-buffer-panel__summary";
    summary.textContent = "⏸️ 未設定 — Buffer API キーを Secret に登録すると deploy 時に X 自動投稿";
  } else if (!ok) {
    summary.className = "dev-buffer-panel__summary is-error";
    summary.textContent = `🔴 ${s.statusLabel} — ${s.message}`;
  } else if (failed) {
    summary.className = "dev-buffer-panel__summary is-error";
    summary.textContent = `🟠 連携OKだが直近投稿失敗 — ${s.lastPostError || s.message}`;
  } else {
    summary.className = "dev-buffer-panel__summary is-ok";
    summary.textContent = `🟢 ${s.statusLabel} — ${s.message}`;
  }

  const rows = [];
  if (s.channelName) rows.push(["X チャンネル", s.channelName]);
  if (s.lastPostAt) {
    rows.push([
      "最終投稿",
      `${s.lastPostSlug || "—"} · ${new Date(s.lastPostAt).toLocaleString("ja-JP")} · ${s.lastPostOk ? "OK" : "NG"}`,
    ]);
  }
  if (s.postsToday != null) rows.push(["本日", `${s.postsToday}/${s.dailyCap ?? 3} 本`]);
  if (s.lastCheckAt || s.fetchedAt) {
    rows.push(["確認", new Date(s.fetchedAt || s.lastCheckAt).toLocaleString("ja-JP")]);
  }
  meta.innerHTML = rows
    .map(([dt, dd]) => `<div><dt>${dt}</dt><dd>${dd}</dd></div>`)
    .join("");

  const steps = s.fixSteps ?? [];
  if (fixes) {
    if (steps.length && (!ok || failed)) {
      fixes.hidden = false;
      fixes.innerHTML = steps.map((x) => `<li>${x}</li>`).join("");
    } else {
      fixes.hidden = true;
      fixes.innerHTML = "";
    }
  }
}

const ADMIN_PAGE_SIZE = 8;
let adminFilter = "action";
let adminPage = 1;

function initAdminPager() {
  const tabs = document.getElementById("admin-tabs");
  const prev = document.getElementById("admin-prev");
  const next = document.getElementById("admin-next");
  if (!tabs) return;

  tabs.querySelectorAll("[data-filter]").forEach((btn) => {
    btn.addEventListener("click", () => {
      adminFilter = btn.getAttribute("data-filter") || "action";
      adminPage = 1;
      tabs.querySelectorAll(".status-slugs__tab").forEach((t) => t.classList.remove("is-active"));
      btn.classList.add("is-active");
      renderAdminPage();
    });
  });
  prev?.addEventListener("click", () => {
    if (adminPage > 1) {
      adminPage -= 1;
      renderAdminPage();
    }
  });
  next?.addEventListener("click", () => {
    adminPage += 1;
    renderAdminPage();
  });
  renderAdminPage();
}

function renderAdminPage() {
  const cards = [...document.querySelectorAll("#admin-cards .status-card")];
  const matched = cards.filter((c) => {
    const f = c.getAttribute("data-admin-filter");
    return adminFilter === "all" || f === adminFilter;
  });
  const totalPages = Math.max(1, Math.ceil(matched.length / ADMIN_PAGE_SIZE));
  if (adminPage > totalPages) adminPage = totalPages;

  cards.forEach((c) => {
    c.style.display = "none";
  });

  const start = (adminPage - 1) * ADMIN_PAGE_SIZE;
  matched.slice(start, start + ADMIN_PAGE_SIZE).forEach((c) => {
    c.style.display = "";
  });

  const pager = document.getElementById("admin-pager");
  const label = document.getElementById("admin-page-label");
  const empty = document.getElementById("admin-empty");
  const hint = document.getElementById("admin-filter-hint");

  if (empty) empty.hidden = matched.length > 0;
  if (pager) pager.hidden = matched.length <= ADMIN_PAGE_SIZE;
  if (label) label.textContent = `${adminPage} / ${totalPages}（${matched.length}件）`;
  if (document.getElementById("admin-prev")) {
    document.getElementById("admin-prev").disabled = adminPage <= 1;
  }
  if (document.getElementById("admin-next")) {
    document.getElementById("admin-next").disabled = adminPage >= totalPages;
  }
  if (hint) {
    const hints = {
      action: "制作中・非表示 — いま手を入れる案件",
      draft: "完成・非公開 — プレビュー確認後に公開",
      live: "公開済み — 薄く表示（終わった案件）",
      all: "全案件 — 公開済みは末尾",
    };
    hint.textContent = hints[adminFilter] || "";
  }
  const wrap = document.getElementById("admin-cards");
  if (wrap) wrap.dataset.filterMode = adminFilter;
}

document.querySelectorAll(".save-title-btn").forEach((btn) => {
  btn.addEventListener("click", async () => {
    const slug = btn.dataset.slug;
    const input = document.querySelector(`.status-card__title-input[data-slug="${slug}"]`);
    const statusEl = document.querySelector(`.title-save-status[data-slug="${slug}"]`);
    const title = input?.value?.trim();
    if (!title) { alert("タイトルを入力してください"); return; }
    btn.disabled = true;
    statusEl.hidden = false;
    statusEl.className = "title-save-status is-loading";
    statusEl.textContent = "⏳ 保存中…";
    try {
      const data = await callDispatch("update_title", { slug, title });
      statusEl.className = "title-save-status is-ok";
      statusEl.textContent = "✅ " + data.message;
    } catch (e) {
      statusEl.className = "title-save-status is-error";
      statusEl.textContent = "❌ " + e.message;
    } finally {
      btn.disabled = false;
    }
  });
});

document.querySelectorAll(".hide-btn").forEach((btn) => {
  btn.addEventListener("click", () => adminAction(btn, "hide", "非表示にしますか？"));
});
document.querySelectorAll(".unhide-btn").forEach((btn) => {
  btn.addEventListener("click", () => adminAction(btn, "unhide", "表示に戻しますか？"));
});
document.querySelectorAll(".delete-btn").forEach((btn) => {
  btn.addEventListener("click", () => adminAction(btn, "delete_article", "完全に削除します。元に戻せません。よろしいですか？"));
});

async function adminAction(btn, action, confirmMsg) {
  const slug = btn.dataset.slug;
  if (!confirm(confirmMsg)) return;
  const statusEl = document.querySelector(`.admin-action-status[data-slug="${slug}"]`);
  btn.disabled = true;
  statusEl.hidden = false;
  statusEl.className = "admin-action-status is-loading";
  statusEl.textContent = "⏳ 処理中…";
  try {
    const data = await callDispatch(action, { slug });
    statusEl.className = "admin-action-status is-ok";
    statusEl.textContent = "✅ " + data.message + " — 15秒後に再読込";
    setTimeout(() => location.reload(), 15000);
  } catch (e) {
    statusEl.className = "admin-action-status is-error";
    statusEl.textContent = "❌ " + e.message;
    btn.disabled = false;
  }
}
</script>
