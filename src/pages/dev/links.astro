---
import AdminShell from "../../components/admin/AdminShell.astro";
import SupportCta from "../../components/SupportCta.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { SITE } from "../../lib/site-config.mjs";
import { getOutboundLinkGroups } from "../../lib/note-link.mjs";

const groups = getOutboundLinkGroups();
---

<AdminShell activeId="links" title="リンク">
  <header class="admin-page-head">
    <h1 class="admin-page-head__title">リンク</h1>
    <p class="admin-page-head__note">
      <code>site-config</code> の外部リンクと、公開フッター・支援CTAのプレビュー。
    </p>
  </header>

  <div class="admin-page-content admin-page-content--full">
    {
      groups.map((group) => (
        <section class="admin-hub__section" aria-labelledby={`links-${group.title}`}>
          <h2 id={`links-${group.title}`} class="admin-hub__heading">{group.title}</h2>
          <div class="admin-list">
            {group.links.map((link) => (
              <article class="admin-row">
                <div class="admin-row__grid admin-row__grid--fluid">
                  <div class="admin-row__main">
                    <header class="admin-row__head">
                      <h3 class="admin-row__title">
                        <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
                      </h3>
                    </header>
                    {link.note && <p class="admin-row__summary">{link.note}</p>}
                  </div>
                  <div class="admin-row__quick">
                    <a href={link.href} class="admin-row__btn admin-row__btn--primary" target="_blank" rel="noopener noreferrer">
                      開く ↗
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))
    }

    <section class="admin-hub__section" aria-labelledby="footer-preview-title">
      <h2 id="footer-preview-title" class="admin-hub__heading">公開フッター（プレビュー）</h2>
      <div class="admin-surface">
        <div class="admin-surface__body">
          <SiteFooter />
        </div>
      </div>
    </section>

    <section class="admin-hub__section" aria-labelledby="cta-preview-title">
      <h2 id="cta-preview-title" class="admin-hub__heading">記事末尾 SupportCta（プレビュー）</h2>
      <div class="admin-surface">
        <div class="admin-surface__body">
          <SupportCta context="dev-links-preview" />
        </div>
      </div>
    </section>

    <section class="admin-hub__section" aria-labelledby="config-raw-title">
      <h2 id="config-raw-title" class="admin-hub__heading">設定値</h2>
      <dl class="admin-config-dl">
        <dt>noteMembershipLive</dt>
        <dd>{String(SITE.noteMembershipLive)}</dd>
        <dt>supportAbVariant</dt>
        <dd>{SITE.supportAbVariant}</dd>
      </dl>
    </section>
  </div>
</AdminShell>

<style>
  .admin-config-dl {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 0.35rem 1rem;
    font-size: 0.88rem;
    margin: 0;
    padding: 1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 0.65rem;
  }
  .admin-config-dl dt { font-weight: 700; color: var(--color-text-muted); }
  .admin-config-dl dd { margin: 0; }
</style>
