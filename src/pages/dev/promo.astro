---
import BaseLayout from "../../layouts/DevLayout.astro";
import DevHeader from "../../components/DevHeader.astro";
import DevChromeOpen from "../../components/DevChromeOpen.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { loadAllArticles } from "../../lib/articles.mjs";
import { articleShortTitle } from "../../lib/case-helpers.mjs";
import { buildPromoSprint, localDateStr } from "../../lib/promo-sprint.mjs";
import { formatWeeklyDigestMarkdown, articleWeekActivity } from "../../lib/promo-generate.mjs";
import { buildSharePayload } from "../../lib/share.mjs";
import { SITE } from "../../lib/site-config.mjs";

const articles = await loadAllArticles();
const sprint = buildPromoSprint(articles);
const todayIso = localDateStr();

const sinceMs = Date.now() - 7 * 86400000;
const weekArticles = articles.filter((a) => articleWeekActivity(a, sinceMs));
const noteDigest = formatWeeklyDigestMarkdown(weekArticles.length ? weekArticles : articles.slice(0, 5), `${todayIso}（直近7日）`);

const siteXUrl = (() => {
  const text = "国会・政府の出典付きで「あの話どうなった？」を追います。\n";
  const params = new URLSearchParams({ text, url: SITE.domain, related: "seiji1192site" });
  return `https://twitter.com/intent/tweet?${params}`;
})();
---

<BaseLayout tabTitle="·">
  <DevHeader current="promo" />
  <div id="dev-gate" style="display:none">
    <main class="container promo-page">
      <p class="status-page__lead status-page__lead--dev">🔒 認証が必要です</p>
      <h1 class="status-page__title">プロモ強化</h1>
      <p class="promo-page__lead">
        文案の自動生成・確認用（<strong>オーナー投稿タスクなし</strong>）。Indexing API / IndexNow は deploy 時自動。
      </p>
      <aside class="promo-auto-note" role="note">
        <strong>自動化相談一覧</strong> — X API（有料）・Buffer（無料枠）・OGP自動（CEO実装可）等は
        リポジトリ内 <code>docs/promo-automation-options.md</code> を参照。
      </aside>

      <aside class="dev-chrome-banner" role="note">
        <strong>X・はてブ・note は Chrome で開く。</strong>
        「Chromeで開く」→ URLコピー → Chromeの Ctrl+L → Ctrl+V。
      </aside>

      <nav class="promo-quick" aria-label="プロモ関連">
        <a href="/dev/tasks/">今日のタスク →</a>
        <a href="/dev/hatena/">はてブ一覧 →</a>
        <DevChromeOpen url={SITE.xUrl} label="Chromeで @seiji1192site を開く" compact />
        <DevChromeOpen url={SITE.noteUrl} label="Chromeで note を開く" compact />
      </nav>

      <section class="promo-today" aria-labelledby="promo-today-title">
        <h2 id="promo-today-title" class="promo-section__title">
          今日の推奨（{sprint.today?.dayLabel} {sprint.today?.date}）
        </h2>
        {
          sprint.today?.title ? (
            <article class="promo-card promo-card--featured">
              <header class="promo-card__head">
                <h3 class="promo-card__title">{sprint.today.title}</h3>
                <a href={`/dev/hatena/#${sprint.today.slug}`} class="promo-card__link">はてブ →</a>
              </header>

              <div class="promo-variants">
                {
                  sprint.today.variants?.map((v) => (
                    <div class="ops-copy-block">
                      <div class="ops-copy-block__head">
                        <span class="ops-copy-block__label">{v.label}</span>
                        <div class="ops-copy-block__actions">
                          {
                            v.id === "main" && sprint.today.xUrl ? (
                              <DevChromeOpen url={sprint.today.xUrl} label="Chromeで X投稿" compact />
                            ) : null
                          }
                          <button type="button" class="ops-copy-btn promo-copy" data-copy={v.text}>
                            コピー
                          </button>
                        </div>
                      </div>
                      <pre class="ops-copy-block__text">{v.text}</pre>
                    </div>
                  ))
                }
              </div>

              {
                sprint.today.thread2 ? (
                  <div class="ops-copy-block">
                    <div class="ops-copy-block__head">
                      <span class="ops-copy-block__label">スレッド 2/3（任意）</span>
                      <button type="button" class="ops-copy-btn promo-copy" data-copy={sprint.today.thread2}>
                        コピー
                      </button>
                    </div>
                    <pre class="ops-copy-block__text">{sprint.today.thread2}</pre>
                  </div>
                ) : null
              }

              {
                sprint.today.hatenaAddUrl ? (
                  <div class="hatena-row">
                    <span class="hatena-row__label">はてブ</span>
                    <DevChromeOpen url={sprint.today.hatenaAddUrl} label="Chromeではてブ登録" compact />
                    <button type="button" class="ops-copy-btn promo-copy" data-copy={sprint.today.hatenaComment || ""}>
                      コメントコピー
                    </button>
                  </div>
                ) : null
              }
            </article>
          ) : (
            <p class="promo-empty">公開案件がありません。</p>
          )
        }
      </section>

      <section class="promo-week" aria-labelledby="promo-week-title">
        <h2 id="promo-week-title" class="promo-section__title">今週のローテ（{sprint.weekStart}〜）</h2>
        <ul class="promo-week-grid">
          {
            sprint.daily.map((d) => (
              <li class={`promo-week-day${d.date === todayIso ? " is-today" : ""}`}>
                <span class="promo-week-day__label">{d.dayLabel}</span>
                <time class="promo-week-day__date" datetime={d.date}>{d.date.slice(5)}</time>
                <span class="promo-week-day__title">{d.title || "—"}</span>
                {d.slug ? <a href={`#day-${d.slug}`} class="promo-week-day__jump">詳細↓</a> : null}
              </li>
            ))
          }
        </ul>
        <ol class="promo-plan">
          {sprint.ownerWeeklyPlan.map((step) => <li>{step}</li>)}
        </ol>
      </section>

      <section class="promo-site" aria-labelledby="promo-site-title">
        <h2 id="promo-site-title" class="promo-section__title">サイトフォロー促進（金曜推奨）</h2>
        <div class="ops-copy-block">
          <div class="ops-copy-block__head">
            <span class="ops-copy-block__label">アカウント紹介投稿</span>
            <div class="ops-copy-block__actions">
              <DevChromeOpen url={siteXUrl} label="Chromeで X投稿" compact />
              <button type="button" class="ops-copy-btn promo-copy" data-copy={sprint.siteFollow}>
                コピー
              </button>
            </div>
          </div>
          <pre class="ops-copy-block__text">{sprint.siteFollow}</pre>
        </div>
      </section>

      <section class="promo-note" aria-labelledby="promo-note-title">
        <h2 id="promo-note-title" class="promo-section__title">note 週次ダイジェスト（木曜推奨）</h2>
        <div class="ops-copy-block">
          <div class="ops-copy-block__head">
            <span class="ops-copy-block__label">本文ドラフト</span>
            <div class="ops-copy-block__actions">
              <DevChromeOpen url={SITE.noteUrl} label="Chromeで note 新規" compact />
              <button type="button" class="ops-copy-btn promo-copy" data-copy={noteDigest}>
                全文コピー
              </button>
            </div>
          </div>
          <pre class="ops-copy-block__text promo-note__body">{noteDigest}</pre>
        </div>
      </section>

      <section class="promo-all" aria-labelledby="promo-all-title">
        <h2 id="promo-all-title" class="promo-section__title">全案件クイック投稿</h2>
        <p class="promo-page__hint">未投稿の案件から優先。詳細文案は <a href="/dev/hatena/">はてブ</a> にもあり。</p>
        <ul class="promo-all-list">
          {
            articles.map((a) => {
              const { xUrl } = buildSharePayload(a);
              const title = articleShortTitle(a);
              return (
                <li class="promo-all-item" id={`day-${a.slug}`}>
                  <span class="promo-all-item__title">{title}</span>
                  <DevChromeOpen url={xUrl} label="X" compact />
                  <a href={`/dev/hatena/#${a.slug}`} class="promo-all-item__hatena">はてブ</a>
                </li>
              );
            })
          }
        </ul>
      </section>
    </main>
  </div>

  <div id="dev-lock" style="display:none">
    <div style="min-height:60vh;display:flex;align-items:center;justify-content:center">
      <div style="text-align:center;padding:2rem">
        <p style="font-size:1.1rem;margin-bottom:1rem">🔒 PINを入力してください</p>
        <input id="pin-input" type="password" maxlength="8"
          style="font-size:1.5rem;text-align:center;width:8rem;padding:0.5rem;border:2px solid var(--color-border);border-radius:0.5rem"
          placeholder="••••" />
        <br><br>
        <button id="pin-submit"
          style="background:var(--color-primary);color:#fff;border:none;padding:0.6rem 1.5rem;border-radius:2rem;font-size:1rem;cursor:pointer">
          入力
        </button>
        <p id="pin-error" style="color:red;margin-top:0.5rem;display:none">PINが違います</p>
      </div>
    </div>
  </div>

  <SiteFooter note="" />
</BaseLayout>

<script>
const PIN = "1192";
const KEY = "dev_auth";

function show(id) { document.getElementById(id).style.display = "block"; }
function hide(id) { document.getElementById(id).style.display = "none"; }

if (localStorage.getItem(KEY) === PIN) {
  show("dev-gate");
} else {
  show("dev-lock");
  document.getElementById("pin-submit").addEventListener("click", () => {
    const val = document.getElementById("pin-input").value;
    if (val === PIN) {
      localStorage.setItem(KEY, PIN);
      hide("dev-lock");
      show("dev-gate");
    } else {
      document.getElementById("pin-error").style.display = "block";
    }
  });
  document.getElementById("pin-input").addEventListener("keydown", (e) => {
    if (e.key === "Enter") document.getElementById("pin-submit").click();
  });
}

document.querySelectorAll(".promo-copy").forEach((btn) => {
  btn.addEventListener("click", async () => {
    const text = btn.getAttribute("data-copy") || "";
    try {
      await navigator.clipboard.writeText(text);
      const prev = btn.textContent;
      btn.textContent = "コピー済";
      setTimeout(() => { btn.textContent = prev; }, 1200);
    } catch {
      btn.textContent = "失敗";
    }
  });
});
</script>
