---
import AdminShell from "../../components/admin/AdminShell.astro";
import AdminKpiBar from "../../components/admin/AdminKpiBar.astro";
import { loadTrendingTopics } from "../../lib/trending-topics.mjs";

const data = await loadTrendingTopics();
const fetchedAt = data?.fetchedAt
  ? new Date(data.fetchedAt).toLocaleString("ja-JP", { timeZone: "Asia/Tokyo" })
  : "未取得";

const trendCards = data?.trendCards ?? data?.political?.slice(0, 12) ?? [];
const evergreen = data?.evergreen ?? [];
const unpublished = evergreen.filter((e) => !e.published).length;
---

<AdminShell activeId="trends" title="関心ワード">
  <header class="admin-page-head">
    <h1 class="admin-page-head__title">関心ワード</h1>
    <p class="admin-page-head__note">
      政治・社会の注目キーワードから記事案を拾う。最終取得: {fetchedAt}
    </p>
  </header>

  <AdminKpiBar items={[
    { label: "トレンド", value: String(trendCards.length) },
    { label: "常連テーマ", value: String(evergreen.length) },
    { label: "未公開", value: String(unpublished), tone: unpublished ? "warn" : undefined },
    { label: "更新", value: "deploy時" },
  ]} />

  {!data && (
    <p class="admin-list__empty">データを読み込めませんでした。次回デプロイで自動取得されます。</p>
  )}

  {data && (
    <>
      <section class="admin-hub__section">
        <h2 class="admin-hub__heading">いまのトレンド（{trendCards.length}件）</h2>
        <p class="admin-page-head__note" style="margin:0 0 1rem">
          Yahooトピックス・Google急上昇・NHK政治/社会から自動取得。スポーツ・芸能は除外。
        </p>
        {trendCards.length === 0 ? (
          <p class="admin-list__empty">取得データなし。</p>
        ) : (
          <div class="admin-list admin-trends-grid">
            {trendCards.map((item) => (
              <article class="admin-row">
                <div class="admin-row__grid admin-row__grid--stack">
                  <div class="admin-row__main">
                    <header class="admin-row__head">
                      <span class="admin-row__badge admin-row__badge--cat">{item.source}</span>
                      {item.traffic && <span class="admin-row__badge admin-row__badge--ng">{item.traffic}</span>}
                    </header>
                    <h3 class="admin-row__title">{item.headline || item.keyword}</h3>
                    <p class="admin-row__summary">検索: {item.keyword}</p>
                    <div class="admin-row__quick" style="margin-top:0.65rem">
                      <button type="button" class="admin-row__btn admin-row__btn--primary use-keyword" data-keyword={item.keyword}>
                        記事作成へ
                      </button>
                      {item.url && (
                        <a class="admin-row__btn" href={item.url} target="_blank" rel="noopener noreferrer">ニュース</a>
                      )}
                      {item.articleSlug && (
                        <a class="admin-row__btn admin-row__btn--ghost" href={`/dev/preview/${item.articleSlug}/`}>プレビュー</a>
                      )}
                    </div>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}
      </section>

      <section class="admin-hub__section">
        <h2 class="admin-hub__heading">常連テーマ</h2>
        <div class="admin-list admin-trends-grid">
          {evergreen.map((item) => (
            <article class="admin-row">
              <div class="admin-row__grid admin-row__grid--stack">
                <div class="admin-row__main">
                  <header class="admin-row__head">
                    <span class:list={["admin-row__badge", item.published ? "admin-row__badge--live" : "admin-row__badge--draft"]}>
                      {item.published ? "公開済" : "未公開"}
                    </span>
                  </header>
                  <h3 class="admin-row__title">{item.headline}</h3>
                  <p class="admin-row__summary">検索: {item.keyword}</p>
                  <div class="admin-row__quick" style="margin-top:0.65rem">
                    <button type="button" class="admin-row__btn use-keyword" data-keyword={item.keyword}>記事作成へ</button>
                    {item.articleSlug && (
                      <a class="admin-row__btn admin-row__btn--ghost" href={`/dev/preview/${item.articleSlug}/`}>プレビュー</a>
                    )}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="admin-hub__section">
        <h2 class="admin-hub__heading">タイトル・ショートの型</h2>
        <ul class="admin-guide-list">
          <li><strong>タイトル</strong> — 政策名ではなく読者の疑問。数字＋「いまどうなった？」。全角42字以内。</li>
          <li><strong>冒頭2秒</strong> — テロップ2行・1行14字以内。「数字の矛盾」か「？」で止める。</li>
          <li><strong>禁止</strong> — 裏切り・嘘・煽り評価語。</li>
        </ul>
      </section>
    </>
  )}
</AdminShell>

<style>
  .admin-trends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 0.5rem;
  }
  .admin-trends-grid .admin-row { margin-bottom: 0; height: 100%; }
  .admin-guide-list {
    margin: 0;
    padding: 1rem 1rem 1rem 1.35rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 0.65rem;
    line-height: 1.7;
    font-size: 0.92rem;
  }
</style>

<script>
document.querySelectorAll(".use-keyword").forEach((btn) => {
  btn.addEventListener("click", () => {
    const kw = btn.getAttribute("data-keyword") || "";
    if (!kw) return;
    const url = new URL("/dev/articles/", window.location.origin);
    url.searchParams.set("keyword", kw);
    window.location.href = url.toString();
  });
});
</script>
