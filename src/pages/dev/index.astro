---
import AdminShell from "../../components/admin/AdminShell.astro";
import { loadDashboardData } from "../../lib/admin-dashboard.mjs";

const dash = await loadDashboardData();
const { status, patrol, cards, activeArticle, generatedAtLabel, patrolHealth } = dash;
---

<AdminShell activeId="dashboard" title="ダッシュボード" liveStatus={true}>
  {status && (
    <header class="admin-dash__hero" aria-label="サイト完成度">
      <div class="admin-dash__ring" id="dash-hero-ring" style={`--pct: ${status.overallGoldPct}`}>
        <span class="admin-dash__pct" id="dash-hero-pct">{status.overallGoldPct}%</span>
        <span class="admin-dash__pct-sub">100%完成</span>
      </div>
      <div class="admin-dash__hero-body">
        <h1 class="admin-dash__title">ダッシュボード</h1>
        <p class="admin-dash__sync">本番同期は品質巡回が自動 · 15秒ごとに更新</p>
        <dl class="admin-dash__stats">
          <div><dt>一般公開</dt><dd id="stat-published">{status.publishedCount}/{status.activeCount}</dd></div>
          <div><dt>ゲート</dt><dd id="stat-gate">{status.overallGatePct}%</dd></div>
          <div><dt>品質NG</dt><dd id="stat-quality">{status.qualityFailed}件</dd></div>
          <div><dt>更新</dt><dd id="stat-updated">{generatedAtLabel}</dd></div>
        </dl>
      </div>
    </header>
  )}

  <section class="admin-dash__patrol" aria-label="巡回状態">
    {patrolHealth?.status === "stalled" ? (
      <p class="admin-dash__patrol-stalled">
        <strong>進行停止</strong> — プロセスは動いていますが完成度が上がっていません。下の詳細を確認
      </p>
    ) : patrolHealth?.status === "paused" ? (
      <p class="admin-dash__patrol-paused">
        <strong>一時停止</strong> — {patrolHealth.message}
      </p>
    ) : patrol.running ? (
      activeArticle || patrol.activeSlug ? (
        <p class="admin-dash__patrol-live">
          <span class="admin-row__work-icon is-demo-spin" aria-hidden="true"></span>
          <strong>今処理中</strong>
          <span id="dash-patrol-slug">{activeArticle?.shortTitle ?? patrol.activeSlug}</span>
          <span class="admin-dash__patrol-check" id="dash-patrol-check">
            — {patrol.activeLabel ?? activeArticle?.workItems?.find((w) => w.state === "active")?.label ?? "品質チェック"}
          </span>
        </p>
      ) : (
        <p class="admin-dash__patrol-idle">
          <span class="admin-dash__patrol-dot" aria-hidden="true">●</span>
          巡回は動作中（サイクル待機中）。未着手の作業は記事一覧で<strong>赤×</strong>表示
        </p>
      )
    ) : (
      <p class="admin-dash__patrol-off">品質巡回は停止中</p>
    )}
  </section>

  <section class="admin-dash__legend" aria-label="作業状態の見方">
    <h2 class="admin-dash__legend-title">作業状態の見方</h2>
    <ul class="admin-dash__legend-list">
      <li>
        <span class="admin-row__work-item is-active admin-dash__legend-chip">
          <span class="admin-row__work-icon" aria-hidden="true"></span>
          <span>くるくる＝今この項目を処理中</span>
        </span>
      </li>
      <li>
        <span class="admin-row__work-item is-blocked admin-dash__legend-chip">
          <span class="admin-row__work-icon" aria-hidden="true">✕</span>
          <span>赤×＝未着手・待ち（動いていない）</span>
        </span>
      </li>
      <li>完了した項目は一覧に出しません</li>
    </ul>
  </section>

  <div class="admin-dash__cards-head">
    <h2 class="admin-dash__cards-title">メニュー</h2>
    <p class="admin-dash__cards-hint">カードをドラッグして並び替え（このブラウザに保存）</p>
  </div>

  <div class="admin-dash__cards" id="dash-cards" data-cards={JSON.stringify(cards.map((c) => c.id))}>
    {
      cards.map((card) => (
        <div
          class:list={["admin-dash__card", `admin-dash__card--${card.tone}`]}
          data-card-id={card.id}
          draggable="true"
          style={`--card-grad: ${card.gradient}`}
        >
          <span class="admin-dash__card-drag" aria-hidden="true" title="ドラッグで並び替え">⠿</span>
          <a class="admin-dash__card-link" href={card.href}>
            <div class="admin-dash__card-head">
              <span class="admin-dash__card-head-icon" aria-hidden="true">{card.groupIcon}</span>
              <span class="admin-dash__card-head-meta">
                <span class="admin-dash__card-cat">{card.groupLabel}</span>
                <span class="admin-dash__card-title">{card.title}</span>
              </span>
            </div>
            <div class="admin-dash__card-body">
              {card.stat && (
                <p class="admin-dash__card-kpi">
                  <span class="admin-dash__card-kpi-num">{card.stat}</span>
                  {card.statLabel && <span class="admin-dash__card-kpi-lbl">{card.statLabel}</span>}
                </p>
              )}
              {card.lines.length > 0 && (
                <ul class="admin-dash__card-lines">
                  {card.lines.map((line) => (
                    <li>{line}</li>
                  ))}
                </ul>
              )}
            </div>
          </a>
        </div>
      ))
    }
  </div>
</AdminShell>

<script is:inline>
(function () {
  const ORDER_KEY = "admin-dashboard-card-order";
  const grid = document.getElementById("dash-cards");
  if (!grid) return;

  function applyOrder() {
    let order = [];
    try { order = JSON.parse(localStorage.getItem(ORDER_KEY) || "[]"); } catch { /* ignore */ }
    if (!order.length) return;
    const cards = [...grid.querySelectorAll(".admin-dash__card")];
    const byId = Object.fromEntries(cards.map((el) => [el.dataset.cardId, el]));
    order.forEach((id) => { if (byId[id]) grid.appendChild(byId[id]); });
  }

  let dragEl = null;
  grid.addEventListener("dragstart", (e) => {
    const card = e.target.closest(".admin-dash__card");
    if (!card) return;
    dragEl = card;
    card.classList.add("is-dragging");
    e.dataTransfer?.setData("text/plain", card.dataset.cardId || "");
  });
  grid.addEventListener("dragend", () => {
    dragEl?.classList.remove("is-dragging");
    dragEl = null;
    const order = [...grid.querySelectorAll(".admin-dash__card")].map((el) => el.dataset.cardId);
    localStorage.setItem(ORDER_KEY, JSON.stringify(order));
  });
  grid.addEventListener("dragover", (e) => {
    e.preventDefault();
    const card = e.target.closest(".admin-dash__card");
    if (!card || card === dragEl) return;
    const rect = card.getBoundingClientRect();
    const after = e.clientY > rect.top + rect.height / 2;
    grid.insertBefore(dragEl, after ? card.nextSibling : card);
  });

  applyOrder();

  function getPin() { return window.adminGetPin?.() || localStorage.getItem("dev_auth") || ""; }

  async function refreshDash() {
    const pin = getPin();
    if (!pin) return;
    try {
      const ts = Date.now();
      let st = null;
      const r1 = await fetch(`/api/project-status?pin=${encodeURIComponent(pin)}&t=${ts}`);
      if (r1.ok) { const d = await r1.json(); if (d.ok && d.status) st = d.status; }
      if (!st) {
        const r2 = await fetch(`/status-live.json?t=${ts}`);
        if (r2.ok) st = await r2.json();
      }
      if (!st) return;
      const ring = document.getElementById("dash-hero-ring");
      const pct = document.getElementById("dash-hero-pct");
      if (ring) ring.style.setProperty("--pct", String(st.overallGoldPct ?? 0));
      if (pct) pct.textContent = `${st.overallGoldPct ?? 0}%`;
      const pub = document.getElementById("stat-published");
      if (pub) pub.textContent = `${st.publishedCount}/${st.activeCount}`;
      const gate = document.getElementById("stat-gate");
      if (gate) gate.textContent = `${st.overallGatePct}%`;
      const q = document.getElementById("stat-quality");
      if (q) q.textContent = `${st.qualityFailed ?? 0}件`;
      if (st.generatedAt) {
        const u = document.getElementById("stat-updated");
        if (u) u.textContent = new Date(st.generatedAt).toLocaleString("ja-JP");
      }
      const active = (st.slugs ?? []).find((s) => s.runState === "active");
      if (active) {
        const slugEl = document.getElementById("dash-patrol-slug");
        const checkEl = document.getElementById("dash-patrol-check");
        if (slugEl) slugEl.textContent = active.shortTitle || active.slug;
        const w = active.workItems?.find((x) => x.state === "active");
        if (checkEl && w) checkEl.textContent = `— ${w.label}`;
      }
    } catch { /* ignore */ }
  }

  window.addEventListener("admin-live-start", () => {
    refreshDash();
    setInterval(refreshDash, 15000);
  });
  if (localStorage.getItem("dev_auth") === "1192") {
    refreshDash();
    setInterval(refreshDash, 15000);
  }
})();
</script>
