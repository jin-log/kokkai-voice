---
import AdminShell from "../../components/admin/AdminShell.astro";
import DevChromeOpen from "../../components/DevChromeOpen.astro";
import { loadAllArticles } from "../../lib/articles.mjs";
import { articleShortTitle } from "../../lib/case-helpers.mjs";
import { buildHatena, formatXMainPost } from "../../lib/promo-generate.mjs";
import { buildSharePayload } from "../../lib/share.mjs";
import { SITE } from "../../lib/site-config.mjs";

const all = await loadAllArticles();
const articles = all
  .filter((a) => !a.adminHidden && a.pageReady)
  .map((a) => ({
    slug: a.slug,
    shortTitle: articleShortTitle(a),
    publishedAt: a.publishedAt?.slice(0, 10) || "",
    hatena: buildHatena(a),
    xMain: formatXMainPost(a),
    xUrl: buildSharePayload(a).xUrl,
  }))
  .sort((a, b) => (b.publishedAt || "").localeCompare(a.publishedAt || ""));
---

<AdminShell activeId="hatena" title="はてブ投稿">
  <header class="admin-page-head">
    <h1 class="admin-page-head__title">はてブ投稿</h1>
    <p class="admin-page-head__note">新記事公開時だけ。Chromeではてブ登録 → コメントをコピペ（2ステップ）。</p>
  </header>

  <aside class="dev-chrome-banner" role="note">
    <strong>はてブ・Xは Chrome で開く。</strong>
    「Chromeで開く」→ URLコピー → Chromeの Ctrl+L → Ctrl+V。
    Cursor内プレビューではログインできません。
  </aside>

  <section class="hatena-hub admin-toolbar" aria-label="はてブ管理">
    <DevChromeOpen url={SITE.hatenaHotentryUrl} label="Chromeでマイページを開く" />
    <code class="hatena-hub__url">{SITE.hatenaHotentryUrl}</code>
  </section>

  {
    articles.length === 0 ? (
      <p class="hatena-empty">公開済み案件がありません。</p>
    ) : (
      <div class="admin-list">
        {
          articles.map((item) => (
            <article class="admin-row admin-row--live" id={item.slug}>
              <div class="admin-row__grid admin-row__grid--stack">
                <div class="admin-row__main">
                  <header class="admin-row__head">
                    <h2 class="admin-row__title">{item.shortTitle}</h2>
                    {item.publishedAt && (
                      <time class="admin-row__badge" datetime={item.publishedAt}>
                        {item.publishedAt}
                      </time>
                    )}
                  </header>

                  <div class="hatena-row">
                    <span class="hatena-row__label">① はてブ登録（Chrome）</span>
                    <div class="hatena-row__actions">
                      <DevChromeOpen url={item.hatena.addUrl} label="Chromeではてブ登録を開く" />
                      <button type="button" class="ops-copy-btn hatena-copy" data-copy={item.hatena.addUrl}>
                        URLコピー
                      </button>
                    </div>
                  </div>

                  <div class="hatena-row">
                    <span class="hatena-row__label">記事URL（Chrome）</span>
                    <div class="hatena-row__actions">
                      <DevChromeOpen url={item.hatena.pageUrl} label="Chromeで記事を開く" compact />
                      <button type="button" class="ops-copy-btn hatena-copy" data-copy={item.hatena.pageUrl}>
                        コピー
                      </button>
                    </div>
                  </div>

                  <div class="ops-copy-block hatena-x">
                    <div class="ops-copy-block__head">
                      <span class="ops-copy-block__label">X 本投稿（そのまま貼付）</span>
                      <div class="ops-copy-block__actions">
                        <DevChromeOpen url={item.xUrl} label="Chromeで X投稿を開く" compact />
                        <button type="button" class="ops-copy-btn hatena-copy" data-copy={item.xMain}>
                          文案コピー
                        </button>
                      </div>
                    </div>
                    <pre class="ops-copy-block__text">{item.xMain}</pre>
                  </div>

                  <div class="ops-copy-block hatena-comment">
                    <div class="ops-copy-block__head">
                      <span class="ops-copy-block__label">② コメント（そのまま貼付）</span>
                      <button type="button" class="ops-copy-btn" data-copy={item.hatena.comment}>
                        コピー
                      </button>
                    </div>
                    <pre class="ops-copy-block__text">{item.hatena.comment}</pre>
                    <p class="hatena-comment__title">
                      タイトル欄がある場合: <strong>{item.hatena.title}</strong>
                    </p>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    )
  }

  <section class="ops-legend hatena-legend">
    <h2>使い方</h2>
    <ol>
      <li><strong>Chromeではてブ登録を開く</strong> — URLコピー → Chromeに貼付</li>
      <li><strong>コメントを貼付</strong> — 下の文案をコピー（X用とは別）</li>
      <li>登録後、<strong>Chromeでマイページ</strong>を開いて確認</li>
    </ol>
  </section>
</AdminShell>

<script>
document.querySelectorAll("[data-copy]").forEach((btn) => {
  btn.addEventListener("click", async () => {
    const text = btn.getAttribute("data-copy") || "";
    try {
      await navigator.clipboard.writeText(text);
      const prev = btn.textContent;
      btn.textContent = "コピー済";
      setTimeout(() => { btn.textContent = prev; }, 1200);
    } catch {
      btn.textContent = "失敗";
    }
  });
});

const hash = location.hash.slice(1);
if (hash) {
  requestAnimationFrame(() => {
    document.getElementById(hash)?.scrollIntoView({ behavior: "smooth", block: "start" });
  });
}
</script>
