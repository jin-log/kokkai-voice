---
import AdminShell from "../../../components/admin/AdminShell.astro";
import AdminArticleRow from "../../../components/admin/AdminArticleRow.astro";
import { computeProjectStatus, sortSlugsForAdminPanel } from "../../../lib/project-status.mjs";
import { loadPatrolRuntime } from "../../../lib/patrol-runtime.mjs";
import { policyCategoryLabel, sortPolicyCategories } from "../../../lib/article-categories.mjs";
import { STATUS_DEFINITIONS, AUTOMATION_POLICY, automationModeLabel } from "../../../lib/admin-status-guide.mjs";

const status = await computeProjectStatus().catch(() => null);
const patrol = await loadPatrolRuntime();
const adminSlugs = status ? sortSlugsForAdminPanel(status.slugs) : [];
const activeSlug = status?.slugs?.find((s) => s.runState === "active" || s.slug === patrol.activeSlug);

const statusCounts = {
  todo: 0,
  prep: 0,
  live: 0,
  hidden: 0,
  all: adminSlugs.length,
};
/** @type {Record<string, number>} */
const categoryCounts = {};
for (const s of adminSlugs) {
  if (s.ownerTodo) statusCounts.todo += 1;
  else if (s.adminBucket === "prep") statusCounts.prep += 1;
  else if (s.adminBucket === "live") statusCounts.live += 1;
  else if (s.adminBucket === "hidden") statusCounts.hidden += 1;
  const cat = policyCategoryLabel(s.category);
  categoryCounts[cat] = (categoryCounts[cat] ?? 0) + 1;
}
const policyCategories = Object.keys(categoryCounts).sort(sortPolicyCategories);
---

<AdminShell activeId="articles" title="記事" liveStatus={true}>
  <header class="admin-page-head">
    <h1 class="admin-page-head__title">記事</h1>
    {status && (
      <p class="admin-page-head__meta">
        完成度 <strong id="status-hero-pct">{status.overallGoldPct}%</strong>
        · 公開 <span id="stat-published">{status.publishedCount}/{status.activeCount}</span>
      </p>
    )}
    <p class="admin-page-head__note">記事は4状態だけ。あなたが触るのは「公開する」「非表示」だけ。それ以外は巡回が自動。</p>
  </header>

  <section class="admin-guide" aria-label="状態の意味と自動化">
    <details class="admin-guide__panel admin-disclosure">
      <summary class="admin-disclosure__summary admin-guide__summary">
        <span class="admin-disclosure__chev" aria-hidden="true"></span>
        <span class="admin-disclosure__label">4つの状態の意味（タップで開く）</span>
        <span class="admin-disclosure__hint">タップで表を表示</span>
      </summary>
      <div class="admin-guide__body">
        <table class="admin-guide__table">
          <thead>
            <tr>
              <th>表示</th>
              <th>意味</th>
              <th>自動で直る？</th>
              <th>自動で戻る？</th>
            </tr>
          </thead>
          <tbody>
            {STATUS_DEFINITIONS.map((d) => (
              <tr>
                <td><strong>{d.label}</strong></td>
                <td>{d.meaning}</td>
                <td>{d.autoFix}</td>
                <td>{d.autoRevert}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="admin-guide__note">
          <strong>仮公開</strong>＝サイトに載っているが内部チェックが全部終わっていない記事。
          細かいチェック一覧は各行の「詳細」を開く。
        </p>
        <table class="admin-guide__table admin-guide__table--auto">
          <caption>何が自動で、何が手動か</caption>
          <thead>
            <tr>
              <th>項目</th>
              <th>方式</th>
              <th>補足</th>
            </tr>
          </thead>
          <tbody>
            {AUTOMATION_POLICY.map((p) => (
              <tr>
                <td>{p.channel}</td>
                <td>{automationModeLabel(p.mode)}</td>
                <td>{p.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </details>
  </section>

  <section class="admin-dash__legend admin-dash__legend--compact" aria-label="凡例">
    <p class="admin-dash__legend-inline">
      <span class="admin-row__badge admin-row__badge--state admin-row__badge--bucket-todo admin-dash__legend-chip">公開できる</span>
      <span class="admin-row__badge admin-row__badge--state admin-row__badge--bucket-live admin-dash__legend-chip">公開中</span>
      <span class="admin-row__badge admin-row__badge--state admin-row__badge--bucket-prep admin-dash__legend-chip">準備中</span>
      {activeSlug ? (
        <span class="admin-dash__patrol-inline" id="article-patrol-active">
          今: <strong>{activeSlug.shortTitle}</strong>
        </span>
      ) : patrol.running ? (
        <span class="admin-dash__patrol-inline">巡回待機中（×は動いていない項目）</span>
      ) : null}
    </p>
  </section>

  <section class="admin-create" id="new-article" aria-label="新規作成">
    <header class="admin-create__head">
      <h2 class="admin-create__title">新規記事</h2>
      <p class="admin-create__note">キーワードから生成（別途キーワード検索は下の絞り込み）</p>
    </header>
    <div class="admin-create__row">
      <label class="admin-create__field">
        <span class="admin-filter__label">キーワード</span>
        <input id="new-keyword" type="search" placeholder="例: 消費税減税" class="admin-filter__input" />
      </label>
      <label class="admin-create__field admin-create__field--grow">
        <span class="admin-filter__label">タイトル（任意）</span>
        <input id="new-title" type="text" placeholder="具体疑問タイトルに編集" class="admin-filter__input" />
      </label>
      <button type="button" id="new-generate" class="admin-create__btn">生成する</button>
    </div>
    <div id="new-status" class="admin-create__status" hidden></div>
    <div id="create-log" class="admin-create__log" hidden>
      <p class="admin-create__log-title">最近作成したキーワード</p>
      <ul id="create-log-list" class="admin-create__log-list"></ul>
    </div>
  </section>

  <section class="admin-filter" aria-label="絞り込み・並び替え">
    <header class="admin-filter__head">
      <h2 class="admin-filter__title">絞り込み・並び替え</h2>
      <button type="button" class="admin-filter__reset" id="filter-reset">条件をクリア</button>
    </header>

    <div class="admin-filter__search">
      <label class="admin-filter__label" for="article-search">キーワード</label>
      <input
        id="article-search"
        type="search"
        class="admin-filter__input"
        placeholder="タイトル・slug・政策カテゴリで検索"
        autocomplete="off"
      />
    </div>

    <div class="admin-filter__group admin-filter__group--status">
      <p class="admin-filter__label">公開状態 <span class="admin-filter__hint">いずれか1つ</span></p>
      <div class="admin-filter__pills" id="status-pills" role="group" aria-label="公開状態">
        <button type="button" class="admin-filter__pill is-active" data-filter="todo">
          あなたがやること <span class="admin-filter__pill-n">{statusCounts.todo}</span>
        </button>
        <button type="button" class="admin-filter__pill" data-filter="prep">
          準備中 <span class="admin-filter__pill-n">{statusCounts.prep}</span>
        </button>
        <button type="button" class="admin-filter__pill" data-filter="live">
          公開中 <span class="admin-filter__pill-n">{statusCounts.live}</span>
        </button>
        <button type="button" class="admin-filter__pill" data-filter="hidden">
          非表示 <span class="admin-filter__pill-n">{statusCounts.hidden}</span>
        </button>
        <button type="button" class="admin-filter__pill" data-filter="all">
          すべて <span class="admin-filter__pill-n">{statusCounts.all}</span>
        </button>
      </div>
    </div>

    <div class="admin-filter__group admin-filter__group--category">
      <p class="admin-filter__label">政策カテゴリ <span class="admin-filter__hint">状態と組み合わせ可</span></p>
      <div class="admin-filter__pills" id="category-pills" role="group" aria-label="政策カテゴリ">
        <button type="button" class="admin-filter__pill is-active" data-category="">
          すべて <span class="admin-filter__pill-n">{statusCounts.all}</span>
        </button>
        {
          policyCategories.map((cat) => (
            <button type="button" class="admin-filter__pill" data-category={cat}>
              {cat} <span class="admin-filter__pill-n">{categoryCounts[cat]}</span>
            </button>
          ))
        }
      </div>
    </div>

    <div class="admin-filter__sort">
      <label class="admin-filter__label" for="article-sort">並び替え</label>
      <select id="article-sort" class="admin-filter__select">
        <option value="priority">優先（やること順）</option>
        <option value="gold-asc">完成度 低い順</option>
        <option value="gold-desc">完成度 高い順</option>
        <option value="title">タイトル順</option>
        <option value="category">政策カテゴリ順</option>
      </select>
    </div>

    <p class="admin-filter__result" id="list-count" aria-live="polite"></p>
    <p class="admin-filter__chips" id="active-filters" hidden></p>
  </section>

  {status && (
    <div id="admin-cards" class="admin-list" data-slugs={JSON.stringify(adminSlugs.map((s) => ({
      slug: s.slug,
      title: s.shortTitle,
      filter: s.adminBucket || "prep",
      ownerTodo: Boolean(s.ownerTodo),
      qualityNg: !s.qualityOk,
      goldPct: s.goldPct,
      publishState: s.publishState,
      stalled: Boolean(s.stall?.stalled),
    })))}>
      {adminSlugs.map((s) => (
        <AdminArticleRow s={s} />
      ))}
    </div>
  )}
  <p id="admin-empty" class="admin-list__empty" hidden>該当なし</p>
  <p id="admin-live-error" class="admin-live admin-live--error" hidden></p>
</AdminShell>

<script is:inline>
(function () {
  const KEY = "dev_auth";
  function getPin() { return window.adminGetPin?.() || localStorage.getItem(KEY) || ""; }

  async function callDispatch(action, extra = {}) {
    const res = await fetch("/api/dispatch", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ pin: getPin(), action, ...extra }),
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || data.detail || "エラー");
    return data;
  }

  function adminBucketFrom(s) {
    return s.adminBucket || "prep";
  }

  const FILTER_LABELS = {
    todo: "あなたがやること",
    prep: "準備中",
    live: "公開中",
    hidden: "非表示",
  };

  function updateFilterCounts(slugs) {
    const counts = { todo: 0, prep: 0, live: 0, hidden: 0, all: slugs.length };
    for (const s of slugs) {
      if (s.ownerTodo) counts.todo += 1;
      else if (adminBucketFrom(s) === "prep") counts.prep += 1;
      else if (adminBucketFrom(s) === "live") counts.live += 1;
      else if (adminBucketFrom(s) === "hidden") counts.hidden += 1;
    }
    document.querySelectorAll("#status-pills .admin-filter__pill").forEach((btn) => {
      const f = btn.dataset.filter;
      const n = btn.querySelector(".admin-filter__pill-n");
      if (n && counts[f] != null) n.textContent = String(counts[f]);
    });
  }

  function updateRowQuick(row, s) {
    const quick = row.querySelector(".admin-row__quick");
    if (!quick) return;
    let pubBtn = quick.querySelector(".publish-slug-btn");
    let hint = quick.querySelector("[data-role=gate-hint]");
    const liveLink = quick.querySelector("[data-role=live-link]");

    if (s.publishGateOk && !s.pageReady) {
      if (!pubBtn) {
        pubBtn = document.createElement("button");
        pubBtn.type = "button";
        pubBtn.className = "admin-row__btn admin-row__btn--primary publish-slug-btn";
        pubBtn.dataset.slug = s.slug;
        pubBtn.textContent = "公開する";
        quick.insertBefore(pubBtn, quick.querySelector(".deploy-slug-status"));
      }
      if (hint) hint.remove();
      if (liveLink) liveLink.remove();
      return;
    }

    if (pubBtn) pubBtn.remove();
    if (s.publishState === "live" && !s.adminHidden) {
      if (!liveLink) {
        const existing = quick.querySelector(`a[href="/case/${s.slug}/"]`);
        if (!existing) {
          const a = document.createElement("a");
          a.href = `/case/${s.slug}/`;
          a.className = "admin-row__btn admin-row__btn--ghost";
          a.dataset.role = "live-link";
          a.textContent = "本番を見る";
          quick.insertBefore(a, quick.querySelector(".deploy-slug-status"));
        }
      }
      if (hint) hint.remove();
      return;
    }

    if (liveLink) liveLink.remove();
    if (!hint) {
      hint = document.createElement("span");
      hint.className = "admin-row__gate-hint";
      hint.dataset.role = "gate-hint";
      quick.insertBefore(hint, quick.querySelector(".deploy-slug-status"));
    }
    const f = adminBucketFrom(s);
    if (f === "ready") hint.textContent = "プレビュー確認後「公開する」";
    else if (f === "prep") hint.textContent = `完成度 ${s.goldPct ?? 0}%`;
    else hint.textContent = "—";
  }

  function updateRowBadges(row, s) {
    const badges = row.querySelector(".admin-row__badges");
    if (!badges) return;
    const bucket = adminBucketFrom(s);
    const badgeText =
      s.adminHidden ? "非表示"
      : s.pageReady ? (s.specialPublish ? "仮公開" : "公開中")
      : s.publishGateOk ? "公開できる"
      : s.stall?.stalled ? "自動停止"
      : "準備中";
    let stateBadge = badges.querySelector(".admin-row__badge--state");
    if (!stateBadge) {
      stateBadge = document.createElement("span");
      stateBadge.className = "admin-row__badge admin-row__badge--state";
      badges.prepend(stateBadge);
    }
    stateBadge.className = `admin-row__badge admin-row__badge--state admin-row__badge--bucket-${bucket}`;
    stateBadge.textContent = badgeText;
    row.classList.toggle("admin-row--special", Boolean(s.specialPublish));
    row.dataset.adminBucket = bucket;
    row.dataset.ownerTodo = s.ownerTodo ? "1" : "0";
    row.classList.toggle("admin-row--stalled", Boolean(s.stall?.stalled));
    row.classList.toggle("admin-row--active", (s.workItems ?? []).some((w) => w.state === "active"));
    row.dataset.stall = s.stall?.stalled ? "1" : "0";
    badges.querySelectorAll(".admin-row__badge--live, .admin-row__badge--special, .admin-row__badge--stall, .admin-row__badge--ng, .admin-row__badge--draft").forEach((el) => el.remove());
  }

  function renderWorkItems(row, workItems) {
    const main = row.querySelector(".admin-row__main");
    if (!main) return;
    let ul = row.querySelector(".admin-row__work");
    let ok = row.querySelector(".admin-row__summary--ok");
    if (!workItems?.length) {
      if (ul) ul.remove();
      if (!ok) {
        ok = document.createElement("p");
        ok.className = "admin-row__summary admin-row__summary--ok";
        ok.textContent = "作業項目なし（公開可または完了）";
        const head = row.querySelector(".admin-row__head");
        if (head?.nextSibling) main.insertBefore(ok, head.nextSibling);
        else main.appendChild(ok);
      }
      return;
    }
    if (ok) ok.remove();
    if (!ul) {
      ul = document.createElement("ul");
      ul.className = "admin-row__work";
      ul.setAttribute("aria-label", "未完了の作業");
      const head = row.querySelector(".admin-row__head");
      if (head?.nextSibling) main.insertBefore(ul, head.nextSibling);
      else main.appendChild(ul);
    }
    ul.innerHTML = workItems.map((w) => {
      const cls = w.state === "active" ? "is-active" : "is-blocked";
      const icon = w.state === "active" ? "" : "✕";
      const label = String(w.label || "").replace(/</g, "&lt;");
      return `<li class="admin-row__work-item ${cls}"><span class="admin-row__work-icon" aria-hidden="true">${icon}</span><span>${label}</span></li>`;
    }).join("");
    row.classList.toggle("admin-row--active", workItems.some((w) => w.state === "active"));
  }

  function getStatusFilter() {
    return document.querySelector("#status-pills .admin-filter__pill.is-active")?.dataset.filter || "todo";
  }

  function getCategoryFilter() {
    const btn = document.querySelector("#category-pills .admin-filter__pill.is-active");
    return btn?.dataset.category ?? "";
  }

  function normCategory(raw) {
    const c = (raw || "").trim();
    return c || "未設定";
  }

  function updateActiveChips(q, statusFilter, categoryFilter) {
    const el = document.getElementById("active-filters");
    if (!el) return;
    const chips = [];
    if (q) chips.push(`検索: ${q}`);
    if (statusFilter !== "all") {
      const labels = {
        todo: "あなたがやること",
        prep: "準備中",
        live: "公開中",
        hidden: "非表示",
      };
      chips.push(`状態: ${labels[statusFilter] || statusFilter}`);
    }
    if (categoryFilter) chips.push(`政策: ${categoryFilter}`);
    if (!chips.length) {
      el.hidden = true;
      el.textContent = "";
      return;
    }
    el.hidden = false;
    el.textContent = `適用中 — ${chips.join(" · ")}`;
  }

  function applyFilterSort() {
    const list = document.getElementById("admin-cards");
    if (!list) return;
    const q = (document.getElementById("article-search")?.value || "").trim().toLowerCase();
    const statusFilter = getStatusFilter();
    const categoryFilter = getCategoryFilter();
    const sort = document.getElementById("article-sort")?.value || "priority";
    const rows = [...list.querySelectorAll(".admin-row")];
    const rank = { todo: 0, prep: 1, live: 2, hidden: 3 };
    const catOrder = { 国会: 0, 行政: 1, 地方: 2, 未設定: 3 };
    let visible = 0;

    rows.forEach((row) => {
      const slug = (row.dataset.slug || "").toLowerCase();
      const title = (row.dataset.title || "").toLowerCase();
      const cat = normCategory(row.dataset.category);
      const bucket = row.dataset.adminBucket || "";
      const ownerTodo = row.dataset.ownerTodo === "1";
      let show = true;
      if (q) {
        const hit = slug.includes(q) || title.includes(q) || cat.toLowerCase().includes(q);
        if (!hit) show = false;
      }
      if (statusFilter === "todo") show = show && ownerTodo;
      else if (statusFilter === "prep") show = show && bucket === "prep" && !ownerTodo;
      else if (statusFilter === "live") show = show && bucket === "live";
      else if (statusFilter === "hidden") show = show && bucket === "hidden";
      else if (statusFilter !== "all") show = false;
      if (categoryFilter && cat !== categoryFilter) show = false;
      row.hidden = !show;
      if (show) visible += 1;
    });

    const shown = rows.filter((r) => !r.hidden);
    shown.sort((a, b) => {
      if (sort === "gold-asc") return Number(a.dataset.goldPct) - Number(b.dataset.goldPct);
      if (sort === "gold-desc") return Number(b.dataset.goldPct) - Number(a.dataset.goldPct);
      if (sort === "title") return (a.dataset.title || "").localeCompare(b.dataset.title || "", "ja");
      if (sort === "category") {
        const ca = catOrder[normCategory(a.dataset.category)] ?? 9;
        const cb = catOrder[normCategory(b.dataset.category)] ?? 9;
        if (ca !== cb) return ca - cb;
        return (a.dataset.title || "").localeCompare(b.dataset.title || "", "ja");
      }
      const ra = rank[a.dataset.ownerTodo === "1" ? "todo" : (a.dataset.adminBucket || "prep")] ?? 9;
      const rb = rank[b.dataset.ownerTodo === "1" ? "todo" : (b.dataset.adminBucket || "prep")] ?? 9;
      if (ra !== rb) return ra - rb;
      return Number(a.dataset.goldPct) - Number(b.dataset.goldPct);
    });
    shown.forEach((r) => list.appendChild(r));

    const empty = document.getElementById("admin-empty");
    const count = document.getElementById("list-count");
    if (empty) empty.hidden = visible > 0;
    if (count) {
      count.textContent = visible > 0
        ? `${visible}件表示（全${rows.length}件）`
        : `該当なし（全${rows.length}件）`;
    }
    updateActiveChips(q, statusFilter, categoryFilter);
  }

  function bindPillGroup(groupId, attr, onPick) {
    const group = document.getElementById(groupId);
    if (!group) return;
    group.querySelectorAll(".admin-filter__pill").forEach((btn) => {
      btn.addEventListener("click", () => {
        group.querySelectorAll(".admin-filter__pill").forEach((b) => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        onPick(btn.dataset[attr] ?? "");
        applyFilterSort();
      });
    });
  }

  bindPillGroup("status-pills", "filter", () => {});
  bindPillGroup("category-pills", "category", () => {});

  document.getElementById("filter-reset")?.addEventListener("click", () => {
    const search = document.getElementById("article-search");
    if (search) search.value = "";
    document.querySelectorAll("#status-pills .admin-filter__pill").forEach((b) => {
      b.classList.toggle("is-active", b.dataset.filter === "action");
    });
    document.querySelectorAll("#category-pills .admin-filter__pill").forEach((b) => {
      b.classList.toggle("is-active", b.dataset.category === "");
    });
    const sort = document.getElementById("article-sort");
    if (sort) sort.value = "priority";
    applyFilterSort();
  });

  function renderPatrolAlert(health) {
    const id = "shell-patrol-alert";
    let el = document.getElementById(id);
    const show = health && (health.status === "stalled" || health.status === "paused" || (health.slugStalls?.length ?? 0) > 0);
    if (!show) {
      if (el) el.remove();
      return;
    }
    if (!el) {
      el = document.createElement("section");
      el.id = id;
      el.className = "admin-patrol-alert admin-patrol-alert--stalled";
      el.setAttribute("role", "alert");
      const main = document.querySelector(".admin-main");
      const head = document.querySelector(".admin-page-head");
      if (main) main.insertBefore(el, head || main.firstChild);
    }
    el.className = `admin-patrol-alert ${health.status === "paused" ? "admin-patrol-alert--paused" : "admin-patrol-alert--stalled"}`;
    const loops = (health.slugStalls ?? []).slice(0, 8).map((s) =>
      `<li><strong>${s.shortTitle}</strong><span class="admin-patrol-alert__loop-line">${s.loopLine}</span>${s.ownerHint ? `<span class="admin-patrol-alert__hint">→ ${s.ownerHint}</span>` : ""}</li>`
    ).join("");
    el.innerHTML = `<header class="admin-patrol-alert__head"><strong class="admin-patrol-alert__title">${health.status === "stalled" ? "⚠ 進行停止 — 巡回は動いているが％が上がっていません" : "⏸ 巡回一時停止"}</strong><span class="admin-patrol-alert__badge">${health.statusLabel}</span></header><p class="admin-patrol-alert__msg">${health.message}</p>${health.globalStall ? `<p class="admin-patrol-alert__global">全体: ${health.globalStall.message}</p>` : ""}${loops ? `<details class="admin-patrol-alert__loops" open><summary>ループ中の記事（${health.slugStalls.length}件）</summary><ol class="admin-patrol-alert__loop-list">${loops}</ol></details>` : ""}`;
  }

  function updateRowStall(row, s) {
    const main = row.querySelector(".admin-row__main");
    if (!main) return;
    let box = row.querySelector("[data-role=stall-box]");
    if (!s.stall?.stalled) {
      if (box) box.remove();
      return;
    }
    if (!box) {
      box = document.createElement("div");
      box.className = "admin-row__stall";
      box.dataset.role = "stall-box";
      const explain = row.querySelector("[data-role=status-explain]");
      if (explain?.nextSibling) main.insertBefore(box, explain.nextSibling);
      else main.appendChild(box);
    }
    box.innerHTML = `<p class="admin-row__stall-title">自動処理が止まっている</p>${s.stall.ownerHint ? `<p class="admin-row__stall-hint">${s.stall.ownerHint}</p>` : ""}`;
  }

  async function refreshLiveStatus() {
    const pin = getPin();
    if (!pin) return;
    const badge = document.getElementById("admin-live-badge");
    const err = document.getElementById("admin-live-error");
    try {
      let st = null;
      const ts = Date.now();
      try {
        const r0 = await fetch(`/status-live.json?t=${ts}`);
        if (r0.ok) st = await r0.json();
      } catch { /* local optional */ }
      if (!st) {
        const r1 = await fetch(`/api/project-status?pin=${encodeURIComponent(pin)}&t=${ts}`);
        if (r1.ok) {
          const d1 = await r1.json();
          if (d1.ok && d1.status) st = d1.status;
        }
      }
      if (!st) {
        if (err) { err.hidden = false; err.textContent = "⚠ 状態の取得に失敗しました"; }
        return;
      }
      const pctEl = document.getElementById("status-hero-pct");
      if (pctEl) pctEl.textContent = `${st.overallGoldPct ?? 0}%`;
      const pub = document.getElementById("stat-published");
      if (pub) pub.textContent = `${st.publishedCount}/${st.activeCount}`;
      const gate = document.getElementById("stat-gate");
      if (gate) gate.textContent = `${st.overallGatePct}%`;
      updateFilterCounts(st.slugs ?? []);
      renderPatrolAlert(st.patrolHealth);
      for (const s of st.slugs ?? []) {
        const row = document.querySelector(`.admin-row[data-slug="${s.slug}"]`);
        if (!row) continue;
        row.dataset.goldPct = String(s.goldPct ?? 0);
        row.dataset.qualityNg = s.qualityOk === false ? "1" : "0";
        row.dataset.adminBucket = s.adminBucket || "prep";
        row.dataset.ownerTodo = s.ownerTodo ? "1" : "0";
        row.dataset.publishState = s.publishState || "";
        if (s.category != null) row.dataset.category = s.category;
        const label = row.querySelector(".admin-row__meter-label");
        if (label) label.textContent = String(s.goldPct);
        const fill = row.querySelector(".admin-row__meter-fill");
        if (fill) fill.style.height = `${s.goldPct}%`;
        const bar = row.querySelector(".status-card__bar > span");
        if (bar) bar.style.width = `${s.goldPct}%`;
        renderWorkItems(row, s.workItems);
        updateRowQuick(row, s);
        updateRowBadges(row, s);
        updateRowStall(row, s);
        const explain = row.querySelector("[data-role=status-explain]");
        if (explain && s.statusExplain) explain.textContent = s.statusExplain;
      }
      applyFilterSort();
      if (badge) badge.hidden = false;
      if (err) err.hidden = true;
    } catch {
      if (err) { err.hidden = false; err.textContent = "⚠ ライブ更新エラー"; }
    }
  }

  let pollStarted = false;
  function startLivePoll() {
    if (pollStarted) return;
    pollStarted = true;
    refreshLiveStatus();
    setInterval(refreshLiveStatus, 15000);
  }

  document.getElementById("article-search")?.addEventListener("input", applyFilterSort);
  document.getElementById("article-sort")?.addEventListener("change", applyFilterSort);
  applyFilterSort();

  document.getElementById("new-keyword")?.addEventListener("input", () => {
    const kw = document.getElementById("new-keyword")?.value.trim();
    const titleEl = document.getElementById("new-title");
    if (titleEl && !titleEl.dataset.manual) {
      titleEl.value = kw ? `${kw}（具体疑問タイトルに編集）` : "";
    }
  });
  document.getElementById("new-title")?.addEventListener("input", () => {
    const titleEl = document.getElementById("new-title");
    if (titleEl) titleEl.dataset.manual = "1";
  });
  document.getElementById("new-generate")?.addEventListener("click", async () => {
    const keyword = document.getElementById("new-keyword")?.value.trim();
    const titleIn = document.getElementById("new-title")?.value.trim();
    const statusEl = document.getElementById("new-status");
    const btn = document.getElementById("new-generate");
    if (!keyword) { alert("キーワードを入力してください"); return; }
    if (statusEl) { statusEl.hidden = false; statusEl.className = "admin-create__status is-loading"; statusEl.textContent = "確認中…"; }
    if (btn) btn.disabled = true;
    try {
      const data = await callDispatch("create", { keyword, title: titleIn });
      if (statusEl) { statusEl.className = "admin-create__status is-ok"; statusEl.textContent = "✅ " + data.message; }
      // 生成中ログを即時表示に反映
      if (data.slug) addPendingLogEntry(data.slug, keyword, titleIn || keyword);
      // 3〜5分後に記事が追加されたかポーリング
      if (data.slug) pollForNewArticle(data.slug);
    } catch (e) {
      if (statusEl) { statusEl.className = "admin-create__status is-error"; statusEl.textContent = "❌ " + e.message; }
      alert(e.message);
    } finally { if (btn) btn.disabled = false; }
  });

  /** 生成中エントリを create-log リストに即時追加 */
  function addPendingLogEntry(slug, keyword, title) {
    const box = document.getElementById("create-log");
    const list = document.getElementById("create-log-list");
    if (!box || !list) return;
    box.hidden = false;
    const li = document.createElement("li");
    li.dataset.pendingSlug = slug;
    li.className = "is-pending";
    li.innerHTML = `<time>${new Date().toISOString().slice(0,10)}</time> <strong>${String(title||keyword).replace(/</g,"&lt;")}</strong> <span>— ${String(keyword).replace(/</g,"&lt;")}</span> <code>${slug}</code> <span class="create-log__badge create-log__badge--pending">⏳ 生成中</span>`;
    list.prepend(li);
  }

  /** 記事が index.json に追加されるまでポーリング（最大10分）*/
  async function pollForNewArticle(slug) {
    const list = document.getElementById("create-log-list");
    for (let i = 0; i < 40; i++) {
      await new Promise((r) => setTimeout(r, 15000));
      try {
        const r = await fetch(`/data/article-create-log.json?t=${Date.now()}`);
        if (!r.ok) continue;
        const log = await r.json();
        const entry = (log.entries || []).find((e) => e.slug === slug);
        const li = list?.querySelector(`[data-pending-slug="${slug}"]`);
        if (entry?.status === "done") {
          if (li) li.innerHTML = li.innerHTML.replace(/<span class="create-log__badge[^<]*<\/span>/, '<span class="create-log__badge create-log__badge--done">✅ 完了</span>');
          // 管理画面をリロードして新記事を表示
          setTimeout(() => location.reload(), 1500);
          return;
        }
        if (entry?.status === "failed") {
          if (li) li.innerHTML = li.innerHTML.replace(/<span class="create-log__badge[^<]*<\/span>/, '<span class="create-log__badge create-log__badge--failed">❌ 失敗</span>');
          return;
        }
      } catch { /* retry */ }
    }
    // タイムアウト（10分）
    const li = list?.querySelector(`[data-pending-slug="${slug}"]`);
    if (li) li.innerHTML = li.innerHTML.replace(/<span class="create-log__badge[^<]*<\/span>/, '<span class="create-log__badge create-log__badge--failed">⚠ タイムアウト</span>');
  }

  // 起動時：生成中エントリがあれば自動ポーリング再開
  fetch("/data/article-create-log.json?t=" + Date.now())
    .then((r) => (r.ok ? r.json() : null))
    .then((log) => {
      if (!log?.entries?.length) return;
      for (const e of log.entries) {
        if (e.status === "pending") pollForNewArticle(e.slug);
      }
    })
    .catch(() => {});

  document.getElementById("admin-cards")?.addEventListener("click", async (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    if (t.classList.contains("publish-slug-btn")) {
      const slug = t.dataset.slug;
      const statusEl = document.querySelector(`.deploy-slug-status[data-slug="${slug}"]`);
      if (!confirm(`「${slug}」を一般公開しますか？`)) return;
      t.disabled = true;
      if (statusEl) { statusEl.hidden = false; statusEl.className = "deploy-slug-status is-loading"; statusEl.textContent = "公開処理を起動中…"; }
      try {
        const data = await callDispatch("deploy_article", { slug });
        if (statusEl) {
          statusEl.className = "deploy-slug-status is-ok";
          statusEl.textContent = "✅ 起動済み — 1〜2分待って更新します…";
        }
        const pin = getPin();
        let done = false;
        for (let i = 0; i < 18 && pin; i++) {
          await new Promise((r) => setTimeout(r, 10000));
          try {
            const r = await fetch(`/api/project-status?pin=${encodeURIComponent(pin)}&t=${Date.now()}`);
            if (!r.ok) continue;
            const d = await r.json();
            const row = d.status?.slugs?.find((s) => s.slug === slug);
            if (row?.pageReady || row?.publishState === "live") {
              done = true;
              break;
            }
          } catch { /* retry */ }
        }
        if (statusEl) {
          statusEl.className = done ? "deploy-slug-status is-ok" : "deploy-slug-status is-error";
          statusEl.textContent = done
            ? "✅ 公開反映を確認しました"
            : "⚠ まだ反映されていません。GitHub Actions を確認するか、しばらく後に再読み込みしてください";
        }
        setTimeout(() => location.reload(), done ? 1500 : 8000);
      } catch (err) {
        if (statusEl) { statusEl.className = "deploy-slug-status is-error"; statusEl.textContent = "❌ " + err.message; }
        t.disabled = false;
      }
      return;
    }
    if (t.classList.contains("save-title-btn")) {
      const slug = t.dataset.slug;
      const input = document.querySelector(`.status-card__title-input[data-slug="${slug}"]`);
      const statusEl = document.querySelector(`.title-save-status[data-slug="${slug}"]`);
      const title = input?.value?.trim();
      if (!title) return;
      t.disabled = true;
      if (statusEl) statusEl.hidden = false;
      try {
        const data = await callDispatch("update_title", { slug, title });
        if (statusEl) { statusEl.className = "title-save-status is-ok"; statusEl.textContent = "✅ " + data.message; }
      } catch (err) {
        if (statusEl) { statusEl.className = "title-save-status is-error"; statusEl.textContent = "❌ " + err.message; }
      } finally { t.disabled = false; }
      return;
    }
    const actionMap = { "hide-btn": ["hide", "非表示にしますか？"], "unhide-btn": ["unhide", "表示に戻しますか？"], "delete-btn": ["delete_article", "削除しますか？"] };
    for (const [cls, [action, msg]] of Object.entries(actionMap)) {
      if (!t.classList.contains(cls)) continue;
      const slug = t.dataset.slug;
      if (!confirm(msg)) return;
      const statusEl = document.querySelector(`.admin-action-status[data-slug="${slug}"]`);
      t.disabled = true;
      if (statusEl) statusEl.hidden = false;
      try {
        const data = await callDispatch(action, { slug });
        if (statusEl) { statusEl.className = "admin-action-status is-ok"; statusEl.textContent = "✅ " + data.message; }
        setTimeout(() => location.reload(), 8000);
      } catch (err) {
        if (statusEl) { statusEl.className = "admin-action-status is-error"; statusEl.textContent = "❌ " + err.message; }
        t.disabled = false;
      }
      break;
    }
  });

  window.addEventListener("admin-live-start", startLivePoll);
  window.addEventListener("admin-unlocked", startLivePoll);
  if (localStorage.getItem(KEY) === "1192") queueMicrotask(startLivePoll);

  const STATUS_BADGE = {
    pending: '<span class="create-log__badge create-log__badge--pending">⏳ 生成中</span>',
    done:    '<span class="create-log__badge create-log__badge--done">✅ 完了</span>',
    failed:  '<span class="create-log__badge create-log__badge--failed">❌ 失敗</span>',
  };
  fetch("/data/article-create-log.json?t=" + Date.now())
    .then((r) => (r.ok ? r.json() : null))
    .then((log) => {
      const box = document.getElementById("create-log");
      const list = document.getElementById("create-log-list");
      if (!box || !list || !log?.entries?.length) return;
      box.hidden = false;
      list.innerHTML = log.entries.slice(0, 8).map((e) => {
        const when = (e.at || "").slice(0, 10);
        const title = String(e.title || e.slug).replace(/</g, "&lt;");
        const kw = String(e.keyword || "").replace(/</g, "&lt;");
        const badge = STATUS_BADGE[e.status] || "";
        const cls = e.status === "pending" ? " is-pending" : "";
        return `<li data-pending-slug="${e.slug}"${cls ? ` class="${cls.trim()}"` : ""}><time>${when}</time> <strong>${title}</strong> <span>— ${kw}</span> <code>${e.slug}</code>${badge}</li>`;
      }).join("");
      // 生成中エントリは自動ポーリング（上書きせずポーリングだけ起動）
      for (const e of log.entries) {
        if (e.status === "pending") pollForNewArticle(e.slug);
      }
    })
    .catch(() => {});
})();
</script>
