---
import DevLayout from "../../layouts/DevLayout.astro";
import DevHeader from "../../components/DevHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
---

<DevLayout tabTitle="·">
  <DevHeader current="comments" />
  <div id="dev-gate" style="display:none">
    <main class="container status-page">
      <h1 class="status-page__title">コメント管理</h1>
      <p class="status-page__lead">
        通報されたコメントの確認・非表示。投稿は規約同意後に即公開（人手承認なし）。
      </p>

      <section class="dev-comments-admin">
        <div id="comments-stats" class="dev-comments-admin__stats"></div>
        <p id="comments-error" class="dev-comments-admin__empty" style="color:var(--color-danger)" hidden></p>
        <h2 class="dev-comments-admin__heading">通報あり</h2>
        <ul id="comments-reported" class="dev-comments-admin__list"></ul>
        <p id="comments-reported-empty" class="dev-comments-admin__empty" hidden>通報はありません。</p>
        <h2 class="dev-comments-admin__heading">公開中（直近）</h2>
        <ul id="comments-live" class="dev-comments-admin__list"></ul>
        <p id="comments-live-empty" class="dev-comments-admin__empty" hidden>公開コメントはありません。</p>
      </section>
    </main>
  </div>

  <div id="dev-lock" style="display:none">
    <div style="min-height:60vh;display:flex;align-items:center;justify-content:center">
      <div style="text-align:center;padding:2rem">
        <p style="font-size:1.1rem;margin-bottom:1rem">🔒 PINを入力してください</p>
        <input id="pin-input" type="password" maxlength="8"
          style="font-size:1.5rem;text-align:center;width:8rem;padding:0.5rem;border:2px solid var(--color-border);border-radius:0.5rem"
          placeholder="••••" />
        <br><br>
        <button id="pin-submit"
          style="background:var(--color-primary);color:#fff;border:none;padding:0.6rem 1.5rem;border-radius:2rem;font-size:1rem;cursor:pointer">
          入力
        </button>
        <p id="pin-error" style="color:red;margin-top:0.5rem;display:none">PINが違います</p>
      </div>
    </div>
  </div>
  <SiteFooter note="" />
</DevLayout>

<script>
const PIN = "1192";
const KEY = "dev_auth";

function show(id) { document.getElementById(id).style.display = "block"; }
function hide(id) { document.getElementById(id).style.display = "none"; }

function getPin() {
  return localStorage.getItem(KEY) || PIN;
}

async function api(path, options = {}) {
  const pin = getPin();
  const sep = path.includes("?") ? "&" : "?";
  const url = `${path}${sep}pin=${encodeURIComponent(pin)}`;
  return fetch(url, {
    ...options,
    headers: {
      "Content-Type": "application/json",
      ...(options.headers || {}),
    },
  });
}

function gate() {
  if (localStorage.getItem(KEY) === PIN) {
    show("dev-gate");
    renderQueue();
  } else {
    show("dev-lock");
    document.getElementById("pin-submit").addEventListener("click", () => {
      const val = document.getElementById("pin-input").value;
      if (val === PIN) {
        localStorage.setItem(KEY, PIN);
        hide("dev-lock");
        show("dev-gate");
        renderQueue();
      } else {
        document.getElementById("pin-error").style.display = "block";
      }
    });
  }
}

async function renderQueue() {
  const errEl = document.getElementById("comments-error");
  errEl.hidden = true;

  const [reportedRes, liveRes] = await Promise.all([
    api("/api/comments-admin?status=reported"),
    api("/api/comments-admin?status=approved"),
  ]);
  const reportedData = await reportedRes.json().catch(() => ({}));
  const liveData = await liveRes.json().catch(() => ({}));

  if (!reportedRes.ok && !liveRes.ok) {
    errEl.textContent =
      reportedData.error || liveData.error || `API エラー。D1 バインディングを確認してください。`;
    errEl.hidden = false;
    document.getElementById("comments-stats").textContent = "—";
    document.getElementById("comments-reported").innerHTML = "";
    document.getElementById("comments-live").innerHTML = "";
    return;
  }

  const reported = reportedData.items || [];
  const live = (liveData.items || []).slice(0, 20);

  document.getElementById("comments-stats").textContent =
    `通報あり ${reported.length} 件 / 公開中 ${liveData.items?.length ?? 0} 件`;

  renderList("comments-reported", "comments-reported-empty", reported, "hide", "非表示", true);
  renderList("comments-live", "comments-live-empty", live, "hide", "非表示");
}

function renderList(listId, emptyId, items, primaryAct, primaryLabel, showReportCount = false) {
  const list = document.getElementById(listId);
  list.innerHTML = "";
  document.getElementById(emptyId).hidden = items.length > 0;

  for (const c of items) {
    const li = document.createElement("li");
    li.className = "dev-comments-admin__item";
    const reportBadge =
      showReportCount && c.reportCount
        ? `<span class="dev-comments-admin__reports">通報 ${c.reportCount} 件</span>`
        : "";
    li.innerHTML = `
      <div class="dev-comments-admin__meta">
        <strong>${escapeHtml(c.name || "匿名")}</strong>
        ${reportBadge}
        <span><a href="/case/${c.slug}/">/case/${c.slug}/</a></span>
        <time>${c.at ? new Date(c.at).toLocaleString("ja-JP") : ""}</time>
      </div>
      <p class="dev-comments-admin__body"></p>
      <div class="dev-comments-admin__actions">
        <button type="button" class="dev-deploy__btn" data-act="${primaryAct}">${primaryLabel}</button>
      </div>`;
    li.querySelector(".dev-comments-admin__body").textContent = c.body;
    li.querySelector(`[data-act="${primaryAct}"]`).addEventListener("click", () =>
      moderate(c.id, primaryAct),
    );
    list.appendChild(li);
  }
}

async function moderate(id, action) {
  const res = await api("/api/comments-admin", {
    method: "POST",
    body: JSON.stringify({ id, action }),
  });
  if (!res.ok) {
    const data = await res.json().catch(() => ({}));
    alert(data.error || "操作に失敗しました");
    return;
  }
  renderQueue();
}

function escapeHtml(s) {
  return String(s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

gate();
</script>
