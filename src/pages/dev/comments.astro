---
import AdminShell from "../../components/admin/AdminShell.astro";
---

<AdminShell activeId="comments" title="コメント">
  <div id="comments-alert" class="admin-alert-band admin-alert-band--danger" hidden></div>

  <header class="admin-page-head">
    <h1 class="admin-page-head__title">コメント</h1>
    <p class="admin-page-head__note">通報優先で確認。卑猥語・殺害予告のみ自動拒否。</p>
  </header>

  <div id="comments-kpi" class="admin-kpi-bar" role="group"></div>

  <div class="admin-filter admin-filter--sticky">
    <div class="admin-filter__pills" role="tablist">
      <button type="button" class="admin-filter__pill is-active" data-tab="reported" role="tab">
        通報あり <span id="tab-count-reported" class="admin-filter__pill-n"></span>
      </button>
      <button type="button" class="admin-filter__pill" data-tab="approved" role="tab">
        公開中 <span id="tab-count-approved" class="admin-filter__pill-n"></span>
      </button>
      <button type="button" class="admin-filter__pill" data-tab="rejected" role="tab">
        非表示 <span id="tab-count-rejected" class="admin-filter__pill-n"></span>
      </button>
    </div>
    <div class="admin-filter__search" style="margin-top:0.65rem">
      <input type="search" id="comments-filter" class="admin-filter__input" placeholder="記事 slug で検索" />
      <button type="button" class="admin-row__btn" id="comments-refresh" style="margin-top:0.5rem">更新</button>
    </div>
  </div>

  <p id="comments-error" class="dev-comments-admin__empty dev-comments-admin__error" hidden></p>
  <div id="comments-list" class="admin-list" role="tabpanel"></div>
  <p id="comments-empty" class="admin-list__empty" hidden>該当コメントはありません。</p>
</AdminShell>

<script>
const PIN = "1192";
const KEY = "dev_auth";
let activeTab = "reported";
let slugFilter = "";
let cache = { reported: [], approved: [], rejected: [] };

function getPin() {
  return window.adminGetPin?.() || localStorage.getItem(KEY) || PIN;
}

async function api(path, options = {}) {
  const pin = getPin();
  const sep = path.includes("?") ? "&" : "?";
  return fetch(`${path}${sep}pin=${encodeURIComponent(pin)}`, {
    ...options,
    headers: { "Content-Type": "application/json", ...(options.headers || {}) },
  });
}

function bindUi() {
  document.querySelectorAll("[data-tab]").forEach((btn) => {
    btn.addEventListener("click", () => {
      activeTab = btn.dataset.tab;
      document.querySelectorAll("[data-tab]").forEach((b) => {
        b.classList.toggle("is-active", b === btn);
      });
      renderList();
    });
  });
  document.getElementById("comments-refresh")?.addEventListener("click", loadAll);
  document.getElementById("comments-filter")?.addEventListener("input", (e) => {
    slugFilter = e.target.value.trim().toLowerCase();
    renderList();
  });
}

async function loadAll() {
  const errEl = document.getElementById("comments-error");
  errEl.hidden = true;

  const [summaryRes, reportedRes, approvedRes, rejectedRes] = await Promise.all([
    api("/api/comments-admin?status=summary"),
    api("/api/comments-admin?status=reported"),
    api("/api/comments-admin?status=approved"),
    api("/api/comments-admin?status=rejected"),
  ]);

  const summary = await summaryRes.json().catch(() => ({}));
  if (!summaryRes.ok) {
    errEl.textContent = summary.error || "API エラー。D1 バインディングを確認してください。";
    errEl.hidden = false;
    return;
  }

  cache.reported = (await reportedRes.json().catch(() => ({}))).items || [];
  cache.approved = (await approvedRes.json().catch(() => ({}))).items || [];
  cache.rejected = (await rejectedRes.json().catch(() => ({}))).items || [];

  const kpi = document.getElementById("comments-kpi");
  if (kpi) {
    kpi.innerHTML = [
      { label: "要対応", value: summary.reported, tone: summary.reported ? "danger" : "" },
      { label: "公開", value: summary.approved },
      { label: "非表示", value: summary.rejected },
      { label: "通報計", value: summary.reportsTotal, tone: "warn" },
    ]
      .map(
        (x) =>
          `<div class="admin-kpi-bar__cell${x.tone ? ` is-${x.tone}` : ""}"><span class="admin-kpi-bar__label">${x.label}</span><span class="admin-kpi-bar__value">${x.value}</span></div>`,
      )
      .join("");
  }

  const alert = document.getElementById("comments-alert");
  if (alert) {
    if (summary.reported > 0) {
      alert.textContent = `通報 ${summary.reported} 件 — 要確認`;
      alert.hidden = false;
    } else {
      alert.hidden = true;
    }
  }

  document.getElementById("tab-count-reported").textContent = summary.reported || "";
  document.getElementById("tab-count-approved").textContent = summary.approved || "";
  document.getElementById("tab-count-rejected").textContent = summary.rejected || "";

  if (summary.reported > 0) activeTab = "reported";
  document.querySelectorAll("[data-tab]").forEach((b) => {
    b.classList.toggle("is-active", b.dataset.tab === activeTab);
  });

  renderList();
}

function renderList() {
  const list = document.getElementById("comments-list");
  const empty = document.getElementById("comments-empty");
  let items = cache[activeTab] || [];
  if (slugFilter) {
    items = items.filter((c) => String(c.slug || "").toLowerCase().includes(slugFilter));
  }

  list.innerHTML = "";
  empty.hidden = items.length > 0;

  for (const c of items) {
    const row = document.createElement("article");
    row.className = `admin-row${c.reportCount > 0 ? " admin-row--quality-ng" : ""}`;
    const hideBtn =
      c.status === "approved"
        ? `<button type="button" class="admin-row__btn admin-row__btn--danger" data-act="hide">非表示</button>`
        : "";
  row.innerHTML = `
      <div class="admin-row__grid admin-row__grid--fluid">
        <div class="admin-row__main">
          <header class="admin-row__head">
            <h3 class="admin-row__title">${escapeHtml(c.name || "匿名")}</h3>
            ${c.reportCount > 0 ? `<span class="admin-row__badge admin-row__badge--ng">通報 ${c.reportCount}</span>` : ""}
          </header>
          <p class="admin-row__summary admin-clamp-2">${escapeHtml(c.body)}</p>
          <p class="admin-row__summary" style="margin-top:0.35rem">
            <a href="/case/${c.slug}/#sec-mood" target="_blank" rel="noopener">${escapeHtml(c.slug)}</a>
            · 投稿 ${formatAt(c.at)}
            ${c.lastReportAt ? ` · 通報 ${formatAt(c.lastReportAt)}` : ""}
          </p>
        </div>
        <div class="admin-row__quick">
          ${hideBtn}
          <button type="button" class="admin-row__btn admin-row__btn--ghost" data-copy>コピー</button>
        </div>
      </div>`;
    row.querySelector('[data-act="hide"]')?.addEventListener("click", () => moderate(c.id, "hide"));
    row.querySelector("[data-copy]")?.addEventListener("click", async (ev) => {
      await navigator.clipboard.writeText(c.body);
      const btn = ev.currentTarget;
      btn.textContent = "済";
      setTimeout(() => { btn.textContent = "コピー"; }, 1500);
    });
    list.appendChild(row);
  }
}

async function moderate(id, action) {
  if (!confirm("このコメントを非表示にしますか？")) return;
  const res = await api("/api/comments-admin", {
    method: "POST",
    body: JSON.stringify({ id, action }),
  });
  if (!res.ok) {
    const data = await res.json().catch(() => ({}));
    alert(data.error || "操作に失敗しました");
    return;
  }
  await loadAll();
}

function formatAt(iso) {
  return iso ? new Date(iso).toLocaleString("ja-JP") : "—";
}

function escapeHtml(s) {
  return String(s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function boot() {
  bindUi();
  const gate = document.getElementById("admin-gate");
  if (!gate?.hidden) loadAll();
  else window.addEventListener("admin-unlocked", loadAll, { once: true });
}

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", boot);
} else {
  boot();
}
</script>
