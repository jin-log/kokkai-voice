---
import DevLayout from "../../layouts/DevLayout.astro";
import DevHeader from "../../components/DevHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
---

<DevLayout tabTitle="·">
  <DevHeader current="comments" />
  <div id="dev-gate" style="display:none">
    <main class="container status-page dev-comments-page">
      <h1 class="status-page__title">コメント管理</h1>
      <p class="status-page__lead">
        通報優先で確認。自動拒否は卑猥語・殺害予告のみ（YouTube型）。それ以外は通報で対応。
      </p>

      <section class="dev-comments-admin">
        <div class="dev-comments-admin__toolbar">
          <div id="comments-stats" class="dev-comments-admin__stats"></div>
          <div class="dev-comments-admin__tools">
            <input
              type="search"
              id="comments-filter"
              class="dev-comments-admin__filter"
              placeholder="案件 slug で絞り込み"
              aria-label="案件 slug で絞り込み"
            />
            <button type="button" class="dev-deploy__btn" id="comments-refresh">更新</button>
          </div>
        </div>
        <p id="comments-error" class="dev-comments-admin__empty dev-comments-admin__error" hidden></p>

        <div class="dev-comments-admin__tabs" role="tablist">
          <button type="button" class="dev-comments-admin__tab is-active" data-tab="reported" role="tab">
            通報あり <span id="tab-count-reported" class="dev-comments-admin__tab-count"></span>
          </button>
          <button type="button" class="dev-comments-admin__tab" data-tab="approved" role="tab">
            公開中 <span id="tab-count-approved" class="dev-comments-admin__tab-count"></span>
          </button>
          <button type="button" class="dev-comments-admin__tab" data-tab="rejected" role="tab">
            非表示済み <span id="tab-count-rejected" class="dev-comments-admin__tab-count"></span>
          </button>
        </div>

        <ul id="comments-list" class="dev-comments-admin__list" role="tabpanel"></ul>
        <p id="comments-empty" class="dev-comments-admin__empty" hidden>該当コメントはありません。</p>
      </section>
    </main>
  </div>

  <div id="dev-lock" style="display:none">
    <div style="min-height:60vh;display:flex;align-items:center;justify-content:center">
      <div style="text-align:center;padding:2rem">
        <p style="font-size:1.1rem;margin-bottom:1rem">🔒 PINを入力してください</p>
        <input id="pin-input" type="password" maxlength="8"
          style="font-size:1.5rem;text-align:center;width:8rem;padding:0.5rem;border:2px solid var(--color-border);border-radius:0.5rem"
          placeholder="••••" />
        <br><br>
        <button id="pin-submit"
          style="background:var(--color-primary);color:#fff;border:none;padding:0.6rem 1.5rem;border-radius:2rem;font-size:1rem;cursor:pointer">
          入力
        </button>
        <p id="pin-error" style="color:red;margin-top:0.5rem;display:none">PINが違います</p>
      </div>
    </div>
  </div>
  <SiteFooter note="" />
</DevLayout>

<script>
const PIN = "1192";
const KEY = "dev_auth";
let activeTab = "reported";
let slugFilter = "";
let cache = { reported: [], approved: [], rejected: [] };

function show(id) { document.getElementById(id).style.display = "block"; }
function hide(id) { document.getElementById(id).style.display = "none"; }

function getPin() {
  return localStorage.getItem(KEY) || PIN;
}

async function api(path, options = {}) {
  const pin = getPin();
  const sep = path.includes("?") ? "&" : "?";
  const url = `${path}${sep}pin=${encodeURIComponent(pin)}`;
  return fetch(url, {
    ...options,
    headers: {
      "Content-Type": "application/json",
      ...(options.headers || {}),
    },
  });
}

function gate() {
  if (localStorage.getItem(KEY) === PIN) {
    show("dev-gate");
    bindUi();
    loadAll();
  } else {
    show("dev-lock");
    document.getElementById("pin-submit").addEventListener("click", () => {
      const val = document.getElementById("pin-input").value;
      if (val === PIN) {
        localStorage.setItem(KEY, PIN);
        hide("dev-lock");
        show("dev-gate");
        bindUi();
        loadAll();
      } else {
        document.getElementById("pin-error").style.display = "block";
      }
    });
  }
}

function bindUi() {
  document.querySelectorAll("[data-tab]").forEach((btn) => {
    btn.addEventListener("click", () => {
      activeTab = btn.dataset.tab;
      document.querySelectorAll("[data-tab]").forEach((b) => {
        b.classList.toggle("is-active", b === btn);
      });
      renderList();
    });
  });
  document.getElementById("comments-refresh")?.addEventListener("click", loadAll);
  document.getElementById("comments-filter")?.addEventListener("input", (e) => {
    slugFilter = e.target.value.trim().toLowerCase();
    renderList();
  });
}

async function loadAll() {
  const errEl = document.getElementById("comments-error");
  errEl.hidden = true;

  const [summaryRes, reportedRes, approvedRes, rejectedRes] = await Promise.all([
    api("/api/comments-admin?status=summary"),
    api("/api/comments-admin?status=reported"),
    api("/api/comments-admin?status=approved"),
    api("/api/comments-admin?status=rejected"),
  ]);

  const summary = await summaryRes.json().catch(() => ({}));
  const reportedData = await reportedRes.json().catch(() => ({}));
  const approvedData = await approvedRes.json().catch(() => ({}));
  const rejectedData = await rejectedRes.json().catch(() => ({}));

  if (!summaryRes.ok) {
    errEl.textContent = summary.error || "API エラー。D1 バインディングを確認してください。";
    errEl.hidden = false;
    return;
  }

  cache.reported = reportedData.items || [];
  cache.approved = approvedData.items || [];
  cache.rejected = rejectedData.items || [];

  document.getElementById("comments-stats").textContent =
    `通報 ${summary.reportsTotal} 件 / 要対応 ${summary.reported} 件 / 公開 ${summary.approved} 件 / 非表示 ${summary.rejected} 件`;

  document.getElementById("tab-count-reported").textContent =
    summary.reported ? `(${summary.reported})` : "";
  document.getElementById("tab-count-approved").textContent =
    summary.approved ? `(${summary.approved})` : "";
  document.getElementById("tab-count-rejected").textContent =
    summary.rejected ? `(${summary.rejected})` : "";

  if (summary.reported > 0) activeTab = "reported";
  document.querySelectorAll("[data-tab]").forEach((b) => {
    b.classList.toggle("is-active", b.dataset.tab === activeTab);
  });

  renderList();
}

function renderList() {
  const list = document.getElementById("comments-list");
  const empty = document.getElementById("comments-empty");
  let items = cache[activeTab] || [];

  if (slugFilter) {
    items = items.filter((c) => String(c.slug || "").toLowerCase().includes(slugFilter));
  }

  list.innerHTML = "";
  empty.hidden = items.length > 0;

  for (const c of items) {
    const li = document.createElement("li");
    li.className = "dev-comments-admin__item";
    const reportMeta =
      c.reportCount > 0
        ? `<span class="dev-comments-admin__reports">通報 ${c.reportCount} 件</span>
           <time class="dev-comments-admin__report-time">最終 ${formatAt(c.lastReportAt)}</time>`
        : "";
    const hideBtn =
      c.status === "approved"
        ? `<button type="button" class="dev-deploy__btn dev-admin-btn--danger" data-act="hide">非表示にする</button>`
        : "";
    li.innerHTML = `
      <div class="dev-comments-admin__meta">
        <strong>${escapeHtml(c.name || "匿名")}</strong>
        ${reportMeta}
        <a class="dev-comments-admin__case" href="/case/${c.slug}/#sec-mood" target="_blank" rel="noopener">案件: ${escapeHtml(c.slug)} ↗</a>
        <time>投稿 ${formatAt(c.at)}</time>
      </div>
      <p class="dev-comments-admin__body"></p>
      <div class="dev-comments-admin__actions">
        ${hideBtn}
        <button type="button" class="dev-deploy__btn dev-comments-admin__copy" data-copy>本文コピー</button>
      </div>`;
    li.querySelector(".dev-comments-admin__body").textContent = c.body;
    li.querySelector('[data-act="hide"]')?.addEventListener("click", () => moderate(c.id, "hide"));
    li.querySelector("[data-copy]")?.addEventListener("click", async () => {
      await navigator.clipboard.writeText(c.body);
      const btn = li.querySelector("[data-copy]");
      btn.textContent = "コピー済み";
      setTimeout(() => { btn.textContent = "本文コピー"; }, 1500);
    });
    list.appendChild(li);
  }
}

async function moderate(id, action) {
  if (!confirm("このコメントを非表示にしますか？")) return;
  const res = await api("/api/comments-admin", {
    method: "POST",
    body: JSON.stringify({ id, action }),
  });
  if (!res.ok) {
    const data = await res.json().catch(() => ({}));
    alert(data.error || "操作に失敗しました");
    return;
  }
  await loadAll();
}

function formatAt(iso) {
  return iso ? new Date(iso).toLocaleString("ja-JP") : "—";
}

function escapeHtml(s) {
  return String(s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

gate();
</script>
