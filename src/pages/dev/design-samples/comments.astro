---
import AdminShell from "../../../components/admin/AdminShell.astro";
import AdminKpiBar from "../../../components/admin/AdminKpiBar.astro";
import AdminAlertBand from "../../../components/admin/AdminAlertBand.astro";
---

<AdminShell activeId="comments" title="コメント">
  <div class="admin-preview-ribbon"><span class="admin-preview-ribbon__dot"></span>デザイン案</div>

  <AdminAlertBand tone="danger">通報 2件 — 要確認</AdminAlertBand>

  <header class="admin-page-head">
    <h1 class="admin-page-head__title">コメント</h1>
  </header>

  <AdminKpiBar items={[
    { label: "要対応", value: "2", tone: "danger" },
    { label: "公開", value: "48" },
    { label: "非表示", value: "3" },
    { label: "通報", value: "2", tone: "warn" },
  ]} />

  <div class="admin-filter admin-filter--sticky">
    <div class="admin-filter__pills">
      <button type="button" class="admin-filter__pill is-active">通報あり<span class="admin-filter__pill-n">2</span></button>
      <button type="button" class="admin-filter__pill">公開中</button>
      <button type="button" class="admin-filter__pill">非表示</button>
    </div>
    <div class="admin-filter__search" style="margin-top:0.65rem">
      <input type="search" class="admin-filter__input" placeholder="記事 slug で検索" />
    </div>
  </div>

  <div class="admin-list">
    <article class="admin-row admin-row--quality-ng">
      <div class="admin-row__grid admin-row__grid--fluid">
        <div class="admin-row__main">
          <header class="admin-row__head">
            <h3 class="admin-row__title">防衛特別税の行方</h3>
            <span class="admin-row__badge admin-row__badge--ng">通報1</span>
          </header>
          <p class="admin-row__summary admin-clamp-2">匿名 · これは事実と違うのではないでしょうか。出典の確認をお願いします。</p>
        </div>
        <div class="admin-row__quick">
          <button type="button" class="admin-row__btn admin-row__btn--danger">却下</button>
          <button type="button" class="admin-row__btn admin-row__btn--primary">承認</button>
        </div>
      </div>
    </article>
  </div>
</AdminShell>
