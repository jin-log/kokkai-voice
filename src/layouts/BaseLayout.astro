---
import { ASSET_V } from "../lib/case-helpers.mjs";
import { SITE } from "../lib/site-config.mjs";
import "../styles/tokens.css";
import "../styles/main.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  bodyClass?: string;
  bodyDataCase?: string;
  includeAppJs?: boolean;
  enableAds?: boolean;
}

const {
  title,
  description = "政治家の発言と行動を追いかける。あの話どうなった？ 国会議事録＋X投稿を案件ごとに整理した政治解説メディア。",
  ogImage = `/assets/og-default.png?v=${ASSET_V}`,
  ogImageAlt = `${SITE.name} — あの話どうなった？`,
  noindex = false,
  bodyClass,
  bodyDataCase,
  includeAppJs = false,
  enableAds = !noindex,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, "https://seiji1192.site").href;
const ogImageUrl = new URL(ogImage, "https://seiji1192.site").href;
const adsClient = SITE.adsensePubId;
const showAds = enableAds && adsClient;
const gaId = SITE.gaMeasurementId;
const productionHosts = SITE.productionHosts;
const cfBeaconToken = "99a12445d1fc46a186cb3189f679088d";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="ja_JP" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@seiji1192site" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="icon" href="/assets/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
  </head>
  <body class:list={[bodyClass]} data-case={bodyDataCase}>
    <slot />
    {includeAppJs && <script is:inline src={`/js/app.js?v=${ASSET_V}`}></script>}
    <script
      is:inline
      define:vars={{ gaId, adsClient, showAds, productionHosts, cfBeaconToken }}
    >
      (function () {
        var host = location.hostname;
        var prod = productionHosts.indexOf(host) >= 0;
        if (!prod) {
          var robots = document.createElement("meta");
          robots.name = "robots";
          robots.content = "noindex,nofollow";
          document.head.appendChild(robots);
          return;
        }
        function loadScript(src, attrs) {
          var s = document.createElement("script");
          s.async = true;
          s.src = src;
          if (attrs) {
            Object.keys(attrs).forEach(function (k) {
              s.setAttribute(k, attrs[k]);
            });
          }
          document.head.appendChild(s);
        }
        if (gaId) {
          loadScript("https://www.googletagmanager.com/gtag/js?id=" + encodeURIComponent(gaId));
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            window.dataLayer.push(arguments);
          }
          window.gtag = gtag;
          gtag("js", new Date());
          gtag("config", gaId, { anonymize_ip: true });
        }
        if (showAds && adsClient) {
          var adsMeta = document.createElement("meta");
          adsMeta.name = "google-adsense-account";
          adsMeta.content = adsClient;
          document.head.appendChild(adsMeta);
          loadScript(
            "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=" +
              encodeURIComponent(adsClient),
            { crossorigin: "anonymous" },
          );
        }
        if (cfBeaconToken) {
          var cf = document.createElement("script");
          cf.defer = true;
          cf.src = "https://static.cloudflareinsights.com/beacon.min.js";
          cf.setAttribute("data-cf-beacon", JSON.stringify({ token: cfBeaconToken }));
          document.body.appendChild(cf);
        }
      })();
    </script>
  </body>
</html>
